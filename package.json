    "admin:seed": "node --env-file=.env.local scripts/admin-seed.mjs"
  },
  "dependencies": {
    "@astrojs/node": "^10.0.6",
    "@astrojs/react": "^5.0.4",
    "@nanostores/react": "^1.1.0",
