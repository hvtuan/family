# Phase 2 admin — Supabase credentials.
# Copy to .env.local (gitignored) and fill in real values.

# Public, browser-safe
PUBLIC_SUPABASE_URL=https://supabase.huynhvantuan.net
PUBLIC_SUPABASE_ANON_KEY=eyJ...your.anon.key...
PUBLIC_SUPABASE_SCHEMA=family

# Server-only — NEVER expose to client. Used by build pipeline + admin endpoints.
SUPABASE_SERVICE_ROLE_KEY=eyJ...your.service.role.key...

# Direct DB connection for running migrations (scripts/db-migrate.mjs).
# Either of these works:
#   - Direct (port 5432):  postgres://postgres:<password>@db.<ref>.supabase.co:5432/postgres
#   - Pooler (port 6543):  postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=postgres://postgres:PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Email seeded into allowed_emails as role=admin during migration.
# Sign in to /admin with this email to gain admin access.
ADMIN_EMAIL=you@example.com

# Optional, for the email-notify-on-signup feature in P4.
# RESEND_API_KEY=re_...
