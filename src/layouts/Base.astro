---
import "@/styles/global.css";
import { SITE, NAV_LINKS } from "@/data/site";
import { getLocations, getMembers } from "@/lib/content";
import { toClientMember } from "@/lib/members-client";
import ThemeSwitcher from "@/components/react/ThemeSwitcher";
import MemberModal from "@/components/react/MemberModal";

interface Props {
  title?: string;
  description?: string;
  pageKey?: string;
}

const { title, description, pageKey } = Astro.props;
const pageTitle = title ? `${title} — ${SITE.brand.vi}` : SITE.brand.vi;
const pageDesc =
  description ?? `${SITE.brand.vi} • ${SITE.hometown} • ${SITE.motto}`;
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";

const allMembers = await getMembers((entry) => entry.data.status === "published");
const clientMembers = allMembers.map(toClientMember);

// Build a name → coords lookup so the MemberModal can show a small map
// when birthPlace / deathPlace / gravesite text matches a known location.
const locationEntries = await getLocations();
type LocationLookupEntry = {
  name: string;
  lat: number;
  lng: number;
  province?: string;
};
const locationLookup: Record<string, LocationLookupEntry> = {};
for (const loc of locationEntries) {
  if (
    typeof loc.data.coords?.lat !== "number" ||
    typeof loc.data.coords?.lng !== "number"
  ) {
    continue;
  }
  const entry: LocationLookupEntry = {
    name: loc.data.name,
    lat: loc.data.coords.lat,
    lng: loc.data.coords.lng,
    province: loc.data.province,
  };
  // Index by both vi name and en name (lowercase) so substring matches
  // on either work in the modal.
  locationLookup[loc.data.name.toLowerCase()] = entry;
  if (loc.data.nameEn) {
    locationLookup[loc.data.nameEn.toLowerCase()] = entry;
  }
}

const googleMapsApiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY ?? "";
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="light" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <script is:inline>
      (() => {
        try {
          const t = localStorage.getItem("theme");
          if (t === "scroll" || t === "modern" || t === "classic") {
            document.documentElement.dataset.theme = t;
          } else {
            document.documentElement.dataset.theme = "classic";
          }
        } catch {
          document.documentElement.dataset.theme = "classic";
        }
      })();
    </script>
  </head>

  <body data-page={pageKey}>
    <a
      href="#main"
      class="absolute -left-[9999px] top-0 bg-ink text-paper px-4 py-3 z-[100] rounded-br-lg focus:left-0"
    >
      Bỏ qua tới nội dung
    </a>

    <header class="sticky top-0 z-30 border-b border-line backdrop-blur-md [background:color-mix(in_oklab,var(--color-paper)_88%,transparent)]">
      <div class="max-w-[1240px] mx-auto px-5 py-3.5 flex flex-wrap gap-4 items-center justify-between">
        <a
          href="/"
          class="inline-flex items-center gap-3 text-ink"
          aria-label={`${SITE.brand.vi} • ${SITE.brand.en}`}
        >
          <span class="inline-flex items-center justify-center w-11 h-11 border-2 border-vermilion text-vermilion bg-vermilion/[0.04] rounded-lg font-display font-bold text-[0.7rem] tracking-wider">
            {SITE.monogram}
          </span>
          <span class="flex flex-col leading-tight">
            <span class="font-display font-bold text-[1.05rem]">{SITE.brand.vi}</span>
            <span class="text-[0.7rem] tracking-[0.16em] uppercase text-ink-3">
              {SITE.brand.en}
            </span>
          </span>
        </a>

        <nav
          class="primary-nav max-[968px]:order-3 max-[968px]:basis-full"
          aria-label="Điều hướng chính"
        >
          <ul class="list-none m-0 p-0 flex flex-wrap gap-x-3.5 gap-y-1 justify-end max-[968px]:justify-center">
            {
              NAV_LINKS.map((link) => {
                const active =
                  link.href === "/"
                    ? currentPath === "/"
                    : currentPath.startsWith(link.href);
                return (
                  <li>
                    <a
                      href={link.href}
                      title={link.en}
                      aria-current={active ? "page" : undefined}
                      class:list={[
                        "inline-flex items-center px-3 py-1.5 rounded-md text-sm transition-colors",
                        active
                          ? "bg-paper-2 text-ink [box-shadow:inset_0_-2px_0_var(--color-vermilion)]"
                          : "text-ink-2 hover:bg-paper-2 hover:text-ink",
                      ]}
                    >
                      {link.vi}
                    </a>
                  </li>
                );
              })
            }
          </ul>
        </nav>

        <div class="flex items-center gap-2">
          <ThemeSwitcher client:load />
        </div>
      </div>
    </header>

    <main id="main" class="min-h-[60vh]"><slot /></main>

    <MemberModal
      client:load
      members={clientMembers}
      locationLookup={locationLookup}
      googleMapsApiKey={googleMapsApiKey}
    />

    <footer class="mt-24 border-t border-line bg-paper-2 u-paper-texture">
      <div class="max-w-[1240px] mx-auto px-5 py-14">
        <!-- Top: motto in script, centered, with blossom marks. -->
        <div class="flex items-center justify-center gap-4 mb-10">
          <span aria-hidden="true" class="h-px w-16 bg-line-strong"></span>
          <span aria-hidden="true" class="text-vermilion text-xl">❀</span>
          <p class="font-script italic text-2xl text-jade m-0">"{SITE.motto}"</p>
          <span aria-hidden="true" class="text-vermilion text-xl">❀</span>
          <span aria-hidden="true" class="h-px w-16 bg-line-strong"></span>
        </div>

        <!-- 3-col grid -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 text-center sm:text-left">
          <!-- Brand -->
          <div class="flex flex-col items-center sm:items-start gap-3">
            <span class="inline-flex items-center justify-center w-14 h-14 rounded-md border-2 border-vermilion text-vermilion bg-vermilion/[0.04] font-display font-bold text-xs tracking-wider">
              {SITE.monogram}
            </span>
            <div>
              <p class="font-display font-bold text-lg text-ink m-0 leading-tight">
                {SITE.brand.vi}
              </p>
              <p class="text-2xs tracking-wider uppercase text-ink-3 mt-1" lang="en">
                {SITE.brand.en}
              </p>
            </div>
          </div>

          <!-- Place -->
          <div class="flex flex-col items-center sm:items-start gap-2">
            <p class="u-kicker">Quê hương</p>
            <p class="text-base text-ink leading-relaxed m-0">
              {SITE.hometown}
            </p>
            <p class="text-sm text-ink-3 tabular-nums m-0">
              Thành lập năm <span class="text-ink font-semibold">{SITE.established}</span>
            </p>
          </div>

          <!-- Nav columns -->
          <div class="flex flex-col items-center sm:items-start gap-2">
            <p class="u-kicker">Liên kết</p>
            <ul class="list-none m-0 p-0 flex flex-col gap-1.5 text-sm">
              <li><a href="/family-tree" class="text-ink-2 hover:text-vermilion">Cây gia phả</a></li>
              <li><a href="/members" class="text-ink-2 hover:text-vermilion">Thành viên</a></li>
              <li><a href="/album" class="text-ink-2 hover:text-vermilion">Album</a></li>
              <li><a href="/timeline" class="text-ink-2 hover:text-vermilion">Mốc thời gian</a></li>
              <li><a href="/admin/login" class="text-ink-3 hover:text-vermilion text-xs">· Admin</a></li>
            </ul>
          </div>
        </div>

        <!-- Bottom: privacy note -->
        <div class="mt-12 pt-6 border-t border-line text-center">
          <p class="text-2xs tracking-wider uppercase text-ink-3 opacity-90 m-0">
            Trang gia phả riêng tư — không công khai chỉ mục
          </p>
          <p class="text-2xs text-ink-3 opacity-60 mt-1" lang="en">
            Private genealogy site, not indexed
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
