---
import "@/styles/global.css";
import { NAV_LINKS } from "@/data/site";
import { getLocations, getMembers } from "@/lib/content";
import { toClientMember } from "@/lib/members-client";
import {
  getSiteIdentity,
  getGoogleMapsApiKey,
  getSeoMeta,
  getSocialLinks,
  getAnalyticsConfig,
  getPrivacyToggles,
} from "@/lib/settings";
import ThemeSwitcher from "@/components/react/ThemeSwitcher";
import MemberModal from "@/components/react/MemberModal";

interface Props {
  title?: string;
  description?: string;
  pageKey?: string;
  ogImageUrl?: string;
}

const { title, description, pageKey, ogImageUrl } = Astro.props;

// All site config now comes from family.settings — admin can edit at
// /admin/settings without rebuilding. SITE constants in data/site.ts
// kept for NAV_LINKS only.
const SITE = await getSiteIdentity();
const seo = await getSeoMeta();
const social = await getSocialLinks();
const analytics = await getAnalyticsConfig();
const privacy = await getPrivacyToggles();

const pageTitle = title ? `${title} — ${SITE.brand.vi}` : SITE.brand.vi;
const pageDesc = description ?? seo.defaultDescription
  ?? `${SITE.brand.vi} • ${SITE.hometown} • ${SITE.motto}`;
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();
const finalOgImage = ogImageUrl ?? seo.ogImageUrl;

const allMembers = await getMembers((entry) => entry.data.status === "published");
const clientMembers = allMembers.map(toClientMember);

const locationEntries = await getLocations();
type LocationLookupEntry = {
  name: string;
  lat: number;
  lng: number;
  province?: string;
};
const locationLookup: Record<string, LocationLookupEntry> = {};
for (const loc of locationEntries) {
  if (
    typeof loc.data.coords?.lat !== "number" ||
    typeof loc.data.coords?.lng !== "number"
  ) {
    continue;
  }
  const entry: LocationLookupEntry = {
    name: loc.data.name,
    lat: loc.data.coords.lat,
    lng: loc.data.coords.lng,
    province: loc.data.province,
  };
  locationLookup[loc.data.name.toLowerCase()] = entry;
  if (loc.data.nameEn) {
    locationLookup[loc.data.nameEn.toLowerCase()] = entry;
  }
}

const googleMapsApiKey = await getGoogleMapsApiKey();
const robotsContent = seo.indexingEnabled ? "index, follow" : "noindex, nofollow";
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="light" />
    <meta name="robots" content={robotsContent} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <link rel="icon" type="image/svg+xml" href={SITE.faviconUrl} />
    <link rel="canonical" href={canonicalUrl} />

    {/* OpenGraph + Twitter — for Facebook / Zalo / X share previews */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.brand.vi} />
    <meta property="og:locale" content="vi_VN" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:url" content={canonicalUrl} />
    {finalOgImage && <meta property="og:image" content={finalOgImage} />}
    <meta name="twitter:card" content={finalOgImage ? "summary_large_image" : "summary"} />
    {seo.twitterHandle && <meta name="twitter:site" content={seo.twitterHandle} />}

    <script is:inline>
      (() => {
        try {
          const t = localStorage.getItem("theme");
          if (t === "scroll" || t === "modern" || t === "classic") {
            document.documentElement.dataset.theme = t;
          } else {
            document.documentElement.dataset.theme = "classic";
          }
        } catch {
          document.documentElement.dataset.theme = "classic";
        }
      })();
    </script>

    {/* Analytics — only inject when configured */}
    {analytics.umamiUrl && analytics.umamiSiteId && (
      <script is:inline defer
        src={analytics.umamiUrl}
        data-website-id={analytics.umamiSiteId}
      ></script>
    )}
    {analytics.plausibleDomain && (
      <script is:inline defer
        data-domain={analytics.plausibleDomain}
        src="https://plausible.io/js/script.js"
      ></script>
    )}
    {analytics.googleTagId && (
      <>
        <script is:inline async
          src={`https://www.googletagmanager.com/gtag/js?id=${analytics.googleTagId}`}
        ></script>
        <script is:inline define:vars={{ tagId: analytics.googleTagId }}>{`
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', tagId);
        `}</script>
      </>
    )}
  </head>

  <body data-page={pageKey}>
    <a
      href="#main"
      class="absolute -left-[9999px] top-0 bg-ink text-paper px-4 py-3 z-[100] rounded-br-lg focus:left-0"
    >
      Bỏ qua tới nội dung
    </a>

    <header class="sticky top-0 z-30 border-b border-line backdrop-blur-md [background:color-mix(in_oklab,var(--color-paper)_88%,transparent)]">
      <div class="max-w-[1240px] mx-auto px-5 py-3.5 flex flex-wrap gap-4 items-center justify-between">
        <a
          href="/"
          class="inline-flex items-center gap-3 text-ink"
          aria-label={`${SITE.brand.vi} • ${SITE.brand.en}`}
        >
          <span class="inline-flex items-center justify-center w-11 h-11 border-2 border-vermilion text-vermilion bg-vermilion/[0.04] rounded-lg font-display font-bold text-[0.7rem] tracking-wider">
            {SITE.monogram}
          </span>
          <span class="flex flex-col leading-tight">
            <span class="font-display font-bold text-[1.05rem]">{SITE.brand.vi}</span>
            <span class="text-[0.7rem] tracking-[0.16em] uppercase text-ink-3">
              {SITE.brand.en}
            </span>
          </span>
        </a>

        <nav
          class="primary-nav max-[968px]:order-3 max-[968px]:basis-full"
          aria-label="Điều hướng chính"
        >
          <ul class="list-none m-0 p-0 flex flex-wrap gap-x-3.5 gap-y-1 justify-end max-[968px]:justify-center">
            {
              NAV_LINKS.map((link) => {
                const active =
                  link.href === "/"
                    ? currentPath === "/"
                    : currentPath.startsWith(link.href);
                return (
                  <li>
                    <a
                      href={link.href}
                      title={link.en}
                      aria-current={active ? "page" : undefined}
                      class:list={[
                        "inline-flex items-center px-3 py-1.5 rounded-md text-sm transition-colors",
                        active
                          ? "bg-paper-2 text-ink [box-shadow:inset_0_-2px_0_var(--color-vermilion)]"
                          : "text-ink-2 hover:bg-paper-2 hover:text-ink",
                      ]}
                    >
                      {link.vi}
                    </a>
                  </li>
                );
              })
            }
          </ul>
        </nav>

        <div class="flex items-center gap-2">
          {privacy.showThemeSwitcher && <ThemeSwitcher client:load />}
        </div>
      </div>
    </header>

    <main id="main" class="min-h-[60vh]"><slot /></main>

    <MemberModal
      client:load
      members={clientMembers}
      locationLookup={locationLookup}
      googleMapsApiKey={googleMapsApiKey}
    />

    <footer class="mt-24 border-t border-line bg-paper-2 u-paper-texture">
      <div class="max-w-[1240px] mx-auto px-5 py-14">
        <!-- Top: motto in script, centered, with blossom marks. -->
        <div class="flex items-center justify-center gap-4 mb-10">
          <span aria-hidden="true" class="h-px w-16 bg-line-strong"></span>
          <span aria-hidden="true" class="text-vermilion text-xl">❀</span>
          <p class="font-script italic text-2xl text-jade m-0">"{SITE.motto}"</p>
          <span aria-hidden="true" class="text-vermilion text-xl">❀</span>
          <span aria-hidden="true" class="h-px w-16 bg-line-strong"></span>
        </div>

        <!-- 3-col grid -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 text-center sm:text-left">
          <!-- Brand -->
          <div class="flex flex-col items-center sm:items-start gap-3">
            <span class="inline-flex items-center justify-center w-14 h-14 rounded-md border-2 border-vermilion text-vermilion bg-vermilion/[0.04] font-display font-bold text-xs tracking-wider">
              {SITE.monogram}
            </span>
            <div>
              <p class="font-display font-bold text-lg text-ink m-0 leading-tight">
                {SITE.brand.vi}
              </p>
              <p class="text-2xs tracking-wider uppercase text-ink-3 mt-1" lang="en">
                {SITE.brand.en}
              </p>
              {SITE.tagline.vi && (
                <p class="mt-2 text-sm italic text-ink-2 leading-snug max-w-xs">
                  {SITE.tagline.vi}
                </p>
              )}
            </div>
          </div>

          <!-- Place -->
          <div class="flex flex-col items-center sm:items-start gap-2">
            <p class="u-kicker">Quê hương</p>
            <p class="text-base text-ink leading-relaxed m-0">
              {SITE.hometown}
            </p>
            <p class="text-sm text-ink-3 tabular-nums m-0">
              Thành lập năm <span class="text-ink font-semibold">{SITE.established}</span>
            </p>

            {/* Social row — only when at least one is set */}
            {(social.facebookUrl || social.youtubeUrl || social.instagramUrl || social.zaloOA) && (
              <div class="mt-3 flex gap-2.5">
                {social.facebookUrl && (
                  <a
                    href={social.facebookUrl}
                    target="_blank"
                    rel="noopener"
                    class="inline-flex size-9 items-center justify-center rounded-full border border-line bg-paper text-ink-2 hover:border-vermilion hover:text-vermilion transition"
                    title="Facebook"
                    aria-label="Facebook"
                  >
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.563 9.875v-6.984H7.898V12h2.539V9.797c0-2.508 1.493-3.891 3.776-3.891 1.094 0 2.238.195 2.238.195v2.461h-1.26c-1.243 0-1.629.77-1.629 1.563V12h2.773l-.443 2.891H13.56v6.984A10 10 0 0 0 22 12z"/></svg>
                  </a>
                )}
                {social.youtubeUrl && (
                  <a
                    href={social.youtubeUrl}
                    target="_blank"
                    rel="noopener"
                    class="inline-flex size-9 items-center justify-center rounded-full border border-line bg-paper text-ink-2 hover:border-vermilion hover:text-vermilion transition"
                    title="YouTube"
                    aria-label="YouTube"
                  >
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.121 2.136c1.872.505 9.377.505 9.377.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.546 15.568V8.432L15.818 12l-6.272 3.568z"/></svg>
                  </a>
                )}
                {social.instagramUrl && (
                  <a
                    href={social.instagramUrl}
                    target="_blank"
                    rel="noopener"
                    class="inline-flex size-9 items-center justify-center rounded-full border border-line bg-paper text-ink-2 hover:border-vermilion hover:text-vermilion transition"
                    title="Instagram"
                    aria-label="Instagram"
                  >
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                  </a>
                )}
                {social.zaloOA && (
                  <a
                    href={social.zaloOA.startsWith("http") ? social.zaloOA : `https://zalo.me/${social.zaloOA}`}
                    target="_blank"
                    rel="noopener"
                    class="inline-flex h-9 items-center justify-center gap-1 rounded-full border border-line bg-paper px-3 text-xs font-semibold text-ink-2 hover:border-vermilion hover:text-vermilion transition"
                    title="Zalo OA"
                    aria-label="Zalo OA"
                  >
                    Zalo
                  </a>
                )}
              </div>
            )}
          </div>

          <!-- Nav columns -->
          <div class="flex flex-col items-center sm:items-start gap-2">
            <p class="u-kicker">Liên kết</p>
            <ul class="list-none m-0 p-0 flex flex-col gap-1.5 text-sm">
              <li><a href="/family-tree" class="text-ink-2 hover:text-vermilion">Cây gia phả</a></li>
              <li><a href="/members" class="text-ink-2 hover:text-vermilion">Thành viên</a></li>
              <li><a href="/album" class="text-ink-2 hover:text-vermilion">Album</a></li>
              <li><a href="/timeline" class="text-ink-2 hover:text-vermilion">Mốc thời gian</a></li>
              {privacy.showAdminLinkInFooter && (
                <li><a href="/admin/login" class="text-ink-3 hover:text-vermilion text-xs">· Admin</a></li>
              )}
            </ul>
          </div>
        </div>

        <!-- Bottom: privacy note -->
        <div class="mt-12 pt-6 border-t border-line text-center">
          <p class="text-2xs tracking-wider uppercase text-ink-3 opacity-90 m-0">
            {seo.indexingEnabled
              ? `© ${SITE.brand.vi} — ${SITE.hometown}`
              : "Trang gia phả riêng tư — không công khai chỉ mục"}
          </p>
          {!seo.indexingEnabled && (
            <p class="text-2xs text-ink-3 opacity-60 mt-1" lang="en">
              Private genealogy site, not indexed
            </p>
          )}
        </div>
      </div>
    </footer>
  </body>
</html>
