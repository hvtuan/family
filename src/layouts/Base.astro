---
import "@/styles/global.css";
import { SITE, NAV_LINKS } from "@/data/site";

interface Props {
  title?: string;
  description?: string;
  pageKey?: string;
}

const { title, description, pageKey } = Astro.props;
const pageTitle = title ? `${title} — ${SITE.brand.vi}` : SITE.brand.vi;
const pageDesc =
  description ?? `${SITE.brand.vi} • ${SITE.hometown} • ${SITE.motto}`;
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="light" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <script is:inline>
      // FOUC-free theme bootstrap (must run before paint).
      (() => {
        try {
          const t = localStorage.getItem("theme");
          if (t === "scroll" || t === "modern" || t === "classic") {
            document.documentElement.dataset.theme = t;
          } else {
            document.documentElement.dataset.theme = "classic";
          }
        } catch {
          document.documentElement.dataset.theme = "classic";
        }
      })();
    </script>
  </head>

  <body data-page={pageKey}>
    <a href="#main" class="skip-link">Bỏ qua tới nội dung</a>

    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="brand" aria-label={`${SITE.brand.vi} • ${SITE.brand.en}`}>
          <span class="brand-mark">{SITE.monogram}</span>
          <span class="brand-text">
            <span class="brand-vi">{SITE.brand.vi}</span>
            <span class="brand-en">{SITE.brand.en}</span>
          </span>
        </a>

        <nav class="primary-nav" aria-label="Điều hướng chính">
          <ul>
            {
              NAV_LINKS.map((link) => {
                const active =
                  link.href === "/"
                    ? currentPath === "/"
                    : currentPath.startsWith(link.href);
                return (
                  <li>
                    <a
                      href={link.href}
                      aria-current={active ? "page" : undefined}
                    >
                      <span class="nav-vi">{link.vi}</span>
                      <span class="nav-en">{link.en}</span>
                    </a>
                  </li>
                );
              })
            }
          </ul>
        </nav>
      </div>
    </header>

    <main id="main"><slot /></main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <span class="u-script">{SITE.motto}</span>
          <span class="footer-motto-en">{SITE.mottoEn}</span>
        </div>
        <div class="footer-meta">
          <span>{SITE.hometown}</span>
          <span aria-hidden="true">•</span>
          <span>Thành lập {SITE.established}</span>
        </div>
        <p class="footer-fineprint">
          Trang gia phả riêng tư — không công khai chỉ mục.
          <br />
          <span lang="en">Private genealogy site — not indexed.</span>
        </p>
      </div>
    </footer>

    <style is:global>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        background: var(--color-ink);
        color: var(--color-paper);
        padding: 0.75rem 1rem;
        z-index: 100;
        border-radius: 0 0 8px 0;
      }
      .skip-link:focus {
        left: 0;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 30;
        background: color-mix(in oklab, var(--color-paper) 88%, transparent);
        backdrop-filter: blur(8px);
        border-bottom: 1px solid var(--color-line);
      }
      .header-inner {
        max-width: 1240px;
        margin: 0 auto;
        padding: 0.875rem 1.25rem;
        display: flex;
        gap: 1.25rem;
        align-items: center;
        justify-content: space-between;
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        color: var(--color-ink);
      }
      .brand-mark {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 44px;
        height: 44px;
        border: 2px solid var(--color-vermilion);
        color: var(--color-vermilion);
        background: rgba(139, 42, 31, 0.04);
        border-radius: 8px;
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 0.7rem;
        letter-spacing: 0.04em;
      }
      .brand-text {
        display: flex;
        flex-direction: column;
        line-height: 1.1;
      }
      .brand-vi {
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 1.05rem;
      }
      .brand-en {
        font-size: 0.7rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--color-ink-3);
      }

      .primary-nav ul {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-wrap: wrap;
        gap: 0.25rem 0.875rem;
        justify-content: flex-end;
      }
      .primary-nav a {
        display: inline-flex;
        flex-direction: column;
        align-items: center;
        padding: 0.4rem 0.6rem;
        border-radius: 8px;
        line-height: 1.1;
      }
      .primary-nav a:hover {
        background: var(--color-paper-2);
      }
      .primary-nav a[aria-current="page"] {
        background: var(--color-paper-2);
        box-shadow: inset 0 -2px 0 var(--color-vermilion);
      }
      .nav-vi {
        font-size: 0.92rem;
        color: var(--color-ink);
      }
      .nav-en {
        font-size: 0.62rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--color-ink-3);
      }

      main {
        min-height: 60vh;
      }

      .site-footer {
        margin-top: 4rem;
        border-top: 1px solid var(--color-line);
        background: var(--color-paper-2);
      }
      .footer-inner {
        max-width: 1240px;
        margin: 0 auto;
        padding: 2.5rem 1.25rem;
        display: grid;
        gap: 0.75rem;
        text-align: center;
        color: var(--color-ink-2);
      }
      .footer-brand {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        font-size: 1.4rem;
      }
      .footer-motto-en {
        font-size: 0.78rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--color-ink-3);
      }
      .footer-meta {
        display: inline-flex;
        gap: 0.5rem;
        justify-content: center;
        flex-wrap: wrap;
        color: var(--color-ink-3);
        font-size: 0.85rem;
      }
      .footer-fineprint {
        font-size: 0.72rem;
        color: var(--color-ink-3);
        opacity: 0.85;
      }

      @media (max-width: 768px) {
        .header-inner {
          flex-direction: column;
          align-items: stretch;
          gap: 0.625rem;
        }
        .primary-nav ul {
          justify-content: center;
        }
      }
    </style>
  </body>
</html>
