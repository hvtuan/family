---
interface Props {
  kicker?: string;
  title: string;
  subtitle?: string;
  subtitleEn?: string;
  align?: "center" | "left";
}

const { kicker, title, subtitle, subtitleEn, align = "center" } = Astro.props;
const alignClasses =
  align === "left"
    ? "text-left items-start"
    : "text-center items-center";
---

<header
  class:list={[
    "max-w-[1240px] mx-auto px-5 pt-12 pb-6 flex flex-col gap-1.5",
    alignClasses,
  ]}
>
  {kicker && <p class="u-kicker">{kicker}</p>}
  <h1 class="text-[clamp(2rem,5vw,3.4rem)] leading-[1.1] text-ink">{title}</h1>
  {
    subtitle && (
      <p class="text-ink-2 text-[1.05rem] max-w-[60ch]">{subtitle}</p>
    )
  }
  {
    subtitleEn && (
      <p
        class="text-ink-3 text-[0.78rem] tracking-[0.18em] uppercase max-w-[70ch]"
        lang="en"
      >
        {subtitleEn}
      </p>
    )
  }
</header>
