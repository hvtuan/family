---
/**
 * One ancestor on the altar grid — sepia portrait, name underneath, soft
 * gold glow on hover. Glows continuously when today is the giỗ.
 *
 * Tone: warm, not gothic. No vermilion ring, no flicker.
 */
import type { MemorialMember } from "@/lib/memorial";

interface Props {
  member: MemorialMember;
  /** True when today is one of this member's anniversaries. */
  isToday?: boolean;
}

const { member, isToday = false } = Astro.props;

function fmt(iso: string | null): string | null {
  if (!iso) return null;
  return new Date(iso).getFullYear().toString();
}

const bornY = fmt(member.born ?? null);
const diedY = fmt(member.died);
const dates = bornY && diedY ? `${bornY} – ${diedY}` : diedY ? `– ${diedY}` : "";
---

<a
  href={`/memorial/${member.id}`}
  class:list={[
    "group block text-center transition-transform duration-300",
    isToday && "altar-tile-today",
  ]}
  aria-label={`Tưởng niệm ${member.name}`}
>
  <figure class="relative inline-block mx-auto">
    <div
      class="relative overflow-hidden rounded-md border border-gold-2/40 transition-all duration-500 group-hover:scale-[1.03] group-hover:shadow-[0_0_28px_-6px_rgba(214,160,80,0.45)]"
      style="width: clamp(120px, 16vw, 180px); aspect-ratio: 4 / 5;"
    >
      {member.photoUrl ? (
        <img
          src={member.photoUrl}
          alt={`Chân dung ${member.name}`}
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          style="filter: sepia(0.18) saturate(0.9);"
          loading="lazy"
        />
      ) : (
        <div class="w-full h-full flex items-center justify-center bg-cream/50 text-gold-2/45">
          <svg viewBox="0 0 24 24" width="48" height="48" fill="currentColor" aria-hidden="true">
            <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4Zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4Z" />
          </svg>
        </div>
      )}
      <span
        class="absolute inset-0 pointer-events-none rounded-md"
        style="box-shadow: inset 0 0 0 1px rgba(200, 160, 90, 0.22);"
      ></span>
    </div>
  </figure>

  <figcaption class="mt-3">
    <p class="font-display italic text-ink m-0 text-base group-hover:text-vermilion transition-colors">
      {member.name}
    </p>
    {dates && (
      <p class="text-xs text-ink-3 m-0 tracking-wide tabular-nums mt-0.5">{dates}</p>
    )}
  </figcaption>
</a>

<style>
  .altar-tile-today figure > div {
    box-shadow: 0 0 32px -6px rgba(214, 160, 80, 0.55);
    border-color: rgba(214, 160, 80, 0.7);
  }
</style>
