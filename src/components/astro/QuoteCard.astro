---
import type { QuoteData } from "@/lib/content";

interface Props {
  quote: QuoteData;
  /** Resolved author member (optional). When provided, author name becomes a link. */
  authorHref?: string;
  /** "compact" = inline blockquote (homepage); "card" = full quote card (sayings). */
  variant?: "compact" | "card";
}

const { quote: q, authorHref, variant = "card" } = Astro.props;

const typeLabel: Record<string, { vi: string; en: string }> = {
  proverb: { vi: "Tục ngữ", en: "Proverb" },
  family: { vi: "Lời nhà", en: "Family" },
  poem: { vi: "Thơ", en: "Poem" },
  letter: { vi: "Thư", en: "Letter" },
};

const t = typeLabel[q.type] ?? typeLabel.family;
---

{
  variant === "compact" ? (
    <blockquote class="m-0 p-6 border-l-[3px] border-vermilion bg-cream rounded-r-xl">
      <p class="font-display italic text-2xl text-ink leading-snug">"{q.text}"</p>
      {q.textEn?.trim() && (
        <p lang="en" class="text-[0.95rem] text-ink-3 italic mt-2">
          "{q.textEn}"
        </p>
      )}
      <footer class="mt-3 text-[0.85rem] text-ink-2">
        — {authorHref ? <a href={authorHref} class="text-vermilion font-semibold">{q.author}</a> : q.author}
      </footer>
    </blockquote>
  ) : (
    <li class="u-card relative pt-8 pr-7 pb-6 pl-7">
      <span
        aria-hidden="true"
        class="absolute -top-2 left-4 font-display text-[5rem] text-vermilion opacity-20 leading-none pointer-events-none"
      >
        "
      </span>
      <blockquote class="m-0">
        <p class="font-display italic text-xl text-ink leading-[1.5]">{q.text}</p>
        {q.textEn?.trim() && (
          <p lang="en" class="mt-1 text-[0.92rem] text-ink-3 italic">
            {q.textEn}
          </p>
        )}
        <footer class="mt-3.5 pt-2.5 border-t border-dashed border-line flex flex-wrap justify-between items-center gap-3">
          <span class="text-[0.92rem] text-ink-2 font-semibold">
            — {authorHref ? <a href={authorHref} class="text-vermilion">{q.author}</a> : q.author}
          </span>
          <span class="inline-flex flex-col leading-tight px-2.5 py-0.5 bg-paper-2 border border-line rounded-full text-[0.74rem] text-ink-2">
            <span>{t.vi}</span>
            <span lang="en" class="text-[0.58rem] tracking-[0.16em] uppercase text-ink-3">{t.en}</span>
          </span>
        </footer>
        {q.context && (
          <p class="mt-2.5 text-[0.85rem] text-ink-3 leading-[1.55]">{q.context}</p>
        )}
      </blockquote>
    </li>
  )
}
