---
import type { QuoteData } from "@/lib/content";

interface Props {
  quote: QuoteData;
  authorHref?: string;
  /** "compact" = inline blockquote (homepage); "card" = full quote card. */
  variant?: "compact" | "card";
}

const { quote: q, authorHref, variant = "card" } = Astro.props;

const typeLabel: Record<string, string> = {
  proverb: "Tục ngữ",
  family: "Lời nhà",
  poem: "Thơ",
  letter: "Thư",
};

const t = typeLabel[q.type] ?? typeLabel.family;
---

{variant === "compact" ? (
  <blockquote class="m-0 p-7 border-l-2 border-gold-2 bg-cream rounded-r-md u-paper-texture">
    <p
      class="font-display italic text-ink leading-snug m-0"
      style="font-size: var(--text-2xl);"
    >
      "{q.text}"
    </p>
    {q.textEn?.trim() && (
      <p lang="en" class="text-sm text-ink-3 italic mt-2 m-0">
        "{q.textEn}"
      </p>
    )}
    <footer class="mt-4 text-sm text-ink-2 m-0">
      —{" "}
      {authorHref ? (
        <a href={authorHref} class="text-jade font-semibold hover:text-vermilion transition-colors">
          {q.author}
        </a>
      ) : (
        <span class="font-semibold">{q.author}</span>
      )}
    </footer>
  </blockquote>
) : (
  <li class="u-card relative pt-9 pr-7 pb-6 pl-7">
    <span
      aria-hidden="true"
      class="absolute -top-1 left-4 font-display text-vermilion opacity-25 leading-none pointer-events-none select-none"
      style="font-size: 5.5rem;"
    >
      "
    </span>
    <blockquote class="m-0">
      <p
        class="font-display italic text-ink leading-relaxed m-0"
        style="font-size: var(--text-lg);"
      >
        {q.text}
      </p>
      {q.textEn?.trim() && (
        <p lang="en" class="mt-1 text-sm text-ink-3 italic m-0">
          {q.textEn}
        </p>
      )}
      <footer class="mt-4 pt-3 border-t border-dashed border-line flex flex-wrap justify-between items-center gap-3">
        <span class="text-sm text-ink-2 font-semibold">
          —{" "}
          {authorHref ? (
            <a href={authorHref} class="text-jade hover:text-vermilion transition-colors">
              {q.author}
            </a>
          ) : (
            q.author
          )}
        </span>
        <span class="inline-flex items-center px-2.5 py-0.5 bg-paper-2 border border-line rounded-full text-xs text-ink-2 tracking-wide">
          {t}
        </span>
      </footer>
      {q.context && (
        <p class="mt-3 text-sm text-ink-3 leading-relaxed m-0">{q.context}</p>
      )}
    </blockquote>
  </li>
)}
