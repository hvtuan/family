---
import type { PhotoData } from "@/lib/content";

interface Props {
  photo: PhotoData;
}

const { photo: p } = Astro.props;
---

<li class="">
  <figure class="m-0 bg-cream border border-line rounded-xl overflow-hidden shadow-paper-1">
    <div class="aspect-[4/3] bg-paper-3">
      <img
        src={p.src}
        alt={p.caption}
        class="w-full h-full object-cover block"
        loading="lazy"
        decoding="async"
      />
    </div>
    <figcaption class="p-4 flex flex-col gap-0.5">
      <p>{p.caption}</p>
      {p.captionEn?.trim() && (
        <p lang="en" class="text-[0.82rem] text-ink-3 italic">{p.captionEn}</p>
      )}
      {(p.year || p.location) && (
        <p class="mt-1.5 text-[0.78rem] text-ink-3 tracking-wide">
          {[p.year, p.location].filter(Boolean).join(" • ")}
        </p>
      )}
    </figcaption>
  </figure>
</li>
