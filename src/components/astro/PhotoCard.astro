---
import type { PhotoData } from "@/lib/content";

interface Props {
  photo: PhotoData;
}

const { photo: p } = Astro.props;
const isVideo = p.kind === "video";

// For images: use medium URL when present, fall back to original src.
// For videos: use the poster (admin-side: src_medium) so the card looks
// identical to a photo card until the user hits play.
const imgSrc = isVideo ? (p.poster ?? p.thumb ?? "") : (p.thumb ?? p.src);
const altText = p.altVi ?? p.caption;

function formatDuration(seconds?: number): string {
  if (!seconds || !Number.isFinite(seconds) || seconds <= 0) return "";
  const m = Math.floor(seconds / 60);
  const s = seconds % 60;
  return `${m}:${String(s).padStart(2, "0")}`;
}
const dur = formatDuration(p.durationSeconds);
---

<li>
  <figure class="m-0 group u-card overflow-hidden">
    <div class="aspect-[4/3] bg-paper-3 relative overflow-hidden">
      {isVideo ? (
        <video
          src={p.src}
          poster={imgSrc || undefined}
          controls
          preload="metadata"
          playsinline
          class="w-full h-full object-cover block bg-ink"
        >
          {altText}
        </video>
      ) : (
        <img
          src={imgSrc}
          alt={altText}
          class="w-full h-full object-cover block transition-transform duration-700 group-hover:scale-[1.03]"
          loading="lazy"
          decoding="async"
        />
      )}
      {isVideo && dur && (
        <span
          class="absolute bottom-2 right-2 rounded bg-ink/75 px-1.5 py-0.5 font-medium text-paper tabular-nums"
          style="font-size: var(--text-2xs);"
        >
          {dur}
        </span>
      )}
    </div>
    <figcaption class="p-4 flex flex-col gap-1">
      <p
        class="font-display text-ink leading-snug m-0"
        style="font-size: var(--text-base);"
      >
        {p.caption}
      </p>
      {p.captionEn?.trim() && (
        <p
          lang="en"
          class="text-ink-3 italic m-0"
          style="font-size: var(--text-xs);"
        >
          {p.captionEn}
        </p>
      )}
      {(p.year || p.location) && (
        <p
          class="mt-2 pt-2 border-t border-dashed border-line text-ink-3 tabular-nums uppercase"
          style="font-size: var(--text-2xs); letter-spacing: var(--tracking-wide);"
        >
          {[p.year, p.location].filter(Boolean).join(" · ")}
        </p>
      )}
    </figcaption>
  </figure>
</li>
