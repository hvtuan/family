---
import type { LocationData } from "@/lib/content";

interface Props {
  location: LocationData;
  memberNames: string[];
}

const { location: loc, memberNames } = Astro.props;

// Prefer Google Maps (matches admin / public PublicMap) — falls back
// to OSM if browser blocks google maps domain.
const mapsLink = `https://www.google.com/maps?q=${loc.coords.lat},${loc.coords.lng}`;
---

<li
  class:list={[
    "u-card p-6 flex flex-col gap-3 transition-shadow hover:shadow-paper-2",
    loc.isHometown && "ring-2 ring-vermilion ring-offset-2 ring-offset-paper",
  ]}
>
  <header>
    {loc.isHometown && (
      <span
        class="inline-flex items-center gap-1 px-3 py-1 bg-vermilion text-paper rounded-full font-semibold mb-3"
        style="font-size: var(--text-xs); letter-spacing: var(--tracking-wide);"
        title="Hometown"
      >
        ★ Quê tổ
      </span>
    )}
    <h2
      class="font-display font-bold text-ink m-0 leading-tight"
      style="font-size: var(--text-2xl);"
      title={loc.nameEn}
    >
      {loc.name}
    </h2>
    <p class="text-ink-2 mt-1" style="font-size: var(--text-sm);">
      {loc.province}
    </p>
  </header>

  {loc.description && (
    <p class="text-ink-2 leading-relaxed" style="font-size: var(--text-base);">
      {loc.description}
    </p>
  )}

  <div
    class="flex items-baseline gap-2 m-0 px-3 py-2 bg-paper-2/60 rounded-md border border-line"
  >
    <span
      class="text-gold-2 uppercase font-semibold"
      style="font-size: var(--text-2xs); letter-spacing: var(--tracking-wide);"
    >
      Thành viên
    </span>
    <span class="font-semibold text-ink tabular-nums">{loc.members.length}</span>
    <span class="text-ink-3" style="font-size: var(--text-sm);">người gắn với nơi này</span>
  </div>

  {memberNames.length > 0 && (
    <p class="text-ink-2 leading-snug" style="font-size: var(--text-sm);">
      {memberNames.slice(0, 6).join(" · ")}
      {memberNames.length > 6 && (
        <span class="text-ink-3">{` · và ${memberNames.length - 6} người khác`}</span>
      )}
    </p>
  )}

  <a
    href={mapsLink}
    target="_blank"
    rel="noopener noreferrer"
    class="mt-auto font-semibold text-jade hover:text-vermilion transition-colors inline-flex items-center gap-1"
    style="font-size: var(--text-sm);"
  >
    Mở trên Google Maps
    <span aria-hidden="true">↗</span>
  </a>
</li>
