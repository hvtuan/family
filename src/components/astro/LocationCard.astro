---
import type { LocationData } from "@/lib/content";

interface Props {
  location: LocationData;
  memberNames: string[];
}

const { location: loc, memberNames } = Astro.props;

const osmLink = `https://www.openstreetmap.org/?mlat=${loc.coords.lat}&mlon=${loc.coords.lng}#map=12/${loc.coords.lat}/${loc.coords.lng}`;
---

<li class:list={["u-card p-6 flex flex-col gap-3", loc.isHometown && "border-2 border-vermilion"]}>
  <header>
    {
      loc.isHometown && (
        <span class="inline-block px-3 py-1 bg-vermilion text-paper rounded-full text-[0.72rem] font-semibold tracking-wide mb-2">
          Quê tổ • Hometown
        </span>
      )
    }
    <h2 class="text-[1.5rem] m-0">{loc.name}</h2>
    {
      loc.nameEn?.trim() && (
        <p lang="en" class="text-[0.78rem] tracking-[0.14em] uppercase text-ink-3">
          {loc.nameEn}
        </p>
      )
    }
    <p class="text-[0.92rem] text-ink-2 mt-1">{loc.province}</p>
  </header>
  {loc.description && <p class="text-ink-2 leading-[1.55]">{loc.description}</p>}
  <dl class="grid grid-cols-2 gap-3 m-0 p-3 bg-paper-2 rounded-lg">
    <div class="flex flex-col gap-0.5">
      <dt class="text-[0.65rem] tracking-[0.16em] uppercase text-ink-3">Tọa độ</dt>
      <dd class="m-0 font-semibold text-ink">
        <code class="font-mono text-[0.82rem] font-normal">
          {loc.coords.lat.toFixed(4)}, {loc.coords.lng.toFixed(4)}
        </code>
      </dd>
    </div>
    <div class="flex flex-col gap-0.5">
      <dt class="text-[0.65rem] tracking-[0.16em] uppercase text-ink-3">Thành viên</dt>
      <dd class="m-0 font-semibold text-ink">{loc.members.length}</dd>
    </div>
  </dl>
  {memberNames.length > 0 && (
    <p class="text-[0.85rem] text-ink-2 leading-snug">{memberNames.join(" • ")}</p>
  )}
  <a
    href={osmLink}
    target="_blank"
    rel="noopener noreferrer"
    class="mt-auto font-semibold text-vermilion text-[0.9rem]"
  >
    Mở trên OpenStreetMap ↗
  </a>
</li>
