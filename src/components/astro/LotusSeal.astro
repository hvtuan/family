---
/**
 * Canonical seal for memorial / heritage assets — lotus motif + Quốc ngữ
 * surname in Dancing Script. Replaces older Hán-Nôm ideograms with a
 * uniquely Vietnamese mark (see feedback memory `family_no_chinese_chars`).
 */
import Lotus from "./Lotus.astro";

interface Props {
  surname: string;
  size?: "sm" | "md" | "lg";
  align?: "center" | "right";
  class?: string;
}

const { surname, size = "md", align = "center", class: className = "" } = Astro.props;

const dims = {
  sm: { lotus: 24, text: "0.95rem", gap: "gap-1" },
  md: { lotus: 36, text: "1.25rem", gap: "gap-1.5" },
  lg: { lotus: 56, text: "1.85rem", gap: "gap-2" },
}[size];

const alignClasses = align === "right" ? "items-end text-right" : "items-center text-center";
---

<div
  class:list={["inline-flex flex-col", alignClasses, dims.gap, className]}
  aria-hidden="true"
>
  <Lotus size={dims.lotus} />
  <div
    class="font-script text-gold-2 leading-none"
    style={`font-size: ${dims.text}; font-family: var(--font-script, 'Dancing Script', cursive);`}
  >
    Họ {surname}
  </div>
</div>
