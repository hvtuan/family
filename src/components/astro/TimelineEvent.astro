---
import type { TimelineData } from "@/lib/content";

interface RelatedMember {
  id: string;
  name: string;
}

interface Props {
  event: TimelineData;
  related: RelatedMember[];
}

const { event: e, related } = Astro.props;

const categoryLabel: Record<string, string> = {
  founding: "Lập gia tộc",
  birth: "Sinh",
  marriage: "Hôn lễ",
  death: "Mất",
  milestone: "Mốc son",
  gathering: "Tụ họp",
};

const categoryEn: Record<string, string> = {
  founding: "Founding",
  birth: "Birth",
  marriage: "Marriage",
  death: "Passing",
  milestone: "Milestone",
  gathering: "Gathering",
};

const cat = e.category ? categoryLabel[e.category] : undefined;
const catEn = e.category ? categoryEn[e.category] : undefined;
---

<li class="grid grid-cols-[112px_1fr] gap-4 items-start pb-8 mobile:grid-cols-[56px_1fr] mobile:gap-3">
  <div class="flex items-center justify-center w-28 relative pt-2 mobile:w-14" aria-hidden="true">
    <span
      class="w-16 h-16 flex items-center justify-center rounded-full bg-cream border-[3px] border-gold-2 font-display font-bold text-base text-gold-2 shadow-paper-1 z-10 mobile:w-12 mobile:h-12 mobile:text-xs tabular-nums"
    >
      {e.year}
    </span>
  </div>

  <article class="u-card p-5 sm:px-6">
    <header class="flex flex-wrap gap-3 items-center justify-between mb-2">
      {cat && (
        <span
          class="inline-flex items-center px-3 py-1 bg-jade/[0.08] text-jade rounded-full text-xs font-semibold tracking-wide"
          title={catEn}
        >
          {cat}
        </span>
      )}
      {e.date && (
        <time
          datetime={e.date}
          class="text-sm text-ink-3 tabular-nums inline-flex gap-1.5 items-center"
        >
          {e.date}
          {e.lunar && (
            <span class="text-2xs px-1.5 py-px bg-paper-3 rounded-full text-ink-2 tracking-wide uppercase">
              âm lịch
            </span>
          )}
        </time>
      )}
    </header>

    <h2
      class="font-display font-bold m-0 text-ink leading-tight"
      style="font-size: var(--text-xl);"
    >
      {e.title}
    </h2>
    {e.titleEn?.trim() && (
      <p lang="en" class="text-2xs tracking-wider uppercase text-ink-3 mb-2 mt-0.5">
        {e.titleEn}
      </p>
    )}
    <p class="text-base text-ink-2 leading-relaxed mt-2">{e.desc}</p>
    {e.descEn?.trim() && (
      <p lang="en" class="text-sm text-ink-3 leading-relaxed mt-1 italic">
        {e.descEn}
      </p>
    )}

    {related.length > 0 && (
      <footer class="mt-4 pt-3 border-t border-dashed border-line flex flex-wrap gap-2 items-baseline text-sm">
        <span class="text-ink-3 text-xs tracking-wide uppercase">Liên quan:</span>
        <ul class="list-none m-0 p-0 flex flex-wrap gap-x-2 gap-y-1">
          {related.map((m) => (
            <li>
              <a
                href={`/members?member=${m.id}`}
                class="text-jade font-medium hover:text-vermilion transition-colors"
              >
                {m.name}
              </a>
            </li>
          ))}
        </ul>
      </footer>
    )}
  </article>
</li>
