---
import type { TraditionEntry } from "@/lib/content";
import { renderMarkdown } from "@/lib/markdown";

interface Props {
  tradition: TraditionEntry;
}

const { tradition } = Astro.props;
const t = tradition.data;
const bodyHtml = renderMarkdown(tradition.body);

const iconGlyph: Record<string, string> = {
  bowl: "🍚",
  fish: "🐟",
  leaf: "🍃",
  shell: "🐚",
  incense: "🪔",
  blossom: "❀",
};

const categoryLabel: Record<string, { vi: string; en: string }> = {
  food: { vi: "Ẩm thực", en: "Food" },
  festival: { vi: "Lễ hội", en: "Festival" },
  ceremony: { vi: "Nghi lễ", en: "Ceremony" },
  craft: { vi: "Thủ công", en: "Craft" },
};

const cat = categoryLabel[t.category];
---

<li class="u-card p-6 flex flex-col gap-2">
  <header class="flex items-center justify-between gap-4">
    <span class="text-[2.4rem] leading-none" aria-hidden="true">{iconGlyph[t.icon]}</span>
    <span
      class="inline-flex items-center px-3 py-1 bg-jade/10 text-jade border border-jade/25 rounded-full font-semibold"
      style="font-size: var(--text-xs); letter-spacing: var(--tracking-wide);"
      title={cat.en}
    >
      {cat.vi}
    </span>
  </header>

  <h2
    class="font-display font-bold text-ink m-0 leading-tight"
    style="font-size: var(--text-2xl);"
    title={t.nameEn}
  >
    {t.name}
  </h2>

  <p class="text-ink-2 leading-relaxed" style="font-size: var(--text-base);">
    {t.desc}
  </p>
  {t.descEn?.trim() && (
    <p
      lang="en"
      class="text-ink-3 italic leading-normal"
      style="font-size: var(--text-sm);"
    >
      {t.descEn}
    </p>
  )}

  {t.origin && (
    <p class="flex gap-2 items-baseline mt-2 text-ink-2" style="font-size: var(--text-sm);">
      <span
        class="font-semibold text-gold-2 uppercase shrink-0"
        style="font-size: var(--text-2xs); letter-spacing: var(--tracking-wide);"
      >
        Nguồn gốc
      </span>
      <span>{t.origin}</span>
    </p>
  )}

  <details class="tradition-details mt-2">
    <summary
      class="cursor-pointer font-semibold text-jade hover:text-vermilion list-none py-1.5 transition-colors"
      style="font-size: var(--text-sm);"
    >
      Xem chi tiết
    </summary>
    <div
      class="tradition-content pt-3 border-t border-dashed border-line text-ink-2 leading-[1.7]"
      set:html={bodyHtml}
    />
  </details>
</li>

<style>
  .tradition-details summary::-webkit-details-marker {
    display: none;
  }
  .tradition-details summary::after {
    content: " ▾";
    display: inline-block;
    transition: transform 160ms ease;
  }
  .tradition-details[open] summary::after {
    transform: rotate(180deg);
  }
  .tradition-content :global(h2),
  .tradition-content :global(h3) {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    margin: 1rem 0 0.5rem;
    color: var(--color-vermilion);
  }
  .tradition-content :global(ul),
  .tradition-content :global(ol) {
    padding-left: 1.5rem;
    margin: 0.5rem 0;
  }
  .tradition-content :global(blockquote) {
    border-left: 3px solid var(--color-gold-2);
    padding: 0.25rem 0 0.25rem 1rem;
    margin: 0.75rem 0;
    font-style: italic;
    color: var(--color-ink-2);
  }
</style>
