---
import type { DateRow } from "@/lib/dates-admin";
import { DATE_TYPES } from "@/lib/dates-admin";

interface Props {
  mode: "create" | "edit";
  values: Partial<DateRow>;
  refs: { id: string; name: string; gen: number }[];
  fieldError?: string | null;
  fieldOk?: string | null;
}
const { mode, values: v, refs, fieldError, fieldOk } = Astro.props;

const typeLabel: Record<(typeof DATE_TYPES)[number], string> = {
  memorial: "Giỗ", festival: "Lễ hội", birthday: "Sinh nhật",
  national: "Lễ quốc gia", anniversary: "Kỷ niệm", gathering: "Sum họp",
};
---

<form method="post" class="space-y-6">
  {fieldError && <div class="rounded-lg border border-error-100 bg-error-50 px-4 py-3 text-theme-sm text-error-700">{fieldError}</div>}
  {fieldOk && <div class="rounded-lg border border-success-100 bg-success-50 px-4 py-3 text-theme-sm text-success-700">{fieldOk}</div>}

  <fieldset class="rounded-2xl border border-gray-200 bg-white p-5 shadow-theme-xs">
    <legend class="px-2 text-theme-sm font-semibold text-gray-800">Thông tin</legend>
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Ngày (MM-DD hoặc YYYY-MM-DD) *</label>
        <input type="text" name="date" required value={v.date ?? ""} placeholder="03-08 hoặc 1928-03-08"
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10" />
      </div>
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Lịch *</label>
        <select name="calendar" required class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10">
          <option value="solar" selected={(v.calendar ?? "solar") === "solar"}>Dương lịch</option>
          <option value="lunar" selected={v.calendar === "lunar"}>Âm lịch</option>
        </select>
      </div>
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Tên (vi) *</label>
        <input type="text" name="name" required value={v.name ?? ""}
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10" />
      </div>
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Tên (en) *</label>
        <input type="text" name="name_en" required value={v.name_en ?? ""}
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10" />
      </div>
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Loại *</label>
        <select name="type" required class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10">
          {DATE_TYPES.map((t) => (
            <option value={t} selected={v.type === t}>{typeLabel[t]}</option>
          ))}
        </select>
      </div>
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Thành viên liên quan</label>
        <select name="member_id" class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10">
          <option value="">— không —</option>
          {refs.map((r) => (
            <option value={r.id} selected={v.member_id === r.id}>{r.name} (đời {r.gen})</option>
          ))}
        </select>
      </div>
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Năm (nếu có)</label>
        <input type="number" name="year" value={v.year ?? ""} placeholder="1928"
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10" />
      </div>
      <label class="flex items-center gap-2 text-theme-sm text-gray-700">
        <input type="checkbox" name="recurring" value="1" checked={v.recurring}
          class="h-4 w-4 rounded border-gray-300 text-brand-500 focus:ring-brand-500/20" />
        Lặp lại hằng năm
      </label>
      <div class="md:col-span-2">
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Ghi chú</label>
        <textarea name="notes" rows="2" class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10">{v.notes ?? ""}</textarea>
      </div>
    </div>
  </fieldset>

  <div class="flex items-center justify-between gap-3">
    <a href="/admin/dates" class="rounded-lg border border-gray-200 px-5 py-2.5 text-theme-sm font-medium text-gray-700 hover:bg-gray-50">Hủy</a>
    <button type="submit" class="rounded-lg bg-brand-500 px-5 py-2.5 text-theme-sm font-medium text-white shadow-theme-xs hover:bg-brand-600">
      {mode === "create" ? "Tạo ngày lễ" : "Lưu thay đổi"}
    </button>
  </div>
</form>
