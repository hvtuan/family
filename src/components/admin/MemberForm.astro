---
import type { MemberRow } from "@/lib/members-admin";
import { formatCsv } from "@/lib/members-admin";
import AttachmentInput from "./AttachmentInput.astro";

interface Props {
  mode: "create" | "edit";
  values: Partial<MemberRow>;
  refs: { id: string; name: string; gen: number }[];
  fieldError?: string | null;
  fieldOk?: string | null;
}

const { mode, values, refs, fieldError, fieldOk } = Astro.props;

const v = values;

// Filter out the current member from ref selectors so a person can't be
// their own parent/spouse.
const refOptions = refs.filter((r) => r.id !== v.id);

const submitLabel = mode === "create" ? "Tạo thành viên" : "Lưu thay đổi";
---

<form method="post" enctype="multipart/form-data" class="space-y-6" autocomplete="off">
  {fieldError && (
    <div class="rounded-lg border border-error-100 bg-error-50 px-4 py-3 text-theme-sm text-error-700">
      {fieldError}
    </div>
  )}
  {fieldOk && (
    <div class="rounded-lg border border-success-100 bg-success-50 px-4 py-3 text-theme-sm text-success-700">
      {fieldOk}
    </div>
  )}

  <!-- Sticky section nav: anchor links + active section highlight via
       Intersection Observer (vanilla JS at the bottom of this file). -->
  <nav
    data-form-toc
    class="sticky top-16 z-30 -mx-2 flex flex-wrap gap-1 overflow-x-auto rounded-lg border border-border bg-background/95 p-1.5 shadow-theme-xs backdrop-blur-sm"
    aria-label="Mục trong biểu mẫu"
  >
    <a href="#section-identity"  class="form-toc-link rounded px-3 py-1.5 text-xs font-medium text-muted-foreground hover:bg-accent">Định danh</a>
    <a href="#section-dates"     class="form-toc-link rounded px-3 py-1.5 text-xs font-medium text-muted-foreground hover:bg-accent">Sinh – mất</a>
    <a href="#section-relations" class="form-toc-link rounded px-3 py-1.5 text-xs font-medium text-muted-foreground hover:bg-accent">Quan hệ</a>
    <a href="#section-intro"     class="form-toc-link rounded px-3 py-1.5 text-xs font-medium text-muted-foreground hover:bg-accent">Giới thiệu</a>
    <a href="#section-personal"  class="form-toc-link rounded px-3 py-1.5 text-xs font-medium text-muted-foreground hover:bg-accent">Cá nhân</a>
    <a href="#section-contact"   class="form-toc-link rounded px-3 py-1.5 text-xs font-medium text-muted-foreground hover:bg-accent">Liên hệ</a>
    <a href="#section-status"    class="form-toc-link rounded px-3 py-1.5 text-xs font-medium text-muted-foreground hover:bg-accent">Trạng thái</a>
    {v.died && (
      <a href="#section-memorial" class="form-toc-link rounded px-3 py-1.5 text-xs font-medium text-muted-foreground hover:bg-accent">Tưởng niệm</a>
    )}
  </nav>

  <!-- ─── Identity ─────────────────────────────────────────────── -->
  <fieldset id="section-identity" class="scroll-mt-24 rounded-2xl border border-border bg-card p-5 shadow-theme-xs">
    <legend class="px-2 text-theme-sm font-semibold text-gray-800">Định danh</legend>
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">
          ID (slug, không đổi sau khi tạo) *
        </label>
        <input
          type="text" name="id" required pattern="[a-z0-9][a-z0-9-]{0,30}"
          value={v.id ?? ""}
          readonly={mode === "edit"}
          placeholder="vd: g3-1"
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm text-gray-800 shadow-theme-xs placeholder:text-gray-400 focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10 read-only:bg-gray-50 read-only:text-gray-500"
        />
      </div>

      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">
          Họ tên *
        </label>
        <input
          type="text" name="name" required
          value={v.name ?? ""}
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm text-gray-800 shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10"
        />
      </div>

      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">
          Tên tiếng Anh
        </label>
        <input
          type="text" name="name_en"
          value={v.name_en ?? ""}
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm text-gray-800 shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10"
        />
      </div>

      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">
          Tên thân mật / nickname
        </label>
        <input
          type="text" name="nickname"
          value={v.nickname ?? ""}
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm text-gray-800 shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10"
        />
      </div>

      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">
          Đời (gen) *
        </label>
        <input
          type="number" name="gen" required min="1" max="8"
          value={v.gen ?? 1}
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm text-gray-800 shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10"
        />
      </div>

      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">
          Vai vế (vd: Ông Tổ, Trưởng nam) *
        </label>
        <input
          type="text" name="role" required
          value={v.role ?? ""}
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm text-gray-800 shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10"
        />
      </div>

      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">
          Vai vế (EN)
        </label>
        <input
          type="text" name="role_en"
          value={v.role_en ?? ""}
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm text-gray-800 shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10"
        />
      </div>

      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">
          Nhánh *
        </label>
        <select
          name="branch" required
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm text-gray-800 shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10"
        >
          <option value="both" selected={(v.branch ?? "both") === "both"}>Cả nội + ngoại</option>
          <option value="noi" selected={v.branch === "noi"}>Họ Nội</option>
          <option value="ngoai" selected={v.branch === "ngoai"}>Họ Ngoại</option>
        </select>
      </div>

      <label class="flex items-center gap-2 text-theme-sm text-gray-700 md:col-span-2">
        <input
          type="checkbox" name="is_family_head" value="1"
          checked={!!v.is_family_head}
          class="h-4 w-4 rounded border-gray-300 text-brand-500 focus:ring-brand-500/20"
        />
        Là tộc trưởng / family head (tự dòng được đánh dấu)
      </label>
    </div>
  </fieldset>

  <!-- ─── Dates + places ──────────────────────────────────────── -->
  <fieldset id="section-dates" class="scroll-mt-24 rounded-2xl border border-border bg-card p-5 shadow-theme-xs">
    <legend class="px-2 text-theme-sm font-semibold text-gray-800">Sinh – mất</legend>
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">
          Năm/ngày sinh (YYYY hoặc YYYY-MM-DD) *
        </label>
        <input
          type="text" name="born" required
          value={v.born ?? ""}
          placeholder="1905-03-12 hoặc 1905"
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm text-gray-800 shadow-theme-xs placeholder:text-gray-400 focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10"
        />
      </div>

      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">
          Năm/ngày mất (để trống nếu còn sống)
        </label>
        <input
          type="text" name="died"
          value={v.died ?? ""}
          placeholder="1978-09-04"
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm text-gray-800 shadow-theme-xs placeholder:text-gray-400 focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10"
        />
      </div>

      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">
          Nơi sinh
        </label>
        <input
          type="text" name="birth_place"
          value={v.birth_place ?? ""}
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm text-gray-800 shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10"
        />
      </div>

      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">
          Nơi mất
        </label>
        <input
          type="text" name="death_place"
          value={v.death_place ?? ""}
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm text-gray-800 shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10"
        />
      </div>
    </div>
  </fieldset>

  <!-- ─── Relations ───────────────────────────────────────────── -->
  <fieldset id="section-relations" class="scroll-mt-24 rounded-2xl border border-border bg-card p-5 shadow-theme-xs">
    <legend class="px-2 text-theme-sm font-semibold text-gray-800">Quan hệ</legend>
    <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Cha</label>
        <select
          name="father_id"
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm text-gray-800 shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10"
        >
          <option value="">— không chọn —</option>
          {refOptions.map((r) => (
            <option value={r.id} selected={v.father_id === r.id}>
              {r.name} (đời {r.gen})
            </option>
          ))}
        </select>
      </div>
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Mẹ</label>
        <select
          name="mother_id"
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm text-gray-800 shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10"
        >
          <option value="">— không chọn —</option>
          {refOptions.map((r) => (
            <option value={r.id} selected={v.mother_id === r.id}>
              {r.name} (đời {r.gen})
            </option>
          ))}
        </select>
      </div>
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Vợ / chồng</label>
        <select
          name="spouse_id"
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm text-gray-800 shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10"
        >
          <option value="">— không chọn —</option>
          {refOptions.map((r) => (
            <option value={r.id} selected={v.spouse_id === r.id}>
              {r.name} (đời {r.gen})
            </option>
          ))}
        </select>
      </div>
    </div>
  </fieldset>

  <!-- ─── Bio ─────────────────────────────────────────────────── -->
  <fieldset id="section-intro" class="scroll-mt-24 rounded-2xl border border-border bg-card p-5 shadow-theme-xs">
    <legend class="px-2 text-theme-sm font-semibold text-gray-800">Giới thiệu</legend>
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">
          Tiểu sử (vi) *
        </label>
        <textarea
          name="bio" required rows="3"
          class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm text-gray-800 shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10"
        >{v.bio ?? ""}</textarea>
      </div>
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">
          Tiểu sử (en) *
        </label>
        <textarea
          name="bio_en" required rows="3"
          class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm text-gray-800 shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10"
        >{v.bio_en ?? ""}</textarea>
      </div>
      <div class="md:col-span-2">
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">
          Nội dung dài (markdown, không bắt buộc)
        </label>
        <textarea
          name="body_md" rows="6"
          class="w-full rounded-lg border border-gray-300 px-4 py-2.5 font-mono text-theme-xs text-gray-800 shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10"
        >{v.body_md ?? ""}</textarea>
      </div>
    </div>
  </fieldset>

  <!-- ─── Other ───────────────────────────────────────────────── -->
  <fieldset id="section-personal" class="scroll-mt-24 rounded-2xl border border-border bg-card p-5 shadow-theme-xs">
    <legend class="px-2 text-theme-sm font-semibold text-gray-800">Cá nhân khác</legend>
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Nơi ở hiện tại</label>
        <input
          type="text" name="location"
          value={v.location ?? ""}
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm text-gray-800 shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10"
        />
      </div>
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Nghề nghiệp (vi)</label>
        <input
          type="text" name="job"
          value={v.job ?? ""}
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm text-gray-800 shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10"
        />
      </div>
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Nghề nghiệp (en)</label>
        <input
          type="text" name="job_en"
          value={v.job_en ?? ""}
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm text-gray-800 shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10"
        />
      </div>
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Sở thích (cách nhau bằng dấu phẩy)</label>
        <input
          type="text" name="hobbies"
          value={formatCsv(v.hobbies)}
          placeholder="Đan tre, Thư pháp, Trồng sen"
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm text-gray-800 shadow-theme-xs placeholder:text-gray-400 focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10"
        />
      </div>
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Tags (cách nhau bằng dấu phẩy)</label>
        <input
          type="text" name="tags"
          value={formatCsv(v.tags)}
          placeholder="khai-tổ, phụ-mẫu"
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm text-gray-800 shadow-theme-xs placeholder:text-gray-400 focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10"
        />
      </div>
      <div class="md:col-span-2">
        <AttachmentInput
          urlFieldName="photo"
          currentUrl={v.photo ?? null}
          label="Ảnh đại diện"
        />
      </div>
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Pattern (nền vẽ)</label>
        <select
          name="pattern"
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm text-gray-800 shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10"
        >
          <option value="">— không —</option>
          {(["hatch", "dots", "lines", "bamboo", "glow"] as const).map((p) => (
            <option value={p} selected={v.pattern === p}>{p}</option>
          ))}
        </select>
      </div>
    </div>
  </fieldset>

  <!-- ─── Contact ─────────────────────────────────────────────── -->
  <fieldset id="section-contact" class="scroll-mt-24 rounded-2xl border border-border bg-card p-5 shadow-theme-xs">
    <legend class="px-2 text-theme-sm font-semibold text-gray-800">Liên hệ</legend>
    <p class="mb-4 text-theme-xs text-gray-500">
      Phone / email / address chỉ hiển thị công khai nếu bật <em>Cho phép hiển thị</em>.
      Privacy scan tự động kiểm tra build không leak.
    </p>
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      <label class="flex items-center gap-2 text-theme-sm text-gray-700 md:col-span-2">
        <input
          type="checkbox" name="contact_public" value="1"
          checked={!!v.contact_public}
          class="h-4 w-4 rounded border-gray-300 text-brand-500 focus:ring-brand-500/20"
        />
        Cho phép hiển thị thông tin liên hệ trên trang công khai
      </label>
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Điện thoại</label>
        <input
          type="text" name="phone"
          value={v.phone ?? ""}
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm text-gray-800 shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10"
        />
      </div>
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Email</label>
        <input
          type="email" name="email"
          value={v.email ?? ""}
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm text-gray-800 shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10"
        />
      </div>
      <div class="md:col-span-2">
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Địa chỉ</label>
        <input
          type="text" name="address"
          value={v.address ?? ""}
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm text-gray-800 shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10"
        />
      </div>
    </div>
  </fieldset>

  <!-- ─── Status ──────────────────────────────────────────────── -->
  <fieldset id="section-status" class="scroll-mt-24 rounded-2xl border border-border bg-card p-5 shadow-theme-xs">
    <legend class="px-2 text-theme-sm font-semibold text-gray-800">Trạng thái</legend>
    <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:gap-6">
      <label class="flex items-center gap-2 text-theme-sm text-gray-700">
        <input type="radio" name="status" value="published"
          checked={(v.status ?? "published") === "published"}
          class="h-4 w-4 border-gray-300 text-brand-500" />
        Đã xuất bản (hiển thị trên trang công khai)
      </label>
      <label class="flex items-center gap-2 text-theme-sm text-gray-700">
        <input type="radio" name="status" value="draft"
          checked={v.status === "draft"}
          class="h-4 w-4 border-gray-300 text-brand-500" />
        Bản nháp (chỉ admin thấy)
      </label>
    </div>
  </fieldset>

  {v.died && (
    <fieldset id="section-memorial" class="scroll-mt-24 rounded-2xl border border-border bg-card p-5 shadow-theme-xs">
      <legend class="px-2 text-theme-sm font-semibold text-gray-800">Tưởng niệm</legend>
      <p class="mb-4 text-xs text-gray-500">
        Trang tưởng niệm tự xuất hiện khi thành viên có ngày mất. Tắt nếu muốn ẩn (giữ data).
      </p>

      <label class="flex items-start gap-3 mb-4">
        <input
          type="checkbox"
          name="memorial_enabled"
          checked={v.memorial_enabled !== false}
          class="mt-1 h-4 w-4 border-gray-300 rounded text-brand-500"
        />
        <span class="text-theme-sm text-gray-700">
          <strong class="text-gray-800">Bật trang tưởng niệm</strong>
          <span class="block text-xs text-gray-500 mt-0.5">/memorial/{v.id ?? "[id]"}</span>
        </span>
      </label>

      <div class="mb-4">
        <p class="mb-2 text-theme-sm text-gray-700">Lịch tính ngày giỗ</p>
        <div class="flex flex-wrap gap-4">
          {[
            { value: "lunar", label: "Âm lịch (truyền thống)" },
            { value: "solar", label: "Dương lịch" },
            { value: "both",  label: "Cả hai (gửi alert 2 lần)" },
          ].map((opt) => (
            <label class="flex items-center gap-2 text-theme-sm text-gray-700">
              <input
                type="radio"
                name="anniversary_calendar"
                value={opt.value}
                checked={(v.anniversary_calendar ?? "lunar") === opt.value}
                class="h-4 w-4 border-gray-300 text-brand-500"
              />
              {opt.label}
            </label>
          ))}
        </div>
      </div>

      <div>
        <p class="mb-1 text-theme-sm text-gray-700">Ngày âm lịch (tuỳ chỉnh, để trống = tự tính)</p>
        <p class="mb-2 text-xs text-gray-500">
          Bỏ trống nếu muốn tự động chuyển từ ngày dương. Điền nếu lib chuyển sai năm nhuận.
        </p>
        <div class="grid grid-cols-3 gap-3 max-w-md">
          <input
            type="number"
            name="death_date_lunar_year"
            value={v.death_date_lunar?.year ?? ""}
            placeholder="Năm âm"
            min="1900" max="2200"
            class="h-11 rounded-lg border border-gray-300 px-3 text-theme-sm"
          />
          <input
            type="number"
            name="death_date_lunar_month"
            value={v.death_date_lunar?.month ?? ""}
            placeholder="Tháng (1-12)"
            min="1" max="12"
            class="h-11 rounded-lg border border-gray-300 px-3 text-theme-sm"
          />
          <input
            type="number"
            name="death_date_lunar_day"
            value={v.death_date_lunar?.day ?? ""}
            placeholder="Ngày (1-30)"
            min="1" max="30"
            class="h-11 rounded-lg border border-gray-300 px-3 text-theme-sm"
          />
        </div>
        <label class="mt-2 flex items-center gap-2 text-xs text-gray-600">
          <input
            type="checkbox"
            name="death_date_lunar_leap"
            checked={v.death_date_lunar?.isLeap === true}
            class="h-3.5 w-3.5 border-gray-300 rounded"
          />
          Tháng nhuận
        </label>
      </div>

      {mode === "edit" && v.id && (
        <div class="mt-5 flex flex-wrap gap-3 border-t border-border pt-4">
          <a
            href={`/memorial/${v.id}`}
            target="_blank"
            class="rounded-lg border border-border px-4 py-2 text-xs font-medium text-foreground hover:bg-accent"
          >
            Xem trang tưởng niệm ↗
          </a>
          <a
            href={`/admin/incense/${v.id}`}
            class="rounded-lg border border-border px-4 py-2 text-xs font-medium text-foreground hover:bg-accent"
          >
            Xem log thắp hương
          </a>
        </div>
      )}
    </fieldset>
  )}

  <div class="flex items-center justify-between gap-3">
    <a
      href="/admin/members"
      class="rounded-lg border border-border bg-background px-5 py-2.5 text-sm font-medium text-foreground hover:bg-accent"
    >
      Hủy
    </a>
    <button
      type="submit"
      class="rounded-lg bg-primary px-5 py-2.5 text-sm font-medium text-primary-foreground shadow-theme-xs hover:bg-brand-600"
    >
      {submitLabel}
    </button>
  </div>
</form>

<style>
  .form-toc-link.is-active {
    background-color: var(--color-primary);
    color: var(--color-primary-foreground);
  }
</style>

<script is:inline>
  // Active-section highlight in the form TOC. Uses IntersectionObserver
  // to track which fieldset is most in view as the user scrolls.
  (() => {
    const links = Array.from(document.querySelectorAll(".form-toc-link"));
    if (links.length === 0) return;
    const sections = links
      .map((a) => {
        const id = a.getAttribute("href")?.slice(1);
        return id ? document.getElementById(id) : null;
      })
      .filter((s) => Boolean(s));
    if (sections.length === 0) return;

    const setActive = (id) => {
      links.forEach((a) => {
        a.classList.toggle("is-active", a.getAttribute("href") === `#${id}`);
      });
    };

    // First section starts active.
    setActive(sections[0].id);

    const io = new IntersectionObserver(
      (entries) => {
        // Pick the entry with the highest intersection ratio that's still
        // visible. Avoids flicker between adjacent sections.
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio);
        if (visible.length === 0) return;
        setActive(visible[0].target.id);
      },
      {
        // Account for sticky header (~64px) + sticky nav (~56px).
        rootMargin: "-128px 0px -50% 0px",
        threshold: [0, 0.25, 0.5, 0.75, 1],
      },
    );

    sections.forEach((s) => io.observe(s));
  })();
</script>
