---
import type { TraditionRow } from "@/lib/traditions-admin";
import { TRADITION_CATS, TRADITION_ICONS } from "@/lib/traditions-admin";
import { formatCsv } from "@/lib/members-admin";

interface Props {
  mode: "create" | "edit";
  values: Partial<TraditionRow>;
  fieldError?: string | null;
  fieldOk?: string | null;
}
const { mode, values: v, fieldError, fieldOk } = Astro.props;
const submitLabel = mode === "create" ? "Tạo truyền thống" : "Lưu thay đổi";

const catLabel: Record<(typeof TRADITION_CATS)[number], string> = {
  food: "Ẩm thực",
  festival: "Lễ hội",
  ceremony: "Nghi lễ",
  craft: "Nghề truyền thống",
};
---

<form method="post" class="space-y-6">
  {fieldError && <div class="rounded-lg border border-error-100 bg-error-50 px-4 py-3 text-theme-sm text-error-700">{fieldError}</div>}
  {fieldOk && <div class="rounded-lg border border-success-100 bg-success-50 px-4 py-3 text-theme-sm text-success-700">{fieldOk}</div>}

  <fieldset class="rounded-2xl border border-gray-200 bg-white p-5 shadow-theme-xs">
    <legend class="px-2 text-theme-sm font-semibold text-gray-800">Định danh</legend>
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">ID (slug, không đổi sau tạo) *</label>
        <input type="text" name="id" required pattern="[a-z0-9][a-z0-9-]{0,30}"
          value={v.id ?? ""} readonly={mode === "edit"} placeholder="vd: banh-it-la-gai"
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10 read-only:bg-gray-50 read-only:text-gray-500" />
      </div>
      <div class="md:col-span-1">
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Danh mục *</label>
        <select name="category" required class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10">
          {TRADITION_CATS.map((c) => (
            <option value={c} selected={v.category === c}>{catLabel[c]}</option>
          ))}
        </select>
      </div>
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Tên (vi) *</label>
        <input type="text" name="name" required value={v.name ?? ""}
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10" />
      </div>
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Tên (en) *</label>
        <input type="text" name="name_en" required value={v.name_en ?? ""}
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10" />
      </div>
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Icon *</label>
        <select name="icon" required class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10">
          {TRADITION_ICONS.map((i) => (
            <option value={i} selected={v.icon === i}>{i}</option>
          ))}
        </select>
      </div>
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">URL ảnh</label>
        <input type="url" name="image" value={v.image ?? ""} placeholder="https://..."
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10" />
      </div>
    </div>
  </fieldset>

  <fieldset class="rounded-2xl border border-gray-200 bg-white p-5 shadow-theme-xs">
    <legend class="px-2 text-theme-sm font-semibold text-gray-800">Mô tả</legend>
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Mô tả ngắn (vi) *</label>
        <textarea name="desc_text" required rows="3" class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10">{v.desc_text ?? ""}</textarea>
      </div>
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Mô tả ngắn (en) *</label>
        <textarea name="desc_en" required rows="3" class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10">{v.desc_en ?? ""}</textarea>
      </div>
      <div class="md:col-span-2">
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Nguồn gốc</label>
        <input type="text" name="origin" value={v.origin ?? ""}
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10" />
      </div>
      <div class="md:col-span-2">
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Nội dung dài (markdown)</label>
        <textarea name="body_md" rows="6" class="w-full rounded-lg border border-gray-300 px-4 py-2.5 font-mono text-theme-xs shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10">{v.body_md ?? ""}</textarea>
      </div>
      <div class="md:col-span-2">
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Tags (CSV)</label>
        <input type="text" name="tags" value={formatCsv(v.tags)} placeholder="tết, nông-thôn"
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10" />
      </div>
    </div>
  </fieldset>

  <div class="flex items-center justify-between gap-3">
    <a href="/admin/traditions" class="rounded-lg border border-gray-200 px-5 py-2.5 text-theme-sm font-medium text-gray-700 hover:bg-gray-50">Hủy</a>
    <button type="submit" class="rounded-lg bg-brand-500 px-5 py-2.5 text-theme-sm font-medium text-white shadow-theme-xs hover:bg-brand-600">{submitLabel}</button>
  </div>
</form>
