---
interface Props {
  pathname: string;
  role: "admin" | "editor" | "branch_editor";
}

const { pathname, role } = Astro.props;

const sections: {
  heading: string;
  items: { href: string; label: string; icon: string; adminOnly?: boolean }[];
}[] = [
  {
    heading: "Nội dung",
    items: [
      { href: "/admin", label: "Tổng quan", icon: "📊" },
      { href: "/admin/members", label: "Thành viên", icon: "👤" },
      { href: "/admin/timeline", label: "Niên đại", icon: "📜" },
      { href: "/admin/traditions", label: "Truyền thống", icon: "🍚" },
      { href: "/admin/photos", label: "Album", icon: "🖼" },
      { href: "/admin/quotes", label: "Câu nói", icon: "💬" },
      { href: "/admin/dates", label: "Ngày lễ", icon: "📅" },
      { href: "/admin/locations", label: "Địa điểm", icon: "📍" },
    ],
  },
  {
    heading: "Hệ thống",
    items: [
      { href: "/admin/users", label: "Người dùng", icon: "👥", adminOnly: true },
      { href: "/admin/allowed-emails", label: "Email được mời", icon: "✉️", adminOnly: true },
      { href: "/admin/audit", label: "Nhật ký", icon: "🪵", adminOnly: true },
    ],
  },
];

function isActive(href: string) {
  if (href === "/admin") return pathname === "/admin";
  return pathname.startsWith(href);
}
---

<aside class="hidden lg:flex flex-col w-64 shrink-0 bg-[oklch(28%_0.05_250)] text-white min-h-screen sticky top-0">
  <div class="px-5 py-5 border-b border-white/10">
    <a href="/admin" class="block">
      <div class="font-display text-lg leading-tight">Gia phả họ Nguyễn</div>
      <div class="text-xs uppercase tracking-wider text-white/60 mt-0.5">Quản trị</div>
    </a>
  </div>

  <nav class="flex-1 overflow-y-auto px-3 py-4 space-y-6 text-sm">
    {sections.map((section) => {
      const visible = section.items.filter(
        (i) => !i.adminOnly || role === "admin",
      );
      if (visible.length === 0) return null;
      return (
        <div>
          <div class="px-2 mb-2 text-xs uppercase tracking-wider text-white/50">
            {section.heading}
          </div>
          <ul class="space-y-0.5">
            {visible.map((item) => (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    "flex items-center gap-3 px-3 py-2 rounded-md transition-colors",
                    isActive(item.href)
                      ? "bg-white/10 text-white"
                      : "text-white/75 hover:bg-white/5 hover:text-white",
                  ]}
                >
                  <span class="text-base w-5 text-center" aria-hidden="true">{item.icon}</span>
                  <span>{item.label}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      );
    })}
  </nav>

  <div class="px-3 py-3 border-t border-white/10">
    <a
      href="/"
      class="flex items-center gap-2 px-3 py-2 rounded-md text-white/70 hover:bg-white/5 hover:text-white text-sm"
    >
      <span aria-hidden="true">🏠</span>
      <span>Xem trang công khai</span>
    </a>
  </div>
</aside>
