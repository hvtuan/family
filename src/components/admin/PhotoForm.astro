---
import type { PhotoRow } from "@/lib/photos-admin";
import MemberPicker from "./MemberPicker.astro";
import PhotoEditorInput from "./PhotoEditorInput.astro";

interface Props {
  mode: "create" | "edit";
  values: Partial<PhotoRow>;
  refs: { id: string; name: string; gen: number }[];
  selectedMembers?: string[];
  fieldError?: string | null;
  fieldOk?: string | null;
}
const { mode, values: v, refs, selectedMembers = [], fieldError, fieldOk } = Astro.props;
---

<form method="post" enctype="multipart/form-data" class="space-y-6">
  {fieldError && <div class="rounded-lg border border-error-100 bg-error-50 px-4 py-3 text-theme-sm text-error-700">{fieldError}</div>}
  {fieldOk && <div class="rounded-lg border border-success-100 bg-success-50 px-4 py-3 text-theme-sm text-success-700">{fieldOk}</div>}

  <fieldset class="rounded-2xl border border-gray-200 bg-white p-5 shadow-theme-xs">
    <legend class="px-2 text-theme-sm font-semibold text-gray-800">Ảnh</legend>
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">ID (slug, không đổi sau tạo) *</label>
        <input type="text" name="id" required pattern="[a-z0-9][a-z0-9._-]{0,60}"
          value={v.id ?? ""} readonly={mode === "edit"} placeholder="vd: g3-1-graduation"
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10 read-only:bg-gray-50 read-only:text-gray-500" />
      </div>
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">URL ảnh</label>
        <input type="url" name="src" value={v.src ?? ""}
          placeholder="Để trống nếu upload file bên dưới"
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10" />
      </div>
      <div class="md:col-span-2">
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">
          Hoặc upload file mới
        </label>
        <PhotoEditorInput name="file" />
        <p class="mt-2 text-theme-xs text-gray-500">
          jpg / png / webp / gif / svg, ≤ 8 MB. File sẽ ghi đè vào
          <code class="font-mono text-theme-xs">family-photos/uploads/{`{id}`}.{`{ext}`}</code>;
          URL public tự động lưu vào trường URL ảnh.
        </p>
      </div>
      {v.src && (
        <div class="md:col-span-2">
          <p class="mb-2 text-theme-xs text-gray-500">Ảnh hiện tại:</p>
          <img src={v.src} alt={v.caption ?? ""} loading="lazy"
            class="max-h-48 rounded-lg border border-gray-200 bg-gray-50" />
        </div>
      )}
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Caption (vi) *</label>
        <input type="text" name="caption" required value={v.caption ?? ""}
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10" />
      </div>
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Caption (en) *</label>
        <input type="text" name="caption_en" required value={v.caption_en ?? ""}
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10" />
      </div>
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Năm</label>
        <input type="number" name="year" value={v.year ?? ""}
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10" />
      </div>
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Ngày (YYYY-MM-DD)</label>
        <input type="text" name="date" value={v.date ?? ""}
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10" />
      </div>
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Địa điểm chụp</label>
        <input type="text" name="location" value={v.location ?? ""}
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10" />
      </div>
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Album / sự kiện</label>
        <input type="text" name="album" value={v.album ?? ""}
          class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10" />
      </div>
      <label class="flex items-center gap-2 text-theme-sm text-gray-700 md:col-span-2">
        <input type="checkbox" name="featured" value="1" checked={v.featured}
          class="h-4 w-4 rounded border-gray-300 text-brand-500 focus:ring-brand-500/20" />
        Ảnh nổi bật (xếp đầu album)
      </label>
    </div>
  </fieldset>

  <fieldset class="rounded-2xl border border-gray-200 bg-white p-5 shadow-theme-xs">
    <legend class="px-2 text-theme-sm font-semibold text-gray-800">Thành viên trong ảnh</legend>
    <MemberPicker name="members" label="" refs={refs} selected={selectedMembers}
      hint="Tích chọn ai có mặt trong ảnh." />
  </fieldset>

  <p class="text-theme-xs text-gray-500">
    Upload ảnh mới: hiện tại mới hỗ trợ URL. Lên ảnh trực tiếp lên Supabase Storage
    qua Studio (<code>family-photos</code> bucket, public read), sau đó dán URL public vào.
  </p>

  <div class="flex items-center justify-between gap-3">
    <a href="/admin/photos" class="rounded-lg border border-gray-200 px-5 py-2.5 text-theme-sm font-medium text-gray-700 hover:bg-gray-50">Hủy</a>
    <button type="submit" class="rounded-lg bg-brand-500 px-5 py-2.5 text-theme-sm font-medium text-white shadow-theme-xs hover:bg-brand-600">
      {mode === "create" ? "Tạo ảnh" : "Lưu thay đổi"}
    </button>
  </div>
</form>
