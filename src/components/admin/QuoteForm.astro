---
import type { QuoteRow } from "@/lib/quotes-admin";
import { QUOTE_TYPES } from "@/lib/quotes-admin";

interface Props {
  mode: "create" | "edit";
  values: Partial<QuoteRow>;
  refs: { id: string; name: string; gen: number }[];
  fieldError?: string | null;
  fieldOk?: string | null;
}
const { mode, values: v, refs, fieldError, fieldOk } = Astro.props;

const typeLabel: Record<(typeof QUOTE_TYPES)[number], string> = {
  proverb: "Tục ngữ",
  family: "Lời gia đình",
  poem: "Thơ",
  letter: "Thư",
};
---

<form method="post" class="space-y-6">
  {fieldError && <div class="rounded-lg border border-error-100 bg-error-50 px-4 py-3 text-theme-sm text-error-700">{fieldError}</div>}
  {fieldOk && <div class="rounded-lg border border-success-100 bg-success-50 px-4 py-3 text-theme-sm text-success-700">{fieldOk}</div>}

  <fieldset class="rounded-2xl border border-gray-200 bg-white p-5 shadow-theme-xs">
    <legend class="px-2 text-theme-sm font-semibold text-gray-800">Nội dung</legend>
    <div class="grid grid-cols-1 gap-4">
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Câu nói (vi) *</label>
        <textarea name="text_vi" required rows="3" class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10">{v.text_vi ?? ""}</textarea>
      </div>
      <div>
        <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Câu nói (en)</label>
        <textarea name="text_en" rows="3" class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10">{v.text_en ?? ""}</textarea>
      </div>
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        <div>
          <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Tác giả (tên) *</label>
          <input type="text" name="author" required value={v.author ?? ""}
            placeholder="vd: Cụ Tổ, Tục ngữ"
            class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10" />
        </div>
        <div>
          <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Liên kết tới thành viên</label>
          <select name="author_ref" class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10">
            <option value="">— không —</option>
            {refs.map((r) => (
              <option value={r.id} selected={v.author_ref === r.id}>{r.name} (đời {r.gen})</option>
            ))}
          </select>
        </div>
        <div>
          <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Loại *</label>
          <select name="type" required class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10">
            {QUOTE_TYPES.map((t) => (
              <option value={t} selected={v.type === t}>{typeLabel[t]}</option>
            ))}
          </select>
        </div>
        <div>
          <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Bối cảnh</label>
          <input type="text" name="context" value={v.context ?? ""}
            class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10" />
        </div>
      </div>
    </div>
  </fieldset>

  <div class="flex items-center justify-between gap-3">
    <a href="/admin/quotes" class="rounded-lg border border-gray-200 px-5 py-2.5 text-theme-sm font-medium text-gray-700 hover:bg-gray-50">Hủy</a>
    <button type="submit" class="rounded-lg bg-brand-500 px-5 py-2.5 text-theme-sm font-medium text-white shadow-theme-xs hover:bg-brand-600">
      {mode === "create" ? "Tạo câu nói" : "Lưu thay đổi"}
    </button>
  </div>
</form>
