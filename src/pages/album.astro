---
import Base from "@/layouts/Base.astro";
import PageHead from "@/components/astro/PageHead.astro";
import { getCollection } from "astro:content";

const photos = await getCollection("photos");
---

<Base title="Album" pageKey="album">
  <PageHead
    kicker="Album • Photographs"
    title="Album gia đình"
    subtitle="Những khoảnh khắc đã đi qua, lưu giữ trong từng tấm ảnh."
    subtitleEn="Moments that have passed, kept in every frame"
  />

  <section class="album">
    {
      photos.length === 0 ? (
        <div class="album-empty">
          <div class="empty-frame" aria-hidden="true">
            <span class="empty-corner top-left" />
            <span class="empty-corner top-right" />
            <span class="empty-corner bottom-left" />
            <span class="empty-corner bottom-right" />
            <span class="empty-icon">❀</span>
          </div>
          <h2>Album đang chờ những bức ảnh đầu tiên</h2>
          <p lang="en" class="empty-en">
            The album is awaiting its first photographs.
          </p>
          <p class="empty-help">
            Khi có ảnh, bỏ vào{" "}
            <code>src/content/photos/</code>{" "}cùng metadata YAML và trang sẽ tự cập nhật.
          </p>
        </div>
      ) : (
        <ul class="photo-grid">
          {photos.map((p) => (
            <li class="photo-card">
              <figure>
                <div class="photo-frame">
                  <img
                    src={p.data.src.src}
                    width={p.data.src.width}
                    height={p.data.src.height}
                    alt={p.data.caption}
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <figcaption>
                  <p>{p.data.caption}</p>
                  <p lang="en">{p.data.captionEn}</p>
                  {(p.data.year || p.data.location) && (
                    <p class="photo-meta">
                      {[p.data.year, p.data.location].filter(Boolean).join(" • ")}
                    </p>
                  )}
                </figcaption>
              </figure>
            </li>
          ))}
        </ul>
      )
    }
  </section>

  <style>
    .album {
      max-width: 1240px;
      margin: 0 auto;
      padding: 1rem 1.25rem 4rem;
    }
    .album-empty {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      padding: 4rem 1.25rem;
      text-align: center;
    }
    .empty-frame {
      position: relative;
      width: min(420px, 90vw);
      aspect-ratio: 4/3;
      background:
        repeating-linear-gradient(
          135deg,
          var(--color-paper-3) 0,
          var(--color-paper-3) 8px,
          var(--color-paper-2) 8px,
          var(--color-paper-2) 16px
        );
      border: 1px solid var(--color-line);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .empty-corner {
      position: absolute;
      width: 24px;
      height: 24px;
      border: 2px solid var(--color-vermilion);
      opacity: 0.7;
    }
    .empty-corner.top-left {
      top: 12px;
      left: 12px;
      border-right: 0;
      border-bottom: 0;
    }
    .empty-corner.top-right {
      top: 12px;
      right: 12px;
      border-left: 0;
      border-bottom: 0;
    }
    .empty-corner.bottom-left {
      bottom: 12px;
      left: 12px;
      border-right: 0;
      border-top: 0;
    }
    .empty-corner.bottom-right {
      bottom: 12px;
      right: 12px;
      border-left: 0;
      border-top: 0;
    }
    .empty-icon {
      font-size: 3rem;
      color: var(--color-vermilion);
      opacity: 0.6;
    }
    .album-empty h2 {
      font-size: 1.5rem;
    }
    .empty-en {
      font-size: 0.78rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--color-ink-3);
    }
    .empty-help {
      max-width: 50ch;
      color: var(--color-ink-2);
    }
    .empty-help code {
      background: var(--color-paper-2);
      padding: 0.1rem 0.45rem;
      border-radius: 6px;
      font-family: var(--font-mono);
      font-size: 0.85em;
    }

    .photo-grid {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1.25rem;
    }
    .photo-card figure {
      margin: 0;
      background: var(--color-cream);
      border: 1px solid var(--color-line);
      border-radius: 12px;
      overflow: hidden;
      box-shadow: var(--shadow-paper-1);
    }
    .photo-frame {
      aspect-ratio: 4/3;
      background: var(--color-paper-3);
    }
    .photo-frame img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .photo-card figcaption {
      padding: 0.875rem 1rem 1rem;
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
    }
    .photo-card figcaption p[lang="en"] {
      font-size: 0.82rem;
      color: var(--color-ink-3);
      font-style: italic;
    }
    .photo-meta {
      margin-top: 0.4rem;
      font-size: 0.78rem;
      color: var(--color-ink-3);
      letter-spacing: 0.04em;
    }
  </style>
</Base>
