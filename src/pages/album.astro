---
export const prerender = false;
import Base from "@/layouts/Base.astro";
import PageHead from "@/components/astro/PageHead.astro";
import PhotoCard from "@/components/astro/PhotoCard.astro";
import { getPhotos } from "@/lib/content";

const photos = await getPhotos();
---

<Base title="Album" pageKey="album">
  <PageHead
    kicker="Album • Photographs"
    title="Album gia đình"
    subtitle="Những khoảnh khắc đã đi qua, lưu giữ trong từng tấm ảnh."
    subtitleEn="Moments that have passed, kept in every frame"
  />

  <section class="max-w-[1240px] mx-auto px-5 pt-4 pb-16">
    {
      photos.length === 0 ? (
        <div class="flex flex-col items-center gap-4 py-16 text-center px-5">
          <div class="relative w-[min(420px,90vw)] aspect-[4/3] [background:repeating-linear-gradient(135deg,var(--color-paper-3)_0,var(--color-paper-3)_8px,var(--color-paper-2)_8px,var(--color-paper-2)_16px)] border border-line rounded-xl flex items-center justify-center" aria-hidden="true">
            <span class="absolute top-3 left-3 w-6 h-6 border-2 border-vermilion border-r-0 border-b-0 opacity-70"></span>
            <span class="absolute top-3 right-3 w-6 h-6 border-2 border-vermilion border-l-0 border-b-0 opacity-70"></span>
            <span class="absolute bottom-3 left-3 w-6 h-6 border-2 border-vermilion border-r-0 border-t-0 opacity-70"></span>
            <span class="absolute bottom-3 right-3 w-6 h-6 border-2 border-vermilion border-l-0 border-t-0 opacity-70"></span>
            <span class="text-5xl text-vermilion opacity-60">❀</span>
          </div>
          <h2 class="text-2xl">Album đang chờ những bức ảnh đầu tiên</h2>
          <p lang="en" class="text-[0.78rem] tracking-[0.18em] uppercase text-ink-3">
            The album is awaiting its first photographs.
          </p>
          <p class="max-w-[50ch] text-ink-2">
            Khi có ảnh, bỏ vào{" "}
            <code class="bg-paper-2 px-1.5 py-0.5 rounded font-mono text-[0.85em]">src/content/photos/</code>{" "}cùng metadata YAML và trang sẽ tự cập nhật.
          </p>
        </div>
      ) : (
        <ul class="list-none m-0 p-0 grid grid-cols-1 sm:grid-cols-[repeat(auto-fit,minmax(240px,1fr))] gap-5">
          {photos.map((p) => (
            <PhotoCard photo={p.data} />
          ))}
        </ul>
      )
    }
  </section>
</Base>
