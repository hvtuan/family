---
export const prerender = false;
import Base from "@/layouts/Base.astro";
import PageHead from "@/components/astro/PageHead.astro";
import MemberFilter from "@/components/react/MemberFilter";
import { getMembers } from "@/lib/content";
import { toClientMember } from "@/lib/members-client";

const all = await getMembers((entry) => entry.data.status === "published");
const clientMembers = all.map(toClientMember);
const totalGens = new Set(clientMembers.map((m) => m.gen)).size;
---

<Base title="Thành viên" pageKey="members">
  <PageHead
    kicker="Members"
    title="Tất cả thành viên"
    subtitle={`${clientMembers.length} thành viên qua ${totalGens} thế hệ. Tìm kiếm và lọc bên dưới.`}
    subtitleEn={`${clientMembers.length} members across ${totalGens} generations`}
  />

  <section class="max-w-[1240px] mx-auto px-5 pt-2 pb-20">
    <MemberFilter members={clientMembers} client:visible />
  </section>
</Base>
