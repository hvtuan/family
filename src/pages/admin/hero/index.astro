---
import AdminLayout from "@/layouts/AdminLayout.astro";
import HeroSlidesList, { type HeroSlideItem } from "@/components/admin/HeroSlidesList.tsx";
import MediaUploaderModal from "@/components/admin/MediaUploaderModal.tsx";
import {
  listHeroSlides, createHeroSlide, updateHeroSlide,
  deleteHeroSlide, reorderHeroSlides,
} from "@/lib/hero-admin";

export const prerender = false;

// POST handler for the React island's fetch calls. Returns JSON.
if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = String(form.get("action") ?? "");
  try {
    if (action === "create") {
      const photo_id = String(form.get("photo_id") ?? "");
      if (!photo_id) throw new Error("photo_id required");
      await createHeroSlide({
        photo_id,
        sort_order: Number(form.get("sort_order") ?? 0),
        active: String(form.get("active") ?? "1") === "1",
      });
    } else if (action === "update") {
      const id = Number(form.get("id"));
      const headline_vi = String(form.get("headline_vi") ?? "").trim();
      const headline_en = String(form.get("headline_en") ?? "").trim();
      const cta_label = String(form.get("cta_label") ?? "").trim();
      const cta_href = String(form.get("cta_href") ?? "").trim();
      const duration_ms = Number(form.get("duration_ms"));
      const photo_id_mobile = String(form.get("photo_id_mobile") ?? "").trim();
      const active_from = String(form.get("active_from") ?? "").trim();
      const active_to = String(form.get("active_to") ?? "").trim();
      await updateHeroSlide(id, {
        headline_vi: headline_vi || null,
        headline_en: headline_en || null,
        cta_label: cta_label || null,
        cta_href: cta_href || null,
        duration_ms: Number.isFinite(duration_ms) ? duration_ms : 6000,
        photo_id_mobile: photo_id_mobile || null,
        active_from: active_from || null,
        active_to: active_to || null,
      });
    } else if (action === "toggle") {
      const id = Number(form.get("id"));
      const active = String(form.get("active") ?? "1") === "1";
      await updateHeroSlide(id, { active });
    } else if (action === "delete") {
      await deleteHeroSlide(Number(form.get("id")));
    } else if (action === "reorder") {
      const ids = String(form.get("ids") ?? "").split(",").map(Number).filter(Number.isFinite);
      await reorderHeroSlides(ids);
    } else {
      throw new Error(`unknown action: ${action}`);
    }
    return new Response(JSON.stringify({ ok: true }), {
      status: 200,
      headers: { "content-type": "application/json" },
    });
  } catch (e) {
    return new Response(
      JSON.stringify({ ok: false, error: e instanceof Error ? e.message : String(e) }),
      { status: 500, headers: { "content-type": "application/json" } },
    );
  }
}

const slides = await listHeroSlides(true);
const items: HeroSlideItem[] = slides as unknown as HeroSlideItem[];
---

<AdminLayout title="Hero homepage" crumbs={[{ label: "Hero homepage" }]}>
  <div class="space-y-6">
    <header>
      <h1 class="text-xl font-semibold text-foreground">Hero slideshow</h1>
      <p class="mt-0.5 text-sm text-muted-foreground">
        Slideshow ảnh / video full-bleed trên đầu trang chủ. Thứ tự, nội dung,
        thời gian hiển thị quản lý ở đây. Khi không có slide nào active, trang
        chủ tự về layout mặc định (Lotus + tên dòng họ).
      </p>
    </header>

    <HeroSlidesList client:load initial={items} />
  </div>

  <!-- Uppy modal so the picker dialog's "📸 Tải / chụp mới" button
       can open the Dashboard with drag-drop + webcam + paste. After
       upload the new media appears in the picker on next reload. -->
  <MediaUploaderModal client:load />
</AdminLayout>
