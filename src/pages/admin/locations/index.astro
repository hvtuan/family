---
import AdminLayout from "@/layouts/AdminLayout.astro";
import LocationsList, { type LocationRow } from "@/components/admin/LocationsList.tsx";
import ToastBanner from "@/components/admin/ToastBanner.tsx";
import { listLocations, deleteLocation } from "@/lib/locations-admin";

export const prerender = false;

let banner: { kind: "ok" | "err"; text: string } | null = null;
if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  if (form.get("action") === "delete") {
    const id = String(form.get("id") ?? "");
    try { await deleteLocation(id); banner = { kind: "ok", text: `Đã xóa "${id}".` }; }
    catch (e) { banner = { kind: "err", text: e instanceof Error ? e.message : "Xóa thất bại." }; }
  }
}
const rows = await listLocations();
const items: LocationRow[] = rows.map((l) => ({
  id: l.id,
  name: l.name,
  name_en: l.name_en,
  province: l.province ?? null,
  lat: l.lat ?? null,
  lng: l.lng ?? null,
  is_hometown: l.is_hometown,
}));
---

<AdminLayout title="Địa điểm" crumbs={[{ label: "Địa điểm" }]}>
  {banner && <ToastBanner client:load kind={banner.kind} text={banner.text} />}

  <div class="space-y-6">
    <header class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
      <div>
        <h1 class="text-xl font-semibold text-foreground">Địa điểm gia tộc</h1>
        <p class="mt-0.5 text-sm text-muted-foreground">
          Quê nhà, nơi sinh sống, nơi an táng — gắn với hành trình của gia tộc.
        </p>
      </div>
      <a
        href="/admin/locations/new"
        class="inline-flex h-10 items-center gap-2 rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground shadow-theme-xs hover:bg-brand-600"
      >
        + Thêm địa điểm
      </a>
    </header>

    <LocationsList client:load items={items} />
  </div>
</AdminLayout>
