---
import AdminLayout from "@/layouts/AdminLayout.astro";
import AuditList, { type AuditEvent } from "@/components/admin/AuditList.tsx";
import { supabaseAdmin } from "@/lib/supabase/admin";

export const prerender = false;

const me = Astro.locals.user;
if (!me || me.role !== "admin") return Astro.redirect("/admin");

type Row = {
  id: number;
  actor_id: string | null;
  action: string;
  entity_type: string;
  entity_id: string | null;
  diff: unknown;
  at: string;
};

// Last 200 rows; the React island handles client-side filtering.
const { data: rows, error } = await supabaseAdmin
  .from("audit_log")
  .select("id, actor_id, action, entity_type, entity_id, diff, at")
  .order("at", { ascending: false })
  .limit(200);
const rawEvents = (rows ?? []) as Row[];

// Resolve actor_id → email for display.
const actorIds = Array.from(
  new Set(rawEvents.map((r) => r.actor_id).filter((v): v is string => !!v)),
);
const { data: users } = actorIds.length
  ? await supabaseAdmin
      .from("app_users")
      .select("id, email")
      .in("id", actorIds)
  : { data: [] as { id: string; email: string }[] };
const actorByEmail = new Map(
  ((users ?? []) as { id: string; email: string }[]).map((u) => [u.id, u.email]),
);

const events: AuditEvent[] = rawEvents.map((e) => ({
  id: e.id,
  actor: e.actor_id
    ? actorByEmail.get(e.actor_id) ?? `${e.actor_id.slice(0, 8)}…`
    : "(service-role)",
  action: e.action,
  entity_type: e.entity_type,
  entity_id: e.entity_id ?? null,
  diff: e.diff,
  at: e.at,
}));

const entities = [
  "members", "timeline", "traditions", "photos", "quotes",
  "dates", "locations", "app_users", "allowed_emails",
];
---

<AdminLayout title="Nhật ký hoạt động" crumbs={[{ label: "Nhật ký" }]}>
  <div class="space-y-6">
    <header>
      <h1 class="text-xl font-semibold text-foreground">Nhật ký hoạt động</h1>
      <p class="mt-0.5 text-sm text-muted-foreground">
        200 sự kiện gần nhất. Trigger DB tự ghi mọi insert/update/delete trên content tables.
      </p>
    </header>

    {error && (
      <div class="rounded-lg border border-error-100 bg-error-50 px-4 py-3 text-sm text-error-700">
        Lỗi tải nhật ký: {error.message}
      </div>
    )}

    <AuditList client:load events={events} entities={entities} />
  </div>
</AdminLayout>
