---
import "@/styles/admin.css";
import { createSupabaseServerClient } from "@/lib/supabase/server";

export const prerender = false;

const supabase = createSupabaseServerClient(Astro.cookies, Astro.request);
const {
  data: { user },
} = await supabase.auth.getUser();
const email = user?.email ?? "";
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Chờ duyệt — Gia phả họ Nguyễn Admin</title>
  </head>
  <body class="bg-white">
    <div class="grid min-h-screen place-items-center px-6">
      <div class="w-full max-w-md text-center">
        <div class="mx-auto mb-6 flex h-14 w-14 items-center justify-center rounded-full bg-warning-50">
          <svg class="fill-warning-500" width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2.25a9.75 9.75 0 1 0 0 19.5 9.75 9.75 0 0 0 0-19.5ZM12.75 8a.75.75 0 0 0-1.5 0v5a.75.75 0 0 0 1.5 0V8Zm-.75 7.75a1 1 0 1 0 0 2 1 1 0 0 0 0-2Z"/>
          </svg>
        </div>
        <h1 class="mb-2 text-title-sm font-semibold text-gray-800 sm:text-title-md">
          Chờ duyệt
        </h1>
        <p class="mb-2 text-theme-sm text-gray-600 leading-relaxed">
          Tài khoản <span class="font-medium text-gray-800">{email || "của bạn"}</span>
          đã được tạo nhưng chưa nằm trong danh sách quản trị viên.
        </p>
        <p class="mb-8 text-theme-sm text-gray-500">
          Quản trị viên sẽ xem xét và cấp quyền sau.
        </p>
        <form method="post" action="/admin/logout">
          <button
            type="submit"
            class="rounded-lg border border-gray-200 px-4 py-2.5 text-theme-sm font-medium text-gray-700 hover:bg-gray-50"
          >
            Đăng xuất
          </button>
        </form>
      </div>
    </div>
  </body>
</html>
