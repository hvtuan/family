---
import { createSupabaseServerClient } from "@/lib/supabase/server";

export const prerender = false;

const supabase = createSupabaseServerClient(Astro.cookies, Astro.request);
const {
  data: { user },
} = await supabase.auth.getUser();
const email = user?.email ?? "";
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Chờ duyệt — Gia phả họ Nguyễn</title>
    <style is:inline>
      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, #f5ecd7 0%, #e6d9b3 100%);
        font-family: "Be Vietnam Pro", system-ui, sans-serif;
        color: #1a120a;
      }
      .card {
        width: min(28rem, 92vw);
        background: #faf3e0;
        border: 1px solid rgba(26, 18, 10, 0.12);
        border-radius: 1rem;
        padding: 2rem;
        box-shadow: 0 8px 24px rgba(26, 18, 10, 0.10);
        text-align: center;
      }
      h1 {
        margin: 0 0 0.5rem;
        font-family: "Lora", Georgia, serif;
        font-size: 1.6rem;
        color: #8b2a1f;
      }
      p { color: #3a2a1a; line-height: 1.6; }
      code { background: #f5ecd7; padding: 0.1rem 0.4rem; border-radius: 0.25rem; }
      form { margin-top: 1.5rem; }
      button {
        background: transparent;
        border: 1px solid rgba(26, 18, 10, 0.25);
        color: #5c4a33;
        padding: 0.5rem 1rem;
        border-radius: 0.4rem;
        cursor: pointer;
        font-size: 0.9rem;
      }
      button:hover { background: #f5ecd7; }
    </style>
  </head>
  <body>
    <main class="card">
      <h1>Chờ duyệt</h1>
      <p>
        Tài khoản <code>{email || "của bạn"}</code> đã được tạo nhưng chưa
        nằm trong danh sách quản trị viên.
      </p>
      <p>
        Quản trị viên sẽ xem xét và cấp quyền sau. /
        Your account is awaiting admin approval.
      </p>
      <form method="post" action="/admin/logout">
        <button type="submit">Đăng xuất / Sign out</button>
      </form>
    </main>
  </body>
</html>
