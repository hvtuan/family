---
import AdminLayout from "@/layouts/AdminLayout.astro";
import QuotesList, { type QuoteRow } from "@/components/admin/QuotesList.tsx";
import ToastBanner from "@/components/admin/ToastBanner.tsx";
import { listQuotes, deleteQuote } from "@/lib/quotes-admin";

export const prerender = false;

let banner: { kind: "ok" | "err"; text: string } | null = null;
if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  if (form.get("action") === "delete") {
    const id = Number(form.get("id"));
    try {
      await deleteQuote(id);
      banner = { kind: "ok", text: `Đã xóa #${id}.` };
    } catch (e) {
      banner = { kind: "err", text: e instanceof Error ? e.message : "Xóa thất bại." };
    }
  }
}
const rows = await listQuotes();
const items: QuoteRow[] = rows.map((q) => ({
  id: q.id,
  text_vi: q.text_vi,
  text_en: q.text_en ?? null,
  author: q.author,
  type: q.type,
  context: q.context ?? null,
}));
---

<AdminLayout title="Câu nói" crumbs={[{ label: "Câu nói" }]}>
  {banner && <ToastBanner client:load kind={banner.kind} text={banner.text} />}

  <div class="space-y-6">
    <header class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
      <div>
        <h1 class="text-xl font-semibold text-foreground">Câu nói gia tộc</h1>
        <p class="mt-0.5 text-sm text-muted-foreground">
          Tục ngữ, lời ông bà, thơ, thư — kho tàng ngôn ngữ của gia tộc.
        </p>
      </div>
      <a
        href="/admin/quotes/new"
        class="inline-flex h-10 items-center gap-2 rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground shadow-theme-xs hover:bg-brand-600"
      >
        + Thêm câu nói
      </a>
    </header>

    <QuotesList client:load items={items} />
  </div>
</AdminLayout>
