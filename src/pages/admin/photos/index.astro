---
// Legacy /admin/photos → /admin/media (M2 of media-v2). Bookmarks +
// existing /admin/photos/new flow still work; the canonical hub is now
// /admin/media.
export const prerender = false;
const qs = Astro.url.search ? Astro.url.search : "";
return Astro.redirect(`/admin/media${qs}`, 301);
---
