---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { listPhotos, deletePhoto } from "@/lib/photos-admin";

export const prerender = false;

let banner: { kind: "ok" | "err"; text: string } | null = null;
if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  if (form.get("action") === "delete") {
    const id = String(form.get("id") ?? "");
    try { await deletePhoto(id); banner = { kind: "ok", text: `Đã xóa "${id}".` }; }
    catch (e) { banner = { kind: "err", text: e instanceof Error ? e.message : "Xóa thất bại." }; }
  }
}
const rows = await listPhotos();
---

<AdminLayout title="Album" crumbs={[{ label: "Album" }]}>
  <div class="space-y-6">
    {banner && <div class:list={["rounded-lg border px-4 py-3 text-theme-sm",
      banner.kind === "ok" ? "border-success-100 bg-success-50 text-success-700"
        : "border-error-100 bg-error-50 text-error-700"]}>{banner.text}</div>}

    <section class="rounded-2xl border border-gray-200 bg-white shadow-theme-xs">
      <header class="flex items-center justify-between border-b border-gray-100 px-5 py-4">
        <h2 class="text-theme-sm font-semibold text-gray-800">Ảnh ({rows.length})</h2>
        <a href="/admin/photos/new" class="rounded-lg bg-brand-500 px-4 py-2 text-theme-sm font-medium text-white shadow-theme-xs hover:bg-brand-600">+ Tạo mới</a>
      </header>
      {rows.length === 0 ? (
        <div class="px-5 py-8 text-center text-gray-500 text-theme-sm">Chưa có ảnh nào.</div>
      ) : (
        <div class="grid grid-cols-1 gap-4 p-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          {rows.map((p) => (
            <div class="rounded-lg border border-gray-200 bg-white overflow-hidden">
              <div class="aspect-[4/3] bg-gray-100 relative">
                <img src={p.src} alt={p.caption} loading="lazy"
                  class="absolute inset-0 h-full w-full object-cover" />
                {p.featured && (
                  <span class="absolute top-2 left-2 rounded bg-warning-50 px-2 py-0.5 text-theme-xs font-medium text-warning-600 border border-warning-100">★</span>
                )}
              </div>
              <div class="p-3 space-y-1">
                <div class="text-theme-sm font-medium text-gray-800 line-clamp-1">{p.caption}</div>
                <div class="text-theme-xs text-gray-500">
                  {p.year ?? "—"}{p.location ? ` · ${p.location}` : ""}
                </div>
                <div class="flex items-center justify-end gap-2 pt-1">
                  <a href={`/admin/photos/${p.id}`} class="rounded-md border border-gray-200 px-3 py-1 text-theme-xs font-medium text-gray-700 hover:bg-gray-50">Sửa</a>
                  <form method="post" class="inline" onsubmit={`return confirm('Xóa "${p.id}"?');`}>
                    <input type="hidden" name="action" value="delete" />
                    <input type="hidden" name="id" value={p.id} />
                    <button type="submit" class="rounded-md border border-error-100 px-3 py-1 text-theme-xs font-medium text-error-700 hover:bg-error-50">Xóa</button>
                  </form>
                </div>
              </div>
            </div>
          ))}
        </div>
      )}
    </section>
  </div>
</AdminLayout>
