---
import AdminLayout from "@/layouts/AdminLayout.astro";
import DatesList, { type DateRow } from "@/components/admin/DatesList.tsx";
import ToastBanner from "@/components/admin/ToastBanner.tsx";
import { listDates, deleteDate } from "@/lib/dates-admin";

export const prerender = false;

let banner: { kind: "ok" | "err"; text: string } | null = null;
if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  if (form.get("action") === "delete") {
    const id = Number(form.get("id"));
    try { await deleteDate(id); banner = { kind: "ok", text: `Đã xóa #${id}.` }; }
    catch (e) { banner = { kind: "err", text: e instanceof Error ? e.message : "Xóa thất bại." }; }
  }
}
const rows = await listDates();
const items: DateRow[] = rows.map((d) => ({
  id: d.id,
  date: d.date,
  calendar: d.calendar,
  name: d.name,
  name_en: d.name_en,
  type: d.type,
  recurring: d.recurring,
  year: d.year ?? null,
}));
---

<AdminLayout title="Ngày lễ" crumbs={[{ label: "Ngày lễ" }]}>
  {banner && <ToastBanner client:load kind={banner.kind} text={banner.text} />}

  <div class="space-y-6">
    <header class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
      <div>
        <h1 class="text-xl font-semibold text-foreground">Ngày lễ gia tộc</h1>
        <p class="mt-0.5 text-sm text-muted-foreground">
          Giỗ tổ, lễ hội, sinh nhật, sum họp — các ngày quan trọng trong năm.
        </p>
      </div>
      <a
        href="/admin/dates/new"
        class="inline-flex h-10 items-center gap-2 rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground shadow-theme-xs hover:bg-brand-600"
      >
        + Thêm ngày
      </a>
    </header>

    <DatesList client:load items={items} />
  </div>
</AdminLayout>
