---
import "@/styles/admin.css";

export const prerender = false;

const errParam = Astro.url.searchParams.get("err");

const errorMessage = !errParam
  ? null
  : errParam === "missing_code"
    ? "Liên kết không hợp lệ. Hãy bấm vào liên kết quản trị viên gửi cho bạn (qua Zalo/Facebook) — không nên truy cập trực tiếp trang này."
    : errParam;
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Đăng nhập — Gia phả họ Nguyễn Admin</title>
  </head>
  <body class="bg-white">
    <div class="relative p-6 z-1 sm:p-0">
      <div class="relative flex h-screen w-full flex-col justify-center sm:p-0 lg:flex-row">
        <!-- Left: form area -->
        <div class="flex w-full flex-1 flex-col lg:w-1/2">
          <div class="mx-auto w-full max-w-md pt-10">
            <a
              href="/"
              class="inline-flex items-center text-theme-sm text-gray-500 transition-colors hover:text-gray-700"
            >
              <svg class="stroke-current" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none">
                <path d="M12.7083 5L7.5 10.2083L12.7083 15.4167" stroke="" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Về trang công khai
            </a>
          </div>

          <div class="mx-auto flex w-full max-w-md flex-1 flex-col justify-center">
            <div class="mb-5 sm:mb-8">
              <h1 class="mb-2 font-semibold text-gray-800 text-title-sm sm:text-title-md">
                Đăng nhập quản trị
              </h1>
              <p class="text-theme-sm text-gray-500">
                Trang này dành riêng cho thành viên gia đình được mời.
              </p>
            </div>

            {errorMessage && (
              <div class="mb-5 rounded-lg border border-error-100 bg-error-50 px-4 py-3 text-theme-sm text-error-700">
                {errorMessage}
              </div>
            )}

            <div class="space-y-5">
              <div class="rounded-xl border border-gray-200 bg-gray-50 p-5">
                <h3 class="text-theme-sm font-semibold text-gray-800 mb-2">
                  Cần liên kết đăng nhập?
                </h3>
                <p class="text-theme-sm text-gray-600 leading-relaxed">
                  Đăng nhập bằng <strong class="text-gray-800">liên kết một lần</strong>
                  do quản trị viên tạo và gửi qua Zalo / Facebook — không cần mật khẩu,
                  không cần email.
                </p>
                <p class="mt-3 text-theme-sm text-gray-600 leading-relaxed">
                  Liên hệ
                  <a href="mailto:hvtuan0311@gmail.com" class="font-medium text-brand-500 hover:text-brand-600">
                    chú An (hvtuan0311@gmail.com)
                  </a>
                  để được mời. Liên kết có hiệu lực 1 giờ và chỉ dùng được 1 lần.
                </p>
              </div>

              <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-theme-xs">
                <h3 class="text-theme-sm font-semibold text-gray-800 mb-2">
                  Đã có liên kết?
                </h3>
                <p class="text-theme-sm text-gray-600 leading-relaxed">
                  Bấm vào liên kết admin gửi cho bạn — bạn sẽ được tự động đăng nhập
                  và chuyển vào trang quản trị.
                </p>
              </div>
            </div>
          </div>

          <div class="mx-auto w-full max-w-md py-6 text-center text-theme-xs text-gray-400">
            © Gia phả họ Nguyễn — Quản trị nội bộ
          </div>
        </div>

        <!-- Right: brand panel -->
        <div class="relative hidden h-full w-full items-center bg-brand-950 lg:grid lg:w-1/2">
          <div class="z-1 flex items-center justify-center">
            <div class="flex max-w-xs flex-col items-center text-center">
              <div class="mb-5 flex h-16 w-16 items-center justify-center rounded-2xl bg-white/10 text-2xl font-display text-white">
                族
              </div>
              <h2 class="mb-3 text-title-sm font-semibold text-white">
                Gia phả họ Nguyễn
              </h2>
              <p class="text-theme-sm text-white/70">
                Tịnh Khê, Sơn Tịnh, Quảng Ngãi · Uống nước nhớ nguồn
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
