---
import { createSupabaseServerClient } from "@/lib/supabase/server";

export const prerender = false;

const next = Astro.url.searchParams.get("next") ?? "/admin";

let stage: "form" | "sent" | "error" = "form";
let email = "";
let errorMsg = "";

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  email = String(form.get("email") ?? "").trim().toLowerCase();

  if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
    stage = "error";
    errorMsg = "Email không hợp lệ. / Invalid email.";
  } else {
    const supabase = createSupabaseServerClient(Astro.cookies, Astro.request);
    const redirectTo = new URL(
      `/admin/auth/callback?next=${encodeURIComponent(next)}`,
      Astro.url,
    ).toString();

    const { error } = await supabase.auth.signInWithOtp({
      email,
      options: { emailRedirectTo: redirectTo },
    });

    if (error) {
      stage = "error";
      errorMsg = error.message;
    } else {
      stage = "sent";
    }
  }
}
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Đăng nhập — Gia phả họ Nguyễn</title>
    <style is:inline>
      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, #f5ecd7 0%, #e6d9b3 100%);
        font-family: "Be Vietnam Pro", system-ui, sans-serif;
        color: #1a120a;
      }
      .card {
        width: min(28rem, 92vw);
        background: #faf3e0;
        border: 1px solid rgba(26, 18, 10, 0.12);
        border-radius: 1rem;
        padding: 2rem;
        box-shadow: 0 8px 24px rgba(26, 18, 10, 0.10);
      }
      h1 {
        margin: 0 0 0.5rem;
        font-family: "Lora", Georgia, serif;
        font-size: 1.6rem;
        color: #8b2a1f;
      }
      .sub { color: #5c4a33; margin-bottom: 1.5rem; font-size: 0.95rem; }
      label { display: block; font-weight: 600; margin-bottom: 0.4rem; }
      input[type="email"] {
        width: 100%;
        padding: 0.7rem 0.9rem;
        border: 1px solid rgba(26, 18, 10, 0.25);
        border-radius: 0.5rem;
        font-size: 1rem;
        background: #fff;
        box-sizing: border-box;
      }
      button {
        margin-top: 1rem;
        width: 100%;
        padding: 0.75rem 1rem;
        background: #8b2a1f;
        color: #faf3e0;
        border: 0;
        border-radius: 0.5rem;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
      }
      button:hover { background: #6b1f17; }
      .alert {
        padding: 0.75rem 1rem;
        border-radius: 0.5rem;
        margin: 1rem 0;
        font-size: 0.95rem;
      }
      .alert-ok { background: #e6f5e6; color: #1a4d1a; border: 1px solid #b3dab3; }
      .alert-err { background: #fde7e3; color: #6b1f17; border: 1px solid #f3b8af; }
      .foot {
        margin-top: 1.5rem;
        padding-top: 1rem;
        border-top: 1px dashed rgba(26, 18, 10, 0.2);
        font-size: 0.85rem;
        color: #5c4a33;
        text-align: center;
      }
      a { color: #8b2a1f; }
    </style>
  </head>
  <body>
    <main class="card">
      <h1>Gia phả họ Nguyễn — Quản trị</h1>
      <p class="sub">
        Nhập email để nhận liên kết đăng nhập. /
        Enter your email to receive a sign-in link.
      </p>

      {stage === "sent" ? (
        <div class="alert alert-ok">
          <strong>Đã gửi email.</strong> Kiểm tra hộp thư <code>{email}</code> và
          bấm vào liên kết để đăng nhập. Liên kết hết hạn sau 1 giờ.
        </div>
      ) : (
        <form method="post">
          {stage === "error" && (
            <div class="alert alert-err">{errorMsg}</div>
          )}
          <label for="email">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            value={email}
            placeholder="ban@example.com"
          />
          <button type="submit">Gửi liên kết / Send link</button>
        </form>
      )}

      <div class="foot">
        Nếu email của bạn chưa được mời, sẽ được chuyển đến trạng thái
        <em>chờ duyệt</em> sau khi đăng nhập.
      </div>
    </main>
  </body>
</html>
