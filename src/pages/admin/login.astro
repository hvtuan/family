---
export const prerender = false;

const errParam = Astro.url.searchParams.get("err");
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Đăng nhập — Gia phả họ Nguyễn</title>
    <style is:inline>
      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, #f5ecd7 0%, #e6d9b3 100%);
        font-family: "Be Vietnam Pro", system-ui, sans-serif;
        color: #1a120a;
      }
      .card {
        width: min(30rem, 92vw);
        background: #faf3e0;
        border: 1px solid rgba(26, 18, 10, 0.12);
        border-radius: 1rem;
        padding: 2rem;
        box-shadow: 0 8px 24px rgba(26, 18, 10, 0.10);
      }
      h1 {
        margin: 0 0 0.5rem;
        font-family: "Lora", Georgia, serif;
        font-size: 1.6rem;
        color: #8b2a1f;
      }
      p { color: #3a2a1a; line-height: 1.6; }
      .alert {
        padding: 0.75rem 1rem;
        border-radius: 0.5rem;
        margin: 1rem 0;
        background: #fde7e3;
        color: #6b1f17;
        border: 1px solid #f3b8af;
        font-size: 0.95rem;
      }
      .info {
        margin-top: 1.5rem;
        padding: 1rem 1.25rem;
        background: #f5ecd7;
        border-left: 3px solid #c9a35a;
        border-radius: 0.4rem;
        font-size: 0.95rem;
      }
      a { color: #8b2a1f; }
    </style>
  </head>
  <body>
    <main class="card">
      <h1>Gia phả họ Nguyễn — Quản trị</h1>

      {errParam && (
        <div class="alert">
          {errParam === "missing_code"
            ? "Liên kết không hợp lệ. Hãy bấm vào liên kết quản trị viên gửi cho bạn (qua Zalo/Facebook) — không nên truy cập trực tiếp trang này."
            : errParam}
        </div>
      )}

      <p>
        Trang quản trị này chỉ dành cho thành viên trong gia đình được mời.
        Đăng nhập bằng <strong>liên kết một lần</strong> mà quản trị gửi qua
        Zalo / Facebook — không cần mật khẩu, không cần email.
      </p>

      <div class="info">
        <p style="margin:0 0 0.5rem; font-weight:600;">Bạn cần một liên kết?</p>
        <p style="margin:0;">
          Liên hệ <em>chú An</em> (<a href="mailto:hvtuan0311@gmail.com">hvtuan0311@gmail.com</a>)
          để được mời. Sau khi nhận liên kết, bấm vào để vào trang quản trị —
          phiên đăng nhập có hiệu lực 1 giờ.
        </p>
      </div>

      <p style="margin-top:1.5rem; font-size:0.85rem; color:#5c4a33;">
        ← <a href="/">Quay về trang công khai</a>
      </p>
    </main>
  </body>
</html>
