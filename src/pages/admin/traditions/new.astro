---
import AdminLayout from "@/layouts/AdminLayout.astro";
import TraditionForm from "@/components/admin/TraditionForm.astro";
import {
  upsertTradition,
  parseTraditionForm,
} from "@/lib/traditions-admin";
import type { TraditionRow } from "@/lib/traditions-admin";

export const prerender = false;

let fieldError: string | null = null;
let values: Partial<TraditionRow> = { category: "festival", icon: "blossom", tags: [] };

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const { input, errors } = parseTraditionForm(form);
  values = input;
  if (errors.length > 0) {
    fieldError = errors.join(" ");
  } else {
    try {
      await upsertTradition(input, "create");
      return Astro.redirect(`/admin/traditions/${input.id}?ok=created`);
    } catch (e) {
      const msg = e instanceof Error ? e.message : "Lưu thất bại.";
      fieldError = msg.includes("duplicate") || msg.includes("23505")
        ? `ID "${input.id}" đã tồn tại.` : msg;
    }
  }
}
---

<AdminLayout title="Truyền thống mới" crumbs={[{ label: "Truyền thống", href: "/admin/traditions" }, { label: "Tạo mới" }]}>
  <TraditionForm mode="create" values={values} fieldError={fieldError} />
</AdminLayout>
