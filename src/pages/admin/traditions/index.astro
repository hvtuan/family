---
import AdminLayout from "@/layouts/AdminLayout.astro";
import TraditionsList, { type TraditionRow } from "@/components/admin/TraditionsList.tsx";
import ToastBanner from "@/components/admin/ToastBanner.tsx";
import { listTraditions, deleteTradition } from "@/lib/traditions-admin";

export const prerender = false;

let banner: { kind: "ok" | "err"; text: string } | null = null;

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  if (form.get("action") === "delete") {
    const id = String(form.get("id") ?? "");
    try {
      await deleteTradition(id);
      banner = { kind: "ok", text: `Đã xóa "${id}".` };
    } catch (e) {
      banner = { kind: "err", text: e instanceof Error ? e.message : "Xóa thất bại." };
    }
  }
}

const rows = await listTraditions();
const items: TraditionRow[] = rows.map((t) => ({
  id: t.id,
  name: t.name,
  name_en: t.name_en,
  category: t.category,
  icon: t.icon,
  image: t.image ?? null,
  tags: Array.isArray(t.tags) ? (t.tags as string[]) : [],
}));
---

<AdminLayout title="Truyền thống" crumbs={[{ label: "Truyền thống" }]}>
  {banner && <ToastBanner client:load kind={banner.kind} text={banner.text} />}

  <div class="space-y-6">
    <header class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
      <div>
        <h1 class="text-xl font-semibold text-foreground">Truyền thống gia tộc</h1>
        <p class="mt-0.5 text-sm text-muted-foreground">
          Món ăn, lễ hội, nghi lễ, nghề — những giá trị văn hóa của gia tộc.
        </p>
      </div>
      <a
        href="/admin/traditions/new"
        class="inline-flex h-10 items-center gap-2 rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground shadow-theme-xs hover:bg-brand-600"
      >
        + Tạo mới
      </a>
    </header>

    <TraditionsList client:load items={items} />
  </div>
</AdminLayout>
