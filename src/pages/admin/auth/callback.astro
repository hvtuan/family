---
/**
 * Magic-link callback. Handles both flow types:
 *
 *   PKCE flow (`?code=...`)
 *     - Server-side exchangeCodeForSession via @supabase/ssr server client.
 *     - Used when login goes through the SMTP-backed signInWithOtp flow.
 *
 *   Implicit flow (`#access_token=...&refresh_token=...` in fragment)
 *     - GoTrue redirects here with tokens in the URL fragment, which is
 *       client-only — server never sees it. We render a tiny HTML page that
 *       reads the fragment, hands the tokens to the browser supabase client
 *       (`supabase.auth.setSession`), which writes the SSR session cookies,
 *       then navigates to /admin.
 *     - Used when the admin runs `pnpm admin:link <email>` to invite a
 *       cô/chú; the resulting URL is shared via Zalo/Facebook (no SMTP).
 *
 * In both cases, app_users provisioning (whitelist lookup → role/branch
 * assignment) happens in src/middleware.ts on the next request, so this
 * page does not query the DB.
 */

import { createSupabaseServerClient } from "@/lib/supabase/server";

export const prerender = false;

const url = Astro.url;
const code = url.searchParams.get("code");
const errorParam =
  url.searchParams.get("error_description") ?? url.searchParams.get("error");
const next = url.searchParams.get("next") ?? "/admin";
// `next` only applies to the PKCE branch below. Implicit flow always lands
// on /admin since GoTrue strips query params in favor of the fragment.

if (errorParam) {
  return Astro.redirect(`/admin/login?err=${encodeURIComponent(errorParam)}`);
}

if (code) {
  const supabase = createSupabaseServerClient(Astro.cookies, Astro.request);
  const { data, error } = await supabase.auth.exchangeCodeForSession(code);
  if (error || !data.user) {
    return Astro.redirect(
      `/admin/login?err=${encodeURIComponent(error?.message ?? "exchange_failed")}`,
    );
  }
  return Astro.redirect(next);
}

// Implicit flow: render a tiny client-side handler that reads window.location.hash.
// We don't know yet whether the fragment is present — only the browser can tell.
// The script either consumes the tokens and redirects, or shows an error.
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Đang đăng nhập — Gia phả họ Nguyễn</title>
    <style is:inline>
      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, #f5ecd7 0%, #e6d9b3 100%);
        font-family: "Be Vietnam Pro", system-ui, sans-serif;
        color: #1a120a;
      }
      .card {
        width: min(28rem, 92vw);
        background: #faf3e0;
        border: 1px solid rgba(26, 18, 10, 0.12);
        border-radius: 1rem;
        padding: 2rem;
        text-align: center;
        box-shadow: 0 8px 24px rgba(26, 18, 10, 0.10);
      }
      h1 {
        margin: 0 0 0.5rem;
        font-family: "Lora", Georgia, serif;
        font-size: 1.4rem;
        color: #8b2a1f;
      }
      .err { color: #6b1f17; font-size: 0.95rem; margin-top: 0.5rem; }
      a { color: #8b2a1f; }
    </style>
  </head>
  <body>
    <main class="card">
      <h1>Đang xác thực…</h1>
      <p id="status">Vui lòng chờ trong giây lát.</p>
      <p class="err" id="error" hidden></p>
      <p id="manual" hidden style="margin-top:1rem;font-size:0.9rem;">
        ← <a href="/admin/login">Quay lại đăng nhập</a>
      </p>
    </main>

    <script>
      import { supabase } from "@/lib/supabase/client";

      const status = document.getElementById("status")!;
      const errorEl = document.getElementById("error")!;
      const manual = document.getElementById("manual")!;

      function fail(msg: string) {
        status.textContent = "Đăng nhập thất bại.";
        errorEl.textContent = msg;
        errorEl.hidden = false;
        manual.hidden = false;
      }

      const hash = window.location.hash.replace(/^#/, "");
      if (!hash) {
        // No code, no fragment, no error — likely a stale visit.
        window.location.replace(
          "/admin/login?err=" + encodeURIComponent("missing_code"),
        );
      } else {
        const params = new URLSearchParams(hash);
        const access_token = params.get("access_token");
        const refresh_token = params.get("refresh_token");
        const errDesc = params.get("error_description") ?? params.get("error");

        if (errDesc) {
          fail(errDesc);
        } else if (!access_token || !refresh_token) {
          fail("Thiếu access_token hoặc refresh_token trong liên kết.");
        } else {
          (async () => {
            const { error } = await supabase.auth.setSession({
              access_token,
              refresh_token,
            });
            if (error) {
              fail(error.message);
              return;
            }
            // Strip fragment so a refresh doesn't re-trigger this handler.
            window.location.replace("/admin");
          })();
        }
      }
    </script>
  </body>
</html>
