---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { listTimeline, deleteTimelineEvent } from "@/lib/timeline-admin";

export const prerender = false;

let banner: { kind: "ok" | "err"; text: string } | null = null;
if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  if (form.get("action") === "delete") {
    const id = Number(form.get("id"));
    try { await deleteTimelineEvent(id); banner = { kind: "ok", text: `Đã xóa #${id}.` }; }
    catch (e) { banner = { kind: "err", text: e instanceof Error ? e.message : "Xóa thất bại." }; }
  }
}
const rows = await listTimeline();
const catLabel: Record<string, string> = {
  founding: "Khai lập", birth: "Sinh", marriage: "Hôn nhân",
  death: "Mất", milestone: "Cột mốc", gathering: "Sum họp",
};
---

<AdminLayout title="Niên đại" crumbs={[{ label: "Niên đại" }]}>
  <div class="space-y-6">
    {banner && <div class:list={["rounded-lg border px-4 py-3 text-theme-sm",
      banner.kind === "ok" ? "border-success-100 bg-success-50 text-success-700"
        : "border-error-100 bg-error-50 text-error-700"]}>{banner.text}</div>}

    <section class="rounded-2xl border border-gray-200 bg-white shadow-theme-xs">
      <header class="flex items-center justify-between border-b border-gray-100 px-5 py-4">
        <h2 class="text-theme-sm font-semibold text-gray-800">Sự kiện ({rows.length})</h2>
        <a href="/admin/timeline/new" class="rounded-lg bg-brand-500 px-4 py-2 text-theme-sm font-medium text-white shadow-theme-xs hover:bg-brand-600">+ Tạo mới</a>
      </header>
      <div class="overflow-x-auto">
        <table class="w-full text-left text-theme-sm">
          <thead class="bg-gray-50 text-theme-xs uppercase text-gray-500">
            <tr>
              <th class="px-5 py-3 font-medium">Năm</th>
              <th class="px-5 py-3 font-medium">Tiêu đề</th>
              <th class="px-5 py-3 font-medium">Danh mục</th>
              <th class="px-5 py-3 font-medium text-right">Hành động</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {rows.length === 0 && <tr><td colspan="4" class="px-5 py-8 text-center text-gray-500">Chưa có sự kiện nào.</td></tr>}
            {rows.map((t) => (
              <tr class="hover:bg-gray-50">
                <td class="px-5 py-3 font-medium text-gray-800">
                  {t.year}{t.date ? ` ${t.date}` : ""}{t.lunar ? " (âm)" : ""}
                </td>
                <td class="px-5 py-3 max-w-md">
                  <div class="text-gray-800">{t.title}</div>
                  <div class="text-theme-xs text-gray-500 line-clamp-1">{t.title_en}</div>
                </td>
                <td class="px-5 py-3 text-gray-700">{t.category ? catLabel[t.category] ?? t.category : "—"}</td>
                <td class="px-5 py-3 text-right">
                  <div class="flex justify-end gap-2">
                    <a href={`/admin/timeline/${t.id}`} class="rounded-md border border-gray-200 px-3 py-1 text-theme-xs font-medium text-gray-700 hover:bg-gray-50">Sửa</a>
                    <form method="post" class="inline" onsubmit={`return confirm('Xóa "${t.title}"?');`}>
                      <input type="hidden" name="action" value="delete" />
                      <input type="hidden" name="id" value={t.id} />
                      <button type="submit" class="rounded-md border border-error-100 px-3 py-1 text-theme-xs font-medium text-error-700 hover:bg-error-50">Xóa</button>
                    </form>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  </div>
</AdminLayout>
