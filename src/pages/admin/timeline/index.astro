---
import AdminLayout from "@/layouts/AdminLayout.astro";
import TimelineList, { type TimelineRow } from "@/components/admin/TimelineList.tsx";
import ToastBanner from "@/components/admin/ToastBanner.tsx";
import { listTimeline, deleteTimelineEvent } from "@/lib/timeline-admin";

export const prerender = false;

let banner: { kind: "ok" | "err"; text: string } | null = null;
if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  if (form.get("action") === "delete") {
    const id = Number(form.get("id"));
    try { await deleteTimelineEvent(id); banner = { kind: "ok", text: `Đã xóa #${id}.` }; }
    catch (e) { banner = { kind: "err", text: e instanceof Error ? e.message : "Xóa thất bại." }; }
  }
}

const rows = await listTimeline();
const items: TimelineRow[] = rows.map((t) => ({
  id: t.id,
  year: t.year,
  date: t.date ?? null,
  lunar: t.lunar,
  title: t.title,
  title_en: t.title_en ?? "",
  category: t.category ?? null,
  image: t.image ?? null,
}));
---

<AdminLayout title="Niên đại" crumbs={[{ label: "Niên đại" }]}>
  {banner && <ToastBanner client:load kind={banner.kind} text={banner.text} />}

  <div class="space-y-6">
    <header class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
      <div>
        <h1 class="text-xl font-semibold text-foreground">Niên đại gia tộc</h1>
        <p class="mt-0.5 text-sm text-muted-foreground">
          Các sự kiện theo dòng thời gian — sinh, hôn nhân, mất, sum họp.
        </p>
      </div>
      <a
        href="/admin/timeline/new"
        class="inline-flex h-10 items-center gap-2 rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground shadow-theme-xs hover:bg-brand-600"
      >
        + Tạo sự kiện
      </a>
    </header>

    <TimelineList client:load items={items} />
  </div>
</AdminLayout>
