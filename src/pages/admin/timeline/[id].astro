---
import AdminLayout from "@/layouts/AdminLayout.astro";
import TimelineForm from "@/components/admin/TimelineForm.astro";
import {
  getTimelineEvent, getTimelineMembers, upsertTimeline, parseTimelineForm,
} from "@/lib/timeline-admin";
import { listMemberRefs } from "@/lib/members-admin";
import { uploadAttachment } from "@/lib/photos-admin";
import type { TimelineRow } from "@/lib/timeline-admin";

export const prerender = false;

const id = Number(Astro.params.id!);
if (!Number.isInteger(id)) return new Response("ID không hợp lệ", { status: 404 });

let fieldError: string | null = null;
let fieldOk: string | null = null;
let existing = await getTimelineEvent(id);
if (!existing) return new Response("Không tìm thấy", { status: 404 });
if (Astro.url.searchParams.get("ok") === "created") fieldOk = "Đã tạo sự kiện.";

let values: Partial<TimelineRow> = existing;
let selectedMembers = await getTimelineMembers(id);

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const { input, memberIds, errors } = parseTimelineForm(form);
  const sanitized = { ...input, id };
  selectedMembers = memberIds;

  const imageFile = form.get("image_file");
  if (errors.length === 0 && imageFile instanceof File && imageFile.size > 0) {
    try {
      sanitized.image = await uploadAttachment(imageFile, "timeline", String(id));
    } catch (e) {
      errors.push(e instanceof Error ? e.message : "Upload ảnh thất bại.");
    }
  }
  values = sanitized;

  if (errors.length > 0) {
    fieldError = errors.join(" ");
  } else {
    try {
      await upsertTimeline(sanitized, memberIds, "update");
      existing = await getTimelineEvent(id);
      values = existing ?? values;
      selectedMembers = await getTimelineMembers(id);
      fieldOk = "Đã lưu thay đổi.";
    } catch (e) {
      fieldError = e instanceof Error ? e.message : "Lưu thất bại.";
    }
  }
}

const refs = await listMemberRefs();
---

<AdminLayout title={existing?.title ?? `#${id}`} crumbs={[{ label: "Niên đại", href: "/admin/timeline" }, { label: existing?.title ?? `#${id}` }]}>
  <TimelineForm mode="edit" values={values} refs={refs}
    selectedMembers={selectedMembers} fieldError={fieldError} fieldOk={fieldOk} />
</AdminLayout>
