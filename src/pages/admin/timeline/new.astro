---
import AdminLayout from "@/layouts/AdminLayout.astro";
import TimelineForm from "@/components/admin/TimelineForm.astro";
import { upsertTimeline, parseTimelineForm } from "@/lib/timeline-admin";
import { listMemberRefs } from "@/lib/members-admin";
import { uploadAttachment } from "@/lib/photos-admin";
import type { TimelineRow } from "@/lib/timeline-admin";

export const prerender = false;

let fieldError: string | null = null;
let values: Partial<TimelineRow> = { lunar: false, category: "milestone" };
let selectedMembers: string[] = [];

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const { input, memberIds, errors } = parseTimelineForm(form);
  values = input as Partial<TimelineRow>;
  selectedMembers = memberIds;
  if (errors.length === 0) {
    try {
      // Insert first to get the auto-id, then upload + update.
      const newId = await upsertTimeline(input, memberIds, "create");
      const imageFile = form.get("image_file");
      if (imageFile instanceof File && imageFile.size > 0) {
        const url = await uploadAttachment(imageFile, "timeline", String(newId));
        await upsertTimeline({ ...input, id: newId, image: url }, memberIds, "update");
      }
      return Astro.redirect(`/admin/timeline/${newId}?ok=created`);
    } catch (e) {
      fieldError = e instanceof Error ? e.message : "Lưu thất bại.";
    }
  } else {
    fieldError = errors.join(" ");
  }
}

const refs = await listMemberRefs();
---

<AdminLayout title="Sự kiện mới" crumbs={[{ label: "Niên đại", href: "/admin/timeline" }, { label: "Tạo mới" }]}>
  <TimelineForm mode="create" values={values} refs={refs}
    selectedMembers={selectedMembers} fieldError={fieldError} />
</AdminLayout>
