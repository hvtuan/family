---
import AdminLayout from "@/layouts/AdminLayout.astro";
import MemberPicker from "@/components/admin/MemberPicker.astro";
import PhotoEditorInput from "@/components/admin/PhotoEditorInput.astro";
import ToastBanner from "@/components/admin/ToastBanner.tsx";
import {
  getPhoto, getPhotoMembers, upsertPhoto, parsePhotoForm,
  replacePhotoMedia, deletePhoto,
} from "@/lib/photos-admin";
import { listMemberRefs } from "@/lib/members-admin";
import type { PhotoRow } from "@/lib/photos-admin";

export const prerender = false;

const id = Astro.params.id!;
let fieldError: string | null = null;
let fieldOk: string | null = null;

let existing = await getPhoto(id);
if (!existing) return new Response("Không tìm thấy", { status: 404 });

let values: Partial<PhotoRow> = existing;
let selectedMembers = await getPhotoMembers(id);

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = String(form.get("action") ?? "save");

  if (action === "delete") {
    try {
      await deletePhoto(id);
      return Astro.redirect("/admin/media?deleted=1");
    } catch (e) {
      fieldError = e instanceof Error ? e.message : "Xóa thất bại.";
    }
  } else if (action === "replace") {
    const file = form.get("file");
    if (file instanceof File && file.size > 0) {
      try {
        const media = await replacePhotoMedia(id, file);
        const updatePayload: Record<string, unknown> = {
          src: media.src,
          src_thumb: media.src_thumb,
          src_medium: media.src_medium,
          width: media.width,
          height: media.height,
          bytes: media.bytes,
          mime: media.mime,
          kind: media.kind,
          exif_stripped: media.kind === "image",
        };
        if (media.duration_seconds != null) {
          updatePayload.duration_seconds = media.duration_seconds;
        }
        const { error } = await (await import("@/lib/supabase/admin")).supabaseAdmin
          .from("photos").update(updatePayload).eq("id", id);
        if (error) throw new Error(error.message);
        existing = await getPhoto(id);
        values = existing ?? values;
        fieldOk = `Đã thay ${media.kind === "video" ? "video" : "ảnh"} + cập nhật metadata.`;
      } catch (e) {
        fieldError = e instanceof Error ? e.message : "Thay ảnh thất bại.";
      }
    } else {
      fieldError = "Chưa chọn file để thay.";
    }
  } else {
    // Default: save metadata
    const { input, memberIds, errors } = parsePhotoForm(form);
    const sanitized = { ...input, id, src: existing.src };
    selectedMembers = memberIds;

    if (errors.length > 0) {
      fieldError = errors.join(" ");
      values = sanitized;
    } else {
      try {
        await upsertPhoto(sanitized, memberIds, "update");
        existing = await getPhoto(id);
        values = existing ?? sanitized;
        selectedMembers = await getPhotoMembers(id);
        fieldOk = "Đã lưu thay đổi.";
      } catch (e) {
        fieldError = e instanceof Error ? e.message : "Lưu thất bại.";
        values = sanitized;
      }
    }
  }
}

const refs = await listMemberRefs();
const v = values as PhotoRow;
const isVideo = v.kind === "video";
const previewSrc = isVideo ? v.src : (v.src_medium || v.src);
const posterSrc = isVideo ? (v.src_medium || v.src_thumb || "") : "";
const tagsCsv = Array.isArray(v.tags) ? v.tags.join(", ") : "";
const linkedMembers = refs.filter((r) => selectedMembers.includes(r.id));
const altMissing = !v.alt_vi || !v.alt_vi.trim();

function formatDuration(seconds?: number | null): string {
  if (seconds == null || !Number.isFinite(seconds) || seconds <= 0) return "—";
  const m = Math.floor(seconds / 60);
  const s = seconds % 60;
  return `${m}:${String(s).padStart(2, "0")}`;
}
---

<AdminLayout title={v.alt_vi ?? v.caption ?? id}
  crumbs={[{ label: "Thư viện ảnh", href: "/admin/media" }, { label: v.alt_vi ?? v.caption ?? id }]}>

  {fieldError && <ToastBanner client:load kind="err" text={fieldError} />}
  {fieldOk && <ToastBanner client:load kind="ok" text={fieldOk} />}

  <div class="space-y-4">
    {altMissing && (
      <div class="rounded-lg border border-warning-100 bg-warning-50 px-4 py-3 text-theme-sm text-warning-700">
        ⚠️ Chưa có <strong>alt text (vi)</strong> — nên thêm để trình đọc màn hình mô tả được {isVideo ? "video" : "ảnh"} cho người khiếm thị.
      </div>
    )}

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-[1fr_22rem]">
      <!-- Preview + replace -->
      <section class="space-y-4">
        <div class="overflow-hidden rounded-2xl border border-gray-200 bg-black shadow-theme-xs">
          {isVideo && previewSrc ? (
            <video
              src={previewSrc}
              poster={posterSrc || undefined}
              controls
              preload="metadata"
              playsinline
              class="block max-h-[70vh] w-full bg-black"
            >
              Trình duyệt không hỗ trợ HTML5 video.
            </video>
          ) : previewSrc ? (
            <img src={previewSrc} alt={v.alt_vi ?? v.caption ?? ""}
              class="block max-h-[70vh] w-full object-contain bg-gray-50" />
          ) : (
            <div class="flex h-64 items-center justify-center text-theme-sm text-gray-500">
              Chưa có {isVideo ? "video" : "ảnh"}
            </div>
          )}
        </div>

        <div class="rounded-2xl border border-gray-200 bg-white p-5 shadow-theme-xs">
          <h3 class="mb-3 text-theme-sm font-semibold text-gray-800">
            Thay {isVideo ? "video" : "ảnh"} (giữ nguyên ID + liên kết)
          </h3>
          <form method="post" enctype="multipart/form-data" class="space-y-3">
            <input type="hidden" name="action" value="replace" />
            {isVideo ? (
              <div>
                <label class="mb-1.5 block text-theme-xs text-gray-500">File video mới (≤ 200 MB; mp4/webm/mov)</label>
                <input type="file" name="file" required accept="video/*,.mp4,.webm,.mov"
                  class="block w-full text-theme-sm file:mr-3 file:rounded-md file:border-0 file:bg-gray-100 file:px-3 file:py-2 file:text-theme-sm file:font-medium file:text-gray-700 hover:file:bg-gray-200" />
              </div>
            ) : (
              <div>
                <label class="mb-1.5 block text-theme-xs text-gray-500">File ảnh mới (≤ 25 MB; jpg/png/webp/gif/heic)</label>
                <PhotoEditorInput name="file" required={true} />
              </div>
            )}
            <div class="flex items-center justify-end">
              <button type="submit" class="rounded-lg bg-gray-900 px-4 py-2.5 text-theme-sm font-medium text-white hover:bg-gray-800">
                Thay {isVideo ? "video" : "ảnh"}
              </button>
            </div>
          </form>
          <p class="mt-2 text-theme-xs text-gray-500">
            {isVideo
              ? "Thay video không tự trích lại poster — vẫn giữ poster cũ. Để đổi poster, dùng /admin/media/[id] sau khi upload xong."
              : "EXIF (GPS, máy ảnh) được tự động xóa. Có thể crop / xoay / resize trước khi lưu. 3 phiên bản (gốc, 800w, 320w) được tạo lại."}
          </p>
        </div>

        <!-- Metadata block -->
        <div class="rounded-2xl border border-gray-200 bg-white p-5 shadow-theme-xs">
          <h3 class="mb-3 text-theme-sm font-semibold text-gray-800">Thông tin file</h3>
          <dl class="grid grid-cols-2 gap-x-4 gap-y-2 text-theme-sm">
            <dt class="text-gray-500">Loại</dt>
            <dd class="text-gray-800">{isVideo ? "🎬 Video" : "🖼️ Ảnh"}</dd>
            <dt class="text-gray-500">Kích thước</dt>
            <dd class="text-gray-800">{v.width && v.height ? `${v.width} × ${v.height} px` : "—"}</dd>
            <dt class="text-gray-500">Dung lượng</dt>
            <dd class="text-gray-800">
              {v.bytes ? (
                v.bytes >= 1024 * 1024
                  ? `${(v.bytes / 1024 / 1024).toFixed(1)} MB`
                  : `${(v.bytes / 1024).toFixed(1)} KB`
              ) : "—"}
            </dd>
            <dt class="text-gray-500">Định dạng</dt>
            <dd class="text-gray-800">{v.mime ?? "—"}</dd>
            {isVideo && (
              <>
                <dt class="text-gray-500">Thời lượng</dt>
                <dd class="text-gray-800 tabular-nums">{formatDuration(v.duration_seconds)}</dd>
                <dt class="text-gray-500">Poster</dt>
                <dd class="text-gray-800">{v.src_medium ? "✓ có" : <span class="text-warning-600">chưa có</span>}</dd>
              </>
            )}
            {!isVideo && (
              <>
                <dt class="text-gray-500">EXIF</dt>
                <dd class="text-gray-800">{v.bytes ? "đã xóa" : "—"}</dd>
                <dt class="text-gray-500">Variants</dt>
                <dd class="text-gray-800">
                  {v.src_thumb && v.src_medium ? "✓ thumb + medium" : (
                    <span class="text-warning-600">chỉ có gốc (legacy)</span>
                  )}
                </dd>
              </>
            )}
          </dl>
          <details class="mt-3">
            <summary class="cursor-pointer text-theme-xs text-gray-500">URL public</summary>
            <div class="mt-2 space-y-1.5 text-theme-xs font-mono text-gray-600">
              <div class="flex items-start gap-2">
                <span class="shrink-0 text-gray-400 not-italic">{isVideo ? "video:" : "gốc:"}</span>
                <span class="break-all flex-1">{v.src}</span>
                <button type="button" data-copy-url={v.src}
                  class="shrink-0 rounded border border-gray-200 bg-white px-1.5 py-0.5 text-[11px] font-medium text-gray-600 hover:bg-gray-50 font-sans">Copy</button>
              </div>
              {v.src_medium && (
                <div class="flex items-start gap-2">
                  <span class="shrink-0 text-gray-400">{isVideo ? "poster:" : "800w:"}</span>
                  <span class="break-all flex-1">{v.src_medium}</span>
                  <button type="button" data-copy-url={v.src_medium}
                    class="shrink-0 rounded border border-gray-200 bg-white px-1.5 py-0.5 text-[11px] font-medium text-gray-600 hover:bg-gray-50 font-sans">Copy</button>
                </div>
              )}
              {v.src_thumb && (
                <div class="flex items-start gap-2">
                  <span class="shrink-0 text-gray-400">{isVideo ? "thumb:" : "320w:"}</span>
                  <span class="break-all flex-1">{v.src_thumb}</span>
                  <button type="button" data-copy-url={v.src_thumb}
                    class="shrink-0 rounded border border-gray-200 bg-white px-1.5 py-0.5 text-[11px] font-medium text-gray-600 hover:bg-gray-50 font-sans">Copy</button>
                </div>
              )}
            </div>
          </details>

          <script is:inline>
            document.addEventListener("click", (e) => {
              const btn = e.target.closest("[data-copy-url]");
              if (!btn) return;
              const url = btn.getAttribute("data-copy-url");
              navigator.clipboard.writeText(url).then(() => {
                const orig = btn.textContent;
                btn.textContent = "✓ Copied";
                setTimeout(() => { btn.textContent = orig; }, 1200);
              }).catch(() => {});
            });
          </script>
        </div>
      </section>

      <!-- Sidebar: metadata edit form -->
      <aside class="space-y-4">
        <form method="post" class="space-y-4">
          <input type="hidden" name="action" value="save" />
          <input type="hidden" name="id" value={v.id} />

          <fieldset class="rounded-2xl border border-gray-200 bg-white p-5 shadow-theme-xs space-y-3">
            <legend class="px-2 text-theme-sm font-semibold text-gray-800">Mô tả & alt text</legend>
            <div>
              <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Caption (vi) *</label>
              <input type="text" name="caption" required value={v.caption ?? ""}
                class="h-10 w-full rounded-lg border border-gray-300 px-3 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10" />
            </div>
            <div>
              <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Caption (en) *</label>
              <input type="text" name="caption_en" required value={v.caption_en ?? ""}
                class="h-10 w-full rounded-lg border border-gray-300 px-3 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10" />
            </div>
            <div>
              <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">
                Alt text (vi) <span class="text-warning-600 font-normal text-theme-xs">— khuyên có để hỗ trợ trình đọc màn hình</span>
              </label>
              <input type="text" name="alt_vi" value={v.alt_vi ?? ""}
                placeholder="Mô tả ngắn cho người không thấy ảnh"
                class="h-10 w-full rounded-lg border border-gray-300 px-3 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10" />
            </div>
            <div>
              <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Alt text (en)</label>
              <input type="text" name="alt_en" value={v.alt_en ?? ""}
                class="h-10 w-full rounded-lg border border-gray-300 px-3 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10" />
            </div>
          </fieldset>

          <fieldset class="rounded-2xl border border-gray-200 bg-white p-5 shadow-theme-xs space-y-3">
            <legend class="px-2 text-theme-sm font-semibold text-gray-800">Thông tin ảnh</legend>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Năm</label>
                <input type="number" name="year" value={v.year ?? ""}
                  class="h-10 w-full rounded-lg border border-gray-300 px-3 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10" />
              </div>
              <div>
                <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Ngày</label>
                <input type="text" name="date" value={v.date ?? ""} placeholder="YYYY-MM-DD"
                  class="h-10 w-full rounded-lg border border-gray-300 px-3 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10" />
              </div>
            </div>
            <div>
              <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Địa điểm chụp</label>
              <input type="text" name="location" value={v.location ?? ""}
                class="h-10 w-full rounded-lg border border-gray-300 px-3 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10" />
            </div>
            <div>
              <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Album / sự kiện</label>
              <input type="text" name="album" value={v.album ?? ""}
                class="h-10 w-full rounded-lg border border-gray-300 px-3 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10" />
            </div>
            <div>
              <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">Tags (CSV)</label>
              <input type="text" name="tags" value={tagsCsv} placeholder="tết, đám-cưới, 2024"
                class="h-10 w-full rounded-lg border border-gray-300 px-3 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10" />
              <p class="mt-1 text-theme-xs text-gray-500">Tag cách nhau bằng dấu phẩy. Dùng để lọc ở thư viện.</p>
            </div>
            <label class="flex items-center gap-2 text-theme-sm text-gray-700">
              <input type="checkbox" name="featured" value="1" checked={v.featured}
                class="h-4 w-4 rounded border-gray-300 text-brand-500 focus:ring-brand-500/20" />
              Ảnh nổi bật (xếp đầu)
            </label>
          </fieldset>

          <fieldset class="rounded-2xl border border-gray-200 bg-white p-5 shadow-theme-xs">
            <legend class="px-2 text-theme-sm font-semibold text-gray-800">Thành viên trong ảnh</legend>
            <MemberPicker name="members" label="" refs={refs} selected={selectedMembers}
              hint="Tích chọn ai có mặt trong ảnh." />
            {linkedMembers.length > 0 && (
              <p class="mt-3 text-theme-xs text-gray-500">
                Hiện liên kết với: {linkedMembers.map((m) => m.name).join(", ")}
              </p>
            )}
          </fieldset>

          <button type="submit" class="block w-full rounded-lg bg-brand-500 px-5 py-2.5 text-theme-sm font-medium text-white shadow-theme-xs hover:bg-brand-600">
            Lưu thay đổi
          </button>
        </form>

        <form method="post" onsubmit="return confirm('Xóa ảnh này? Tất cả liên kết với thành viên / sự kiện cũng bị gỡ.');"
          class="rounded-2xl border border-error-100 bg-error-50 p-4">
          <input type="hidden" name="action" value="delete" />
          <button type="submit" class="block w-full rounded-lg border border-error-200 bg-white px-4 py-2 text-theme-sm font-medium text-error-700 hover:bg-error-50">
            Xóa ảnh
          </button>
          <p class="mt-2 text-theme-xs text-error-600">
            Xóa cả file gốc + các phiên bản (thumb/medium) khỏi Storage.
          </p>
        </form>
      </aside>
    </div>
  </div>
</AdminLayout>
