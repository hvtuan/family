---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { listPhotos, deletePhoto } from "@/lib/photos-admin";

export const prerender = false;

let banner: { kind: "ok" | "err"; text: string } | null = null;

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = String(form.get("action") ?? "");

  if (action === "delete") {
    const id = String(form.get("id") ?? "");
    try { await deletePhoto(id); banner = { kind: "ok", text: `Đã xóa "${id}".` }; }
    catch (e) { banner = { kind: "err", text: e instanceof Error ? e.message : "Xóa thất bại." }; }
  } else if (action === "bulk-delete") {
    const ids = form.getAll("ids").map((v) => String(v)).filter(Boolean);
    let ok = 0, fail = 0;
    for (const id of ids) {
      try { await deletePhoto(id); ok++; } catch { fail++; }
    }
    banner = fail === 0
      ? { kind: "ok", text: `Đã xóa ${ok} ảnh.` }
      : { kind: "err", text: `Đã xóa ${ok} ảnh, ${fail} lỗi.` };
  }
}

const url = new URL(Astro.request.url);
const q = (url.searchParams.get("q") ?? "").trim().toLowerCase();
const year = url.searchParams.get("year") ?? "";
const tag = url.searchParams.get("tag") ?? "";
const featuredOnly = url.searchParams.get("featured") === "1";
const kindFilter = url.searchParams.get("kind") ?? ""; // '' | 'image' | 'video'

const all = await listPhotos();

// Compute filter facets BEFORE filtering, so the dropdowns show every option
// the dataset actually contains, not just options inside the current filter.
const yearFacets = Array.from(
  new Set(all.map((p) => p.year).filter((y): y is number => typeof y === "number")),
).sort((a, b) => b - a);

const tagFacets = Array.from(
  new Set(all.flatMap((p) => (Array.isArray(p.tags) ? p.tags : []))),
).sort();

const rows = all.filter((p) => {
  if (q) {
    const hay = [
      p.id, p.caption, p.caption_en, p.alt_vi ?? "", p.alt_en ?? "",
      p.location ?? "", p.album ?? "",
      ...(Array.isArray(p.tags) ? p.tags : []),
    ].join(" ").toLowerCase();
    if (!hay.includes(q)) return false;
  }
  if (year && String(p.year ?? "") !== year) return false;
  if (tag && !(Array.isArray(p.tags) && p.tags.includes(tag))) return false;
  if (featuredOnly && !p.featured) return false;
  if (kindFilter && (p.kind ?? "image") !== kindFilter) return false;
  return true;
});

function thumbFor(p: typeof rows[number]): string {
  // For video rows the thumb is the poster (src_thumb / src_medium).
  // The original src is the video itself which can't render as an <img>.
  if (p.kind === "video") return p.src_thumb || p.src_medium || "";
  return p.src_thumb || p.src_medium || p.src;
}

function durationLabel(seconds?: number | null): string {
  if (seconds == null || !Number.isFinite(seconds) || seconds <= 0) return "";
  const m = Math.floor(seconds / 60);
  const s = seconds % 60;
  return `${m}:${String(s).padStart(2, "0")}`;
}
---

<AdminLayout title="Thư viện ảnh" crumbs={[{ label: "Thư viện ảnh" }]}>
  <div class="space-y-6">
    {banner && (
      <div class:list={[
        "rounded-lg border px-4 py-3 text-theme-sm",
        banner.kind === "ok"
          ? "border-success-100 bg-success-50 text-success-700"
          : "border-error-100 bg-error-50 text-error-700",
      ]}>{banner.text}</div>
    )}

    <section class="rounded-2xl border border-gray-200 bg-white shadow-theme-xs">
      <header class="flex flex-col gap-4 border-b border-gray-100 px-5 py-4 lg:flex-row lg:items-center lg:justify-between">
        <div>
          <h2 class="text-theme-sm font-semibold text-gray-800">
            Ảnh ({rows.length}{rows.length !== all.length ? ` / ${all.length}` : ""})
          </h2>
          <p class="text-theme-xs text-gray-500 mt-0.5">
            Toàn bộ ảnh dùng chung cho thành viên, niên đại, truyền thống.
          </p>
        </div>
        <div class="flex items-center gap-2">
          <button type="button" data-upload-trigger
            class="rounded-lg bg-brand-500 px-4 py-2 text-theme-sm font-medium text-white shadow-theme-xs hover:bg-brand-600">
            + Tải ảnh lên
          </button>
          <input type="file" data-upload-input multiple
            accept="image/*,video/*,.heic,.heif,.mp4,.webm,.mov" class="hidden" />
        </div>
      </header>

      <form method="get" class="flex flex-col gap-3 border-b border-gray-100 bg-gray-50 px-5 py-4 lg:flex-row lg:items-center">
        <input type="search" name="q" value={q}
          placeholder="Tìm theo tên, caption, alt, tag, địa điểm…"
          class="h-10 w-full lg:w-72 rounded-lg border border-gray-200 bg-white px-3 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10" />

        <select name="kind" class="h-10 rounded-lg border border-gray-200 bg-white px-3 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10">
          <option value="">Mọi loại</option>
          <option value="image" selected={kindFilter === "image"}>Ảnh</option>
          <option value="video" selected={kindFilter === "video"}>Video</option>
        </select>

        <select name="year" class="h-10 rounded-lg border border-gray-200 bg-white px-3 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10">
          <option value="">Mọi năm</option>
          {yearFacets.map((y) => (
            <option value={String(y)} selected={String(y) === year}>{y}</option>
          ))}
        </select>

        <select name="tag" class="h-10 rounded-lg border border-gray-200 bg-white px-3 text-theme-sm shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10">
          <option value="">Mọi tag</option>
          {tagFacets.map((t) => (
            <option value={t} selected={t === tag}>{t}</option>
          ))}
        </select>

        <label class="flex items-center gap-2 text-theme-sm text-gray-700">
          <input type="checkbox" name="featured" value="1" checked={featuredOnly}
            class="h-4 w-4 rounded border-gray-300 text-brand-500 focus:ring-brand-500" />
          Nổi bật
        </label>

        <div class="flex items-center gap-2 lg:ml-auto">
          <button type="submit" class="h-10 rounded-lg bg-gray-900 px-4 text-theme-sm font-medium text-white hover:bg-gray-800">Lọc</button>
          {(q || year || tag || featuredOnly || kindFilter) && (
            <a href="/admin/media" class="h-10 inline-flex items-center rounded-lg border border-gray-200 bg-white px-4 text-theme-sm font-medium text-gray-700 hover:bg-gray-50">Xóa lọc</a>
          )}
        </div>
      </form>

      {rows.length === 0 ? (
        <div class="px-5 py-16 text-center">
          <p class="text-theme-sm text-gray-500">
            {all.length === 0 ? "Chưa có ảnh nào." : "Không có ảnh nào khớp bộ lọc."}
          </p>
        </div>
      ) : (
        <form method="post" id="bulk-form">
          <input type="hidden" name="action" value="bulk-delete" />
          <div class="grid grid-cols-2 gap-4 p-5 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5">
            {rows.map((p) => (
              <label class="group block cursor-pointer rounded-lg border border-gray-200 bg-white overflow-hidden transition hover:shadow-theme-md has-[:checked]:border-brand-400 has-[:checked]:ring-2 has-[:checked]:ring-brand-500/20">
                <div class="aspect-square bg-gray-100 relative">
                  {thumbFor(p) ? (
                    <img src={thumbFor(p)} alt={p.alt_vi ?? p.caption} loading="lazy"
                      class="absolute inset-0 h-full w-full object-cover" />
                  ) : (
                    <div class="absolute inset-0 flex items-center justify-center text-3xl opacity-60">
                      {p.kind === "video" ? "🎬" : "🖼️"}
                    </div>
                  )}
                  {p.kind === "video" && (
                    <>
                      <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
                        <span class="flex h-12 w-12 items-center justify-center rounded-full bg-gray-900/60 text-white">
                          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                        </span>
                      </div>
                      {durationLabel(p.duration_seconds) && (
                        <span class="absolute bottom-2 right-2 rounded bg-gray-900/70 px-1.5 py-0.5 text-theme-xs font-medium text-white tabular-nums">
                          {durationLabel(p.duration_seconds)}
                        </span>
                      )}
                    </>
                  )}
                  <div class="absolute top-2 left-2 flex items-center gap-2">
                    <input type="checkbox" name="ids" value={p.id}
                      data-bulk-checkbox
                      class="h-5 w-5 rounded border-white bg-white/90 text-brand-500 shadow-sm focus:ring-brand-500"
                      onclick="event.stopPropagation();" />
                  </div>
                  {p.featured && (
                    <span class="absolute top-2 right-2 rounded bg-warning-50 px-1.5 py-0.5 text-theme-xs font-medium text-warning-600 border border-warning-100" title="Nổi bật">★</span>
                  )}
                  {p.kind !== "video" && !p.src_thumb && (
                    <span class="absolute bottom-2 left-2 rounded bg-gray-900/60 px-1.5 py-0.5 text-theme-xs font-medium text-white" title="Ảnh chưa có thumbnail (legacy)">legacy</span>
                  )}
                </div>
                <a href={`/admin/media/${p.id}`} class="block p-2.5">
                  <div class="text-theme-sm font-medium text-gray-800 line-clamp-1">
                    {p.alt_vi ?? p.caption}
                  </div>
                  <div class="text-theme-xs text-gray-500 line-clamp-1">
                    {p.year ?? "—"}{p.location ? ` · ${p.location}` : ""}
                  </div>
                  {Array.isArray(p.tags) && p.tags.length > 0 && (
                    <div class="mt-1.5 flex flex-wrap gap-1">
                      {p.tags.slice(0, 3).map((t) => (
                        <span class="rounded bg-gray-100 px-1.5 py-0.5 text-theme-xs text-gray-600">{t}</span>
                      ))}
                    </div>
                  )}
                </a>
              </label>
            ))}
          </div>
        </form>
      )}
    </section>
  </div>

  <!-- Drag-and-drop overlay (shown during dragenter on document) -->
  <div data-drop-overlay
    class="fixed inset-0 z-[60] hidden items-center justify-center bg-brand-500/20 backdrop-blur-sm">
    <div class="rounded-2xl border-4 border-dashed border-brand-500 bg-white px-12 py-10 text-center shadow-theme-lg pointer-events-none">
      <div class="mb-2 text-3xl">📥</div>
      <div class="text-theme-md font-semibold text-gray-800">Thả ảnh hoặc video để tải lên</div>
      <div class="mt-1 text-theme-xs text-gray-500">Ảnh: JPG/PNG/WebP/GIF/HEIC ≤ 25 MB · Video: MP4/WebM/MOV ≤ 200 MB</div>
    </div>
  </div>

  <!-- Upload progress panel (shown while uploads are in flight or after) -->
  <div data-upload-panel
    class="fixed inset-x-0 bottom-0 z-[55] hidden border-t border-gray-200 bg-white shadow-[0_-4px_16px_rgba(0,0,0,.06)]">
    <div class="mx-auto max-h-[40vh] max-w-screen-2xl overflow-y-auto px-6 py-4">
      <header class="mb-3 flex items-center justify-between">
        <h3 class="text-theme-sm font-semibold text-gray-800">
          Đang tải lên (<span data-upload-summary>0/0</span>)
        </h3>
        <button type="button" data-upload-close class="text-theme-xs text-gray-500 hover:text-gray-700">Đóng</button>
      </header>
      <ul data-upload-list class="space-y-2"></ul>
    </div>
  </div>

  <!-- Sticky bulk action bar (hidden until any checkbox is ticked) -->
  <div data-bulk-bar
    class="fixed inset-x-0 bottom-0 z-40 hidden border-t border-gray-200 bg-white shadow-[0_-2px_10px_rgba(0,0,0,.04)]">
    <div class="mx-auto flex max-w-screen-2xl items-center justify-between px-6 py-3">
      <div class="text-theme-sm text-gray-700">
        Đã chọn <span data-bulk-count class="font-semibold">0</span> ảnh
      </div>
      <div class="flex items-center gap-2">
        <button type="button" data-bulk-clear class="rounded-lg border border-gray-200 bg-white px-4 py-2 text-theme-sm font-medium text-gray-700 hover:bg-gray-50">Bỏ chọn</button>
        <button type="button" data-bulk-delete class="rounded-lg border border-error-100 bg-error-50 px-4 py-2 text-theme-sm font-medium text-error-700 hover:bg-error-100">Xóa đã chọn</button>
      </div>
    </div>
  </div>

  <script is:inline>
    (() => {
      const form = document.getElementById("bulk-form");
      if (!form) return;
      const bar = document.querySelector("[data-bulk-bar]");
      const count = document.querySelector("[data-bulk-count]");
      const boxes = () => Array.from(form.querySelectorAll("[data-bulk-checkbox]"));

      function refresh() {
        const checked = boxes().filter((b) => b.checked);
        count.textContent = String(checked.length);
        bar.classList.toggle("hidden", checked.length === 0);
      }

      form.addEventListener("change", (e) => {
        if (e.target && e.target.matches("[data-bulk-checkbox]")) refresh();
      });

      document.querySelector("[data-bulk-clear]")?.addEventListener("click", () => {
        boxes().forEach((b) => (b.checked = false));
        refresh();
      });

      document.querySelector("[data-bulk-delete]")?.addEventListener("click", () => {
        const checked = boxes().filter((b) => b.checked);
        if (checked.length === 0) return;
        if (!confirm(`Xóa ${checked.length} ảnh? Hành động này không hoàn tác được.`)) return;
        form.submit();
      });

      refresh();
    })();
  </script>

  <script is:inline>
    (() => {
      const trigger = document.querySelector("[data-upload-trigger]");
      const input = document.querySelector("[data-upload-input]");
      const overlay = document.querySelector("[data-drop-overlay]");
      const panel = document.querySelector("[data-upload-panel]");
      const list = document.querySelector("[data-upload-list]");
      const summary = document.querySelector("[data-upload-summary]");
      const closeBtn = document.querySelector("[data-upload-close]");
      if (!trigger || !input || !overlay || !panel || !list || !summary) return;

      let dragDepth = 0;

      function showOverlay() { overlay.classList.remove("hidden"); overlay.classList.add("flex"); }
      function hideOverlay() { overlay.classList.add("hidden"); overlay.classList.remove("flex"); }
      function showPanel() { panel.classList.remove("hidden"); }

      // Document-wide drag-drop. We count enter/leave events because the
      // browser fires a leave when crossing into a child element.
      ["dragenter", "dragover"].forEach((evt) => {
        document.addEventListener(evt, (e) => {
          if (!e.dataTransfer || !Array.from(e.dataTransfer.types).includes("Files")) return;
          e.preventDefault();
          if (evt === "dragenter") dragDepth++;
          if (dragDepth > 0) showOverlay();
        });
      });
      document.addEventListener("dragleave", (e) => {
        e.preventDefault();
        dragDepth = Math.max(0, dragDepth - 1);
        if (dragDepth === 0) hideOverlay();
      });
      document.addEventListener("drop", (e) => {
        if (!e.dataTransfer) return;
        e.preventDefault();
        dragDepth = 0;
        hideOverlay();
        const files = Array.from(e.dataTransfer.files).filter((f) =>
          f.type.startsWith("image/") || f.type.startsWith("video/") ||
          /\.(heic|heif|mp4|webm|mov)$/i.test(f.name)
        );
        if (files.length > 0) startUploads(files);
      });

      trigger.addEventListener("click", () => input.click());
      input.addEventListener("change", () => {
        const files = Array.from(input.files || []);
        input.value = ""; // allow re-picking the same file
        if (files.length > 0) startUploads(files);
      });

      closeBtn?.addEventListener("click", () => {
        panel.classList.add("hidden");
        list.innerHTML = "";
      });

      function rowFor(file) {
        const li = document.createElement("li");
        li.className = "flex items-center gap-3 rounded-lg border border-gray-200 bg-white p-3";
        li.innerHTML = `
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded bg-gray-100 text-theme-sm" data-thumb>📷</div>
          <div class="min-w-0 flex-1">
            <div class="truncate text-theme-sm font-medium text-gray-800" data-name>${file.name}</div>
            <div class="text-theme-xs text-gray-500" data-status>Chuẩn bị…</div>
            <div class="mt-1 h-1.5 w-full overflow-hidden rounded bg-gray-100">
              <div class="h-full bg-brand-500 transition-[width] duration-150" style="width:0%" data-bar></div>
            </div>
          </div>
          <a class="hidden text-theme-xs font-medium text-brand-600 hover:underline" data-edit>Sửa</a>
        `;
        return li;
      }

      function setRow(li, { status, percent, error, editUrl, src }) {
        const statusEl = li.querySelector("[data-status]");
        const bar = li.querySelector("[data-bar]");
        const edit = li.querySelector("[data-edit]");
        const thumb = li.querySelector("[data-thumb]");
        if (typeof percent === "number") bar.style.width = percent + "%";
        if (status) statusEl.textContent = status;
        if (error) {
          statusEl.classList.add("text-error-600");
          bar.classList.add("bg-error-500");
        } else {
          statusEl.classList.remove("text-error-600");
        }
        if (editUrl) {
          edit.href = editUrl;
          edit.classList.remove("hidden");
        }
        if (src) {
          thumb.innerHTML = `<img src="${src}" alt="" class="h-10 w-10 rounded object-cover" />`;
        }
      }

      // Detect video by mime + extension fallback (Safari iCloud .mov
      // sometimes reports empty mime).
      function isVideo(file) {
        if (file.type && file.type.startsWith("video/")) return true;
        return /\.(mp4|webm|mov)$/i.test(file.name);
      }

      // Extract a poster frame from a video file via a hidden <video>
      // element + canvas. Resolves with { posterFile, durationSeconds }.
      // Failures resolve with nulls so the upload still succeeds — the
      // detail page can render without a poster, just less pretty.
      async function extractPoster(file) {
        return new Promise((resolve) => {
          const url = URL.createObjectURL(file);
          const video = document.createElement("video");
          video.src = url;
          video.muted = true;
          video.playsInline = true;
          video.preload = "metadata";

          const cleanup = () => URL.revokeObjectURL(url);
          let captured = false;

          function capture() {
            if (captured) return;
            captured = true;
            try {
              const w = video.videoWidth || 1280;
              const h = video.videoHeight || 720;
              const canvas = document.createElement("canvas");
              canvas.width = w;
              canvas.height = h;
              canvas.getContext("2d").drawImage(video, 0, 0, w, h);
              canvas.toBlob((blob) => {
                cleanup();
                if (!blob) {
                  resolve({ posterFile: null, durationSeconds: video.duration || null });
                  return;
                }
                const posterFile = new File([blob], "poster.jpg", { type: "image/jpeg" });
                resolve({ posterFile, durationSeconds: Math.round(video.duration) || null });
              }, "image/jpeg", 0.9);
            } catch (err) {
              cleanup();
              resolve({ posterFile: null, durationSeconds: video.duration || null });
            }
          }

          video.addEventListener("loadedmetadata", () => {
            // Seek to a moment past 0 so iOS doesn't return a black frame.
            const target = Math.min(1, (video.duration || 1) * 0.1);
            try { video.currentTime = target; } catch { capture(); }
          });
          video.addEventListener("seeked", capture);
          video.addEventListener("error", () => { cleanup(); resolve({ posterFile: null, durationSeconds: null }); });
          // Hard timeout so a stuck video doesn't block the queue.
          setTimeout(() => { if (!captured) { cleanup(); resolve({ posterFile: null, durationSeconds: null }); } }, 8000);
        });
      }

      function uploadOne(file, li) {
        return new Promise(async (resolve) => {
          const fd = new FormData();
          fd.append("file", file);

          let extra = null;
          if (isVideo(file)) {
            setRow(li, { status: "Trích frame video…", percent: 5 });
            extra = await extractPoster(file);
            if (extra?.posterFile) fd.append("poster", extra.posterFile);
            if (extra?.durationSeconds) fd.append("duration_seconds", String(extra.durationSeconds));
          }

          const xhr = new XMLHttpRequest();
          xhr.open("POST", "/admin/media/upload");
          xhr.upload.addEventListener("progress", (e) => {
            if (!e.lengthComputable) return;
            const pct = Math.round((e.loaded / e.total) * 90);
            setRow(li, { status: `Đang tải… ${pct}%`, percent: pct });
          });
          xhr.addEventListener("load", () => {
            try {
              const body = JSON.parse(xhr.responseText || "{}");
              if (xhr.status >= 200 && xhr.status < 300 && body.ok) {
                const status = body.kind === "video" ? "Xong (video)" : "Xong";
                setRow(li, { status, percent: 100, editUrl: body.editUrl, src: body.src_thumb || body.src_medium });
              } else {
                setRow(li, { status: body.error || `Lỗi (${xhr.status})`, error: true, percent: 100 });
              }
            } catch {
              setRow(li, { status: `Phản hồi không hợp lệ (${xhr.status})`, error: true, percent: 100 });
            }
            resolve();
          });
          xhr.addEventListener("error", () => {
            setRow(li, { status: "Lỗi mạng", error: true, percent: 100 });
            resolve();
          });
          setRow(li, { status: "Đang tải… 0%", percent: 0 });
          xhr.send(fd);
        });
      }

      async function startUploads(files) {
        showPanel();
        let done = 0;
        const total = files.length;
        summary.textContent = `${done}/${total}`;

        // Build all rows up-front so user sees the queue.
        const rows = files.map((f) => {
          const li = rowFor(f);
          list.prepend(li);
          return { file: f, li };
        });

        // Limit concurrency to 3 so a 50-photo dump doesn't slam the
        // server's sharp pipeline. Sequential per-file inside each lane.
        const lanes = 3;
        let cursor = 0;
        async function lane() {
          while (cursor < rows.length) {
            const i = cursor++;
            await uploadOne(rows[i].file, rows[i].li);
            done++;
            summary.textContent = `${done}/${total}`;
          }
        }
        await Promise.all(Array.from({ length: lanes }, lane));

        // Refresh the grid in place once all uploads finish so the new
        // photos appear without reloading.
        if (done > 0 && done === total) {
          setTimeout(() => location.reload(), 800);
        }
      }
    })();
  </script>
</AdminLayout>
