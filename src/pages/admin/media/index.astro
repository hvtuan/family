---
/**
 * /admin/media — pro media library hub.
 *
 * Astro page is the SSR shell:
 *   - Fetches every photos row server-side.
 *   - Handles POST bulk-delete + single-delete (idempotent admin path).
 *   - Hands the data + last-action banner to the React island
 *     <MediaLibrary> which renders the masonry grid + lightbox + chip
 *     filters + sticky year sections + selection bar via shadcn/ui.
 *   - Mounts <MediaUploaderModal> (Uppy v5) for the upload flow.
 *
 * Banner state (after a server-side bulk delete) is forwarded to the
 * island and surfaced as a sonner toast on first hydration.
 */
import AdminLayout from "@/layouts/AdminLayout.astro";
import MediaUploaderModal from "@/components/admin/MediaUploaderModal.tsx";
import MediaLibrary, {
  type MediaItem, type MemberRef, type LocationRef,
} from "@/components/admin/MediaLibrary.tsx";
import { listPhotos, deletePhoto } from "@/lib/photos-admin";
import { supabaseAdmin } from "@/lib/supabase/admin";

export const prerender = false;

let banner: { kind: "ok" | "err"; text: string } | null = null;

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = String(form.get("action") ?? "");

  if (action === "delete") {
    const id = String(form.get("id") ?? "");
    try { await deletePhoto(id); banner = { kind: "ok", text: `Đã xóa "${id}".` }; }
    catch (e) { banner = { kind: "err", text: e instanceof Error ? e.message : "Xóa thất bại." }; }
  } else if (action === "bulk-delete") {
    const ids = form.getAll("ids").map((v) => String(v)).filter(Boolean);
    let ok = 0, fail = 0;
    for (const id of ids) {
      try { await deletePhoto(id); ok++; } catch { fail++; }
    }
    banner = fail === 0
      ? { kind: "ok", text: `Đã xóa ${ok} ảnh.` }
      : { kind: "err", text: `Đã xóa ${ok} ảnh, ${fail} lỗi.` };
  } else if (action === "bulk-featured") {
    const ids = form.getAll("ids").map((v) => String(v)).filter(Boolean);
    const value = form.get("value") === "1";
    let ok = 0, fail = 0;
    for (const id of ids) {
      try {
        const { error } = await supabaseAdmin
          .from("photos").update({ featured: value }).eq("id", id);
        if (error) throw new Error(error.message);
        ok++;
      } catch { fail++; }
    }
    const verb = value ? "Đã đánh dấu" : "Đã bỏ";
    banner = fail === 0
      ? { kind: "ok", text: `${verb} nổi bật cho ${ok} ảnh.` }
      : { kind: "err", text: `${verb} cho ${ok} ảnh, ${fail} lỗi.` };
  } else if (action === "bulk-tag") {
    const ids = form.getAll("ids").map((v) => String(v)).filter(Boolean);
    const rawTags = String(form.get("tags") ?? "").trim();
    const newTags = rawTags
      .split(",").map((t) => t.trim().toLowerCase()).filter(Boolean);
    const mode = String(form.get("mode") ?? "add"); // 'add' | 'remove'

    if (ids.length === 0 || newTags.length === 0) {
      banner = { kind: "err", text: "Cần ít nhất 1 ảnh + 1 tag." };
    } else {
      let ok = 0, fail = 0;
      for (const id of ids) {
        try {
          const { data: row } = await supabaseAdmin
            .from("photos").select("tags").eq("id", id).maybeSingle();
          const current: string[] = Array.isArray(row?.tags) ? row.tags : [];
          let next: string[];
          if (mode === "remove") {
            next = current.filter((t) => !newTags.includes(t));
          } else {
            next = Array.from(new Set([...current, ...newTags]));
          }
          const { error } = await supabaseAdmin
            .from("photos").update({ tags: next }).eq("id", id);
          if (error) throw new Error(error.message);
          ok++;
        } catch {
          fail++;
        }
      }
      const verb = mode === "remove" ? "Đã gỡ" : "Đã thêm";
      banner = fail === 0
        ? { kind: "ok", text: `${verb} tag "${newTags.join(", ")}" cho ${ok} ảnh.` }
        : { kind: "err", text: `${verb} cho ${ok} ảnh, ${fail} lỗi.` };
    }
  }
}

const all = await listPhotos();

// Fetch members + photo_members M2M + locations for discovery tabs.
const [{ data: memberRows }, { data: linkRows }, { data: locationRows }] = await Promise.all([
  supabaseAdmin
    .from("members")
    .select("id, name, gen, photo")
    .order("gen", { ascending: true })
    .order("birth_order", { ascending: true, nullsFirst: false }),
  supabaseAdmin
    .from("photo_members")
    .select("photo_id, member_id"),
  supabaseAdmin
    .from("locations")
    .select("id, name, name_en, province, lat, lng, is_hometown"),
]);

const members: MemberRef[] = (memberRows ?? []).map((m) => ({
  id: m.id as string,
  name: m.name as string,
  gen: m.gen as number,
  photo: (m.photo as string | null) ?? null,
}));

// Build a Map<photoId, memberId[]> for O(1) lookup in the island.
const photoMembers: Record<string, string[]> = {};
for (const r of linkRows ?? []) {
  const pid = (r as { photo_id: string }).photo_id;
  const mid = (r as { member_id: string }).member_id;
  if (!photoMembers[pid]) photoMembers[pid] = [];
  photoMembers[pid].push(mid);
}

const locations: LocationRef[] = (locationRows ?? []).map((l) => ({
  id: l.id as string,
  name: l.name as string,
  name_en: (l.name_en as string | null) ?? null,
  province: (l.province as string | null) ?? null,
  lat: l.lat as number | null,
  lng: l.lng as number | null,
  is_hometown: Boolean(l.is_hometown),
}));

const googleMapsApiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY ?? "";

// Shape rows for the React island — strip nullables to the props type.
const items: MediaItem[] = all.map((p) => ({
  id: p.id,
  kind: (p.kind ?? "image") as "image" | "video",
  src: p.src,
  src_thumb: p.src_thumb ?? null,
  src_medium: p.src_medium ?? null,
  alt_vi: p.alt_vi ?? null,
  caption: p.caption,
  caption_en: p.caption_en,
  year: p.year ?? null,
  location: p.location ?? null,
  album: p.album ?? null,
  featured: p.featured,
  tags: Array.isArray(p.tags) ? p.tags : [],
  width: p.width ?? null,
  height: p.height ?? null,
  duration_seconds: p.duration_seconds ?? null,
}));
---

<AdminLayout title="Thư viện ảnh" crumbs={[{ label: "Thư viện ảnh" }]}>
  <div class="space-y-6">
    <header class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
      <div>
        <h1 class="text-xl font-semibold text-foreground">Thư viện ảnh & video</h1>
        <p class="mt-0.5 text-sm text-muted-foreground">
          Toàn bộ kỷ niệm — dùng chung cho thành viên, niên đại, truyền thống.
        </p>
      </div>
      <div class="flex flex-wrap items-center gap-2">
        <button type="button" data-uppy-trigger
          class="inline-flex h-10 items-center gap-2 rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground shadow-theme-xs hover:bg-brand-600 focus-visible:outline-hidden focus-visible:ring-3 focus-visible:ring-ring/40">
          + Tải ảnh / video
        </button>
        <a href="/admin/media/new"
          class="inline-flex h-10 items-center rounded-md border border-border bg-background px-4 text-sm font-medium text-foreground shadow-theme-xs hover:bg-accent">
          Tạo có form đầy đủ
        </a>
      </div>
    </header>

    <MediaLibrary
      client:load
      items={items}
      members={members}
      photoMembers={photoMembers}
      locations={locations}
      googleMapsApiKey={googleMapsApiKey}
      initialBanner={banner}
    />
  </div>

  <MediaUploaderModal client:load />
</AdminLayout>
