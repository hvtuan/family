---
import AdminLayout from "@/layouts/AdminLayout.astro";
import MemberForm from "@/components/admin/MemberForm.astro";
import MemberPhotos from "@/components/admin/MemberPhotos.astro";
import {
  getMember,
  listMemberRefs,
  upsertMember,
  syncMemberChildren,
} from "@/lib/members-admin";
import { parseMemberForm } from "@/lib/members-form";
import {
  listPhotosForMember,
  listPhotosNotLinkedTo,
  uploadAttachment,
} from "@/lib/photos-admin";
import type { MemberInput, MemberRow } from "@/lib/members-admin";

export const prerender = false;

const me = Astro.locals.user!;
const id = Astro.params.id!;
let fieldError: string | null = null;
let fieldOk: string | null = null;

let existing = await getMember(id);
if (!existing) {
  return new Response("Không tìm thấy thành viên", { status: 404 });
}

const okParam = Astro.url.searchParams.get("ok");
const errParam = Astro.url.searchParams.get("err");
if (okParam) {
  if (okParam === "created") fieldOk = "Đã tạo thành viên.";
  else if (okParam === "photo_uploaded") fieldOk = "Đã tải ảnh lên + liên kết với thành viên.";
  else if (okParam.startsWith("photo_linked_"))
    fieldOk = `Đã liên kết ${okParam.split("_")[2]} ảnh.`;
  else if (okParam === "photo_unlinked") fieldOk = "Đã bỏ liên kết ảnh.";
  else fieldOk = okParam;
}
if (errParam) fieldError = errParam;

let values: Partial<MemberRow> = existing;

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const { input, errors } = parseMemberForm(form);
  // Don't allow id change on edit — keep the original id even if the form
  // somehow submitted a different one.
  const sanitized: MemberInput = { ...input, id };
  values = { ...existing, ...sanitized };

  const photoFile = form.get("photo_file");
  if (errors.length === 0 && photoFile instanceof File && photoFile.size > 0) {
    try {
      sanitized.photo = await uploadAttachment(photoFile, "avatars", id);
      values = { ...existing, ...sanitized };
    } catch (e) {
      errors.push(e instanceof Error ? e.message : "Upload ảnh thất bại.");
    }
  }

  if (errors.length > 0) {
    fieldError = errors.join(" ");
  } else {
    try {
      await upsertMember(sanitized, "update", me.id);
      await syncMemberChildren();
      existing = await getMember(id);
      values = existing ?? values;
      fieldOk = "Đã lưu thay đổi.";
    } catch (e) {
      fieldError = e instanceof Error ? e.message : "Lưu thất bại.";
    }
  }
}

const [refs, linkedPhotos, otherPhotos] = await Promise.all([
  listMemberRefs(),
  listPhotosForMember(id),
  listPhotosNotLinkedTo(id),
]);
---

<AdminLayout
  title={existing?.name ?? id}
  crumbs={[
    { label: "Thành viên", href: "/admin/members" },
    { label: existing?.name ?? id },
  ]}
>
  <div class="space-y-6">
    <MemberForm
      mode="edit"
      values={values}
      refs={refs}
      fieldError={fieldError}
      fieldOk={fieldOk}
    />
    <MemberPhotos memberId={id} linked={linkedPhotos} others={otherPhotos} />
  </div>
</AdminLayout>
