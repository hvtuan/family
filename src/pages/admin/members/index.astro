---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { listMembers, deleteMember, syncMemberChildren } from "@/lib/members-admin";

export const prerender = false;

// Audit logging is handled by the family.log_audit trigger on every
// content table; we don't write audit rows from page handlers. Trigger
// limitation: actor_id falls back to auth.uid(), which is null when
// supabaseAdmin (service-role) is the writer. Capturing the real actor
// for service-role writes requires either a session GUC + transaction or
// switching to the user-authed client; punted to a later cleanup.

let banner: { kind: "ok" | "err"; text: string } | null = null;

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = String(form.get("action") ?? "");
  const id = String(form.get("id") ?? "");
  if (action === "delete" && id) {
    try {
      await deleteMember(id);
      await syncMemberChildren();
      banner = { kind: "ok", text: `Đã xóa "${id}".` };
    } catch (e) {
      banner = {
        kind: "err",
        text: e instanceof Error ? e.message : "Xóa thất bại.",
      };
    }
  }
}

const rows = await listMembers();

const branchLabel: Record<"noi" | "ngoai" | "both", string> = {
  noi: "Nội",
  ngoai: "Ngoại",
  both: "Cả",
};
---

<AdminLayout title="Thành viên" crumbs={[{ label: "Thành viên" }]}>
  <div class="space-y-6">
    {banner && (
      <div
        class:list={[
          "rounded-lg border px-4 py-3 text-theme-sm",
          banner.kind === "ok"
            ? "border-success-100 bg-success-50 text-success-700"
            : "border-error-100 bg-error-50 text-error-700",
        ]}
      >
        {banner.text}
      </div>
    )}

    <section class="rounded-2xl border border-gray-200 bg-white shadow-theme-xs">
      <header class="flex items-center justify-between border-b border-gray-100 px-5 py-4">
        <div>
          <h2 class="text-theme-sm font-semibold text-gray-800">
            Danh sách thành viên ({rows.length})
          </h2>
          <p class="mt-1 text-theme-xs text-gray-500">
            Đời được sắp xếp tăng dần. Bấm <em>Sửa</em> để chỉnh hoặc <em>Tạo
            mới</em> để thêm thành viên.
          </p>
        </div>
        <a
          href="/admin/members/new"
          class="rounded-lg bg-brand-500 px-4 py-2 text-theme-sm font-medium text-white shadow-theme-xs hover:bg-brand-600"
        >
          + Tạo mới
        </a>
      </header>

      <div class="overflow-x-auto">
        <table class="w-full text-left text-theme-sm">
          <thead class="bg-gray-50 text-theme-xs uppercase text-gray-500">
            <tr>
              <th class="px-5 py-3 font-medium">Thành viên</th>
              <th class="px-5 py-3 font-medium">Đời</th>
              <th class="px-5 py-3 font-medium">Vai vế</th>
              <th class="px-5 py-3 font-medium">Nhánh</th>
              <th class="px-5 py-3 font-medium">Sinh – mất</th>
              <th class="px-5 py-3 font-medium">Trạng thái</th>
              <th class="px-5 py-3 font-medium text-right">Hành động</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {rows.length === 0 && (
              <tr>
                <td colspan="7" class="px-5 py-8 text-center text-gray-500">
                  Chưa có thành viên nào.
                </td>
              </tr>
            )}
            {rows.map((m) => (
              <tr class="hover:bg-gray-50">
                <td class="px-5 py-3">
                  <div class="flex items-center gap-3">
                    {m.photo ? (
                      <img
                        src={m.photo}
                        alt={m.name}
                        loading="lazy"
                        class="h-9 w-9 rounded-full object-cover bg-gray-100"
                      />
                    ) : (
                      <div class="flex h-9 w-9 items-center justify-center rounded-full bg-brand-50 text-theme-xs font-medium text-brand-600">
                        {m.name[0]}
                      </div>
                    )}
                    <div class="min-w-0">
                      <div class="font-medium text-gray-800">
                        {m.name}
                        {m.is_family_head && (
                          <span class="ml-2 rounded bg-warning-50 px-1.5 py-0.5 text-theme-xs font-medium text-warning-600">
                            tộc trưởng
                          </span>
                        )}
                      </div>
                      <div class="text-theme-xs text-gray-500 truncate">
                        {m.name_en || m.id}
                      </div>
                    </div>
                  </div>
                </td>
                <td class="px-5 py-3 text-gray-700">{m.gen}</td>
                <td class="px-5 py-3 text-gray-700">{m.role}</td>
                <td class="px-5 py-3 text-gray-700">{branchLabel[m.branch]}</td>
                <td class="px-5 py-3 text-theme-xs text-gray-500">
                  {m.born}{m.died ? ` – ${m.died}` : ""}
                </td>
                <td class="px-5 py-3">
                  <span
                    class:list={[
                      "inline-flex rounded-md border px-2 py-0.5 text-theme-xs font-medium",
                      m.status === "published"
                        ? "border-success-100 bg-success-50 text-success-700"
                        : "border-gray-200 bg-gray-50 text-gray-600",
                    ]}
                  >
                    {m.status === "published" ? "Đã xuất bản" : "Bản nháp"}
                  </span>
                </td>
                <td class="px-5 py-3 text-right">
                  <div class="flex justify-end gap-2">
                    <a
                      href={`/admin/members/${m.id}`}
                      class="rounded-md border border-gray-200 px-3 py-1 text-theme-xs font-medium text-gray-700 hover:bg-gray-50"
                    >
                      Sửa
                    </a>
                    <form
                      method="post"
                      class="inline"
                      onsubmit={`return confirm('Xóa ${m.name}? Quan hệ cha/mẹ ở các thành viên khác sẽ tự bỏ tham chiếu.');`}
                    >
                      <input type="hidden" name="action" value="delete" />
                      <input type="hidden" name="id" value={m.id} />
                      <button
                        type="submit"
                        class="rounded-md border border-error-100 px-3 py-1 text-theme-xs font-medium text-error-700 hover:bg-error-50"
                      >
                        Xóa
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  </div>
</AdminLayout>
