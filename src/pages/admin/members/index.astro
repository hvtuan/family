---
import AdminLayout from "@/layouts/AdminLayout.astro";
import MembersList, {
  type MemberCardRow,
} from "@/components/admin/MembersList.tsx";
import ToastBanner from "@/components/admin/ToastBanner.tsx";
import { listMembers, deleteMember, syncMemberChildren } from "@/lib/members-admin";

export const prerender = false;

let banner: { kind: "ok" | "err"; text: string } | null = null;

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = String(form.get("action") ?? "");
  const id = String(form.get("id") ?? "");
  if (action === "delete" && id) {
    try {
      await deleteMember(id);
      await syncMemberChildren();
      banner = { kind: "ok", text: `Đã xóa "${id}".` };
    } catch (e) {
      banner = {
        kind: "err",
        text: e instanceof Error ? e.message : "Xóa thất bại.",
      };
    }
  }
}

const rows = await listMembers();

const items: MemberCardRow[] = rows.map((m) => ({
  id: m.id,
  name: m.name,
  name_en: m.name_en ?? null,
  gen: m.gen,
  role: m.role,
  branch: m.branch,
  born: m.born,
  died: m.died ?? null,
  status: m.status,
  is_family_head: m.is_family_head,
  photo: m.photo ?? null,
}));
---

<AdminLayout title="Thành viên" crumbs={[{ label: "Thành viên" }]}>
  {banner && <ToastBanner client:load kind={banner.kind} text={banner.text} />}

  <div class="space-y-6">
    <header class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
      <div>
        <h1 class="text-xl font-semibold text-foreground">Thành viên gia tộc</h1>
        <p class="mt-0.5 text-sm text-muted-foreground">
          Sắp xếp theo đời, bấm thẻ để chỉnh hoặc thêm người mới.
        </p>
      </div>
      <a
        href="/admin/members/new"
        class="inline-flex h-10 items-center gap-2 rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground shadow-theme-xs hover:bg-brand-600 focus-visible:outline-hidden focus-visible:ring-3 focus-visible:ring-ring/40"
      >
        + Thêm thành viên
      </a>
    </header>

    <MembersList client:load items={items} />
  </div>
</AdminLayout>
