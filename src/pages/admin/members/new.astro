---
import AdminLayout from "@/layouts/AdminLayout.astro";
import MemberForm from "@/components/admin/MemberForm.astro";
import {
  listMemberRefs,
  upsertMember,
  syncMemberChildren,
} from "@/lib/members-admin";
import { parseMemberForm } from "@/lib/members-form";
import type { MemberInput } from "@/lib/members-admin";

export const prerender = false;

const me = Astro.locals.user!;

let fieldError: string | null = null;
let values: Partial<MemberInput> = {
  branch: "both",
  status: "published",
  gen: 1,
  is_family_head: false,
  contact_public: false,
  hobbies: [],
  tags: [],
};

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const { input, errors } = parseMemberForm(form);
  values = input;
  if (errors.length > 0) {
    fieldError = errors.join(" ");
  } else {
    try {
      await upsertMember(input, "create", me.id);
      await syncMemberChildren();
      return Astro.redirect(`/admin/members/${input.id}?ok=created`);
    } catch (e) {
      const msg = e instanceof Error ? e.message : "Lưu thất bại.";
      fieldError = msg.includes("duplicate") || msg.includes("23505")
        ? `ID "${input.id}" đã tồn tại — chọn ID khác.`
        : msg;
    }
  }
}

const refs = await listMemberRefs();
---

<AdminLayout
  title="Thành viên mới"
  crumbs={[
    { label: "Thành viên", href: "/admin/members" },
    { label: "Tạo mới" },
  ]}
>
  <MemberForm mode="create" values={values} refs={refs} fieldError={fieldError} />
</AdminLayout>
