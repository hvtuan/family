---
import AdminLayout from "@/layouts/AdminLayout.astro";
import DashboardHero from "@/components/admin/DashboardHero.tsx";
import { supabaseAdmin } from "@/lib/supabase/admin";

export const prerender = false;

const tables = [
  { id: "members", label: "Thành viên", href: "/admin/members", iconKey: "users" },
  { id: "timeline", label: "Niên đại", href: "/admin/timeline", iconKey: "calendar" },
  { id: "traditions", label: "Truyền thống", href: "/admin/traditions", iconKey: "scroll" },
  { id: "photos", label: "Thư viện", href: "/admin/media", iconKey: "image" },
  { id: "quotes", label: "Câu nói", href: "/admin/quotes", iconKey: "quote" },
  { id: "dates", label: "Ngày lễ", href: "/admin/dates", iconKey: "calendarDays" },
  { id: "locations", label: "Địa điểm", href: "/admin/locations", iconKey: "map" },
] as const;

// Counts per content table.
const counts = await Promise.all(
  tables.map(async (t) => {
    const { count } = await supabaseAdmin
      .from(t.id)
      .select("*", { count: "exact", head: true });
    return { ...t, count: count ?? 0 };
  }),
);

// Pending users (admin-only). Falls back to 0.
const { count: pendingCount } = await supabaseAdmin
  .from("app_users")
  .select("*", { count: "exact", head: true })
  .eq("status", "pending");

// Last 8 audit log entries — joined with app_users via actor_id when set.
const { data: auditRows } = await supabaseAdmin
  .from("audit_log")
  .select("id, action, entity_type, entity_id, actor_id, created_at")
  .order("created_at", { ascending: false })
  .limit(8);

// Last 6 photos by created_at (will become media gallery on dashboard).
const { data: recentMedia } = await supabaseAdmin
  .from("photos")
  .select("id, kind, src, src_thumb, alt_vi, caption, year, created_at")
  .order("created_at", { ascending: false })
  .limit(6);

const user = Astro.locals.user!;
const isAdmin = user.role === "admin";
---

<AdminLayout title="Tổng quan">
  <DashboardHero
    client:load
    userEmail={user.email}
    userRole={user.role}
    stats={counts.map((c) => ({
      key: c.id,
      label: c.label,
      href: c.href,
      count: c.count,
      iconKey: c.iconKey,
    }))}
    pendingUsers={isAdmin ? (pendingCount ?? 0) : null}
    recentAudit={(auditRows ?? []).map((r) => ({
      id: r.id as number,
      action: r.action as string,
      entity_type: r.entity_type as string,
      entity_id: (r.entity_id as string | null) ?? null,
      created_at: r.created_at as string,
    }))}
    recentMedia={(recentMedia ?? []).map((m) => ({
      id: m.id as string,
      kind: ((m.kind as string) ?? "image") as "image" | "video",
      src: m.src as string,
      src_thumb: (m.src_thumb as string | null) ?? null,
      alt_vi: (m.alt_vi as string | null) ?? null,
      caption: (m.caption as string) ?? "",
      year: (m.year as number | null) ?? null,
    }))}
  />
</AdminLayout>
