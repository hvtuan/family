---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { supabaseAdmin } from "@/lib/supabase/admin";

export const prerender = false;

const tables = [
  { id: "members", label: "Thành viên", href: "/admin/members" },
  { id: "timeline", label: "Niên đại", href: "/admin/timeline" },
  { id: "traditions", label: "Truyền thống", href: "/admin/traditions" },
  { id: "photos", label: "Ảnh", href: "/admin/photos" },
  { id: "quotes", label: "Câu nói", href: "/admin/quotes" },
  { id: "dates", label: "Ngày lễ", href: "/admin/dates" },
  { id: "locations", label: "Địa điểm", href: "/admin/locations" },
] as const;

const counts = await Promise.all(
  tables.map(async (t) => {
    const { count } = await supabaseAdmin
      .from(t.id)
      .select("*", { count: "exact", head: true });
    return { ...t, count: count ?? 0 };
  }),
);

const { count: pendingCount } = await supabaseAdmin
  .from("app_users")
  .select("*", { count: "exact", head: true })
  .eq("status", "pending");

const isAdmin = Astro.locals.user?.role === "admin";
---

<AdminLayout title="Tổng quan">
  <div class="space-y-6">
    <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:gap-6 xl:grid-cols-4">
      {counts.map((t) => (
        <a
          href={t.href}
          class="rounded-2xl border border-gray-200 bg-white p-5 shadow-theme-xs transition-shadow hover:shadow-theme-sm"
        >
          <div class="mt-2 flex items-end justify-between">
            <div>
              <span class="text-theme-sm text-gray-500">{t.label}</span>
              <h4 class="mt-1 font-bold text-gray-800 text-title-sm">{t.count}</h4>
            </div>
            <span class="rounded-md bg-brand-50 px-2 py-1 text-theme-xs font-medium text-brand-600">
              Tổng
            </span>
          </div>
        </a>
      ))}
    </div>

    {isAdmin && (
      <div class="grid grid-cols-1 gap-4 lg:grid-cols-2">
        <a
          href="/admin/users"
          class="rounded-2xl border border-warning-100 bg-warning-50 p-5 transition-shadow hover:shadow-theme-sm"
        >
          <div class="flex items-end justify-between">
            <div>
              <span class="text-theme-sm text-warning-600">Người dùng chờ duyệt</span>
              <h4 class="mt-1 font-bold text-gray-800 text-title-sm">{pendingCount ?? 0}</h4>
            </div>
            <span class="rounded-md bg-warning-100 px-2 py-1 text-theme-xs font-medium text-warning-600">
              Cần xử lý
            </span>
          </div>
        </a>

        <div class="rounded-2xl border border-gray-200 bg-white p-5 shadow-theme-xs">
          <h3 class="text-theme-sm font-semibold text-gray-800">Cập nhật tức thời</h3>
          <p class="mt-1 text-theme-xs text-gray-500 leading-relaxed">
            Trang công khai
            <a href="https://family.huynhvantuan.net" class="text-brand-500 hover:text-brand-600">family.huynhvantuan.net</a>
            đang chạy SSR — mọi thay đổi ở admin xuất hiện ngay khi anh refresh trang đó.
            Không cần build lại.
          </p>
        </div>
      </div>
    )}
  </div>
</AdminLayout>
