---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { supabaseAdmin } from "@/lib/supabase/admin";

export const prerender = false;

const tables = [
  { id: "members", label: "Thành viên", href: "/admin/members" },
  { id: "timeline", label: "Niên đại", href: "/admin/timeline" },
  { id: "traditions", label: "Truyền thống", href: "/admin/traditions" },
  { id: "photos", label: "Ảnh", href: "/admin/photos" },
  { id: "quotes", label: "Câu nói", href: "/admin/quotes" },
  { id: "dates", label: "Ngày lễ", href: "/admin/dates" },
  { id: "locations", label: "Địa điểm", href: "/admin/locations" },
] as const;

const counts = await Promise.all(
  tables.map(async (t) => {
    const { count } = await supabaseAdmin
      .from(t.id)
      .select("*", { count: "exact", head: true });
    return { ...t, count: count ?? 0 };
  }),
);

const { count: pendingCount } = await supabaseAdmin
  .from("app_users")
  .select("*", { count: "exact", head: true })
  .eq("status", "pending");

const isAdmin = Astro.locals.user?.role === "admin";
---

<AdminLayout title="Tổng quan">
  <div class="space-y-6">
    <section>
      <h2 class="text-xs uppercase tracking-wider text-ink-3 mb-3">Nội dung</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
        {counts.map((t) => (
          <a
            href={t.href}
            class="block bg-cream border border-line rounded-lg p-4 hover:shadow-paper-1 transition-shadow"
          >
            <div class="text-2xl font-display text-vermilion">{t.count}</div>
            <div class="text-sm text-ink-2 mt-1">{t.label}</div>
          </a>
        ))}
      </div>
    </section>

    {isAdmin && (
      <section>
        <h2 class="text-xs uppercase tracking-wider text-ink-3 mb-3">Hệ thống</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
          <a
            href="/admin/users"
            class="block bg-cream border border-line rounded-lg p-4 hover:shadow-paper-1 transition-shadow"
          >
            <div class="text-2xl font-display text-vermilion">{pendingCount ?? 0}</div>
            <div class="text-sm text-ink-2 mt-1">Chờ duyệt</div>
          </a>
        </div>
      </section>
    )}

    <section class="text-sm text-ink-3 mt-8 p-4 bg-paper-2/50 border border-dashed border-line rounded-lg">
      <p class="font-semibold text-ink-2 mb-1">P4 đang triển khai.</p>
      <p>
        CRUD members và 6 collection còn lại sẽ ra mắt ở P5–P6 theo kế hoạch.
        Hôm nay: đã có login + middleware + layout shell.
      </p>
    </section>
  </div>
</AdminLayout>
