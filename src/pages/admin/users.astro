---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { supabaseAdmin } from "@/lib/supabase/admin";
import { usernameToEmail, emailToUsername, validateUsername } from "@/lib/username";

export const prerender = false;

const me = Astro.locals.user;
if (!me || me.role !== "admin") {
  return Astro.redirect("/admin");
}

type Role = "admin" | "editor" | "branch_editor";
type Branch = "noi" | "ngoai" | "both";
type Status = "pending" | "approved" | "revoked";

let formError: string | null = null;
let formOk: string | null = null;
let username = "";
let role: Role = "branch_editor";
let branch: Branch = "both";

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = String(form.get("action") ?? "");

  if (action === "create") {
    username = String(form.get("username") ?? "").trim();
    const password = String(form.get("password") ?? "");
    role = (String(form.get("role") ?? "branch_editor") as Role);
    branch = (String(form.get("branch") ?? "both") as Branch);

    const usernameErr = validateUsername(username);
    if (usernameErr) {
      formError = usernameErr;
    } else if (password.length < 6) {
      formError = "Mật khẩu phải có ít nhất 6 ký tự.";
    } else if (!["admin", "editor", "branch_editor"].includes(role)) {
      formError = "Vai trò không hợp lệ.";
    } else if (!["noi", "ngoai", "both"].includes(branch)) {
      formError = "Nhánh không hợp lệ.";
    } else {
      const email = usernameToEmail(username);
      const { data: created, error: createErr } =
        await supabaseAdmin.auth.admin.createUser({
          email,
          password,
          email_confirm: true,
        });

      if (createErr || !created.user) {
        formError = createErr?.message?.includes("already")
          ? "Tên đăng nhập này đã được dùng."
          : `Tạo tài khoản thất bại: ${createErr?.message ?? "unknown"}`;
      } else {
        const { error: insertErr } = await supabaseAdmin
          .from("app_users")
          .upsert(
            {
              id: created.user.id,
              email,
              role,
              // Only branch_editor uses branch; admins/editors operate across all.
              branch: role === "branch_editor" ? branch : "both",
              status: "approved",
            },
            { onConflict: "id" },
          );

        if (insertErr) {
          // Rollback the auth user so we don't leave a half-provisioned account.
          await supabaseAdmin.auth.admin.deleteUser(created.user.id);
          formError = `Lưu hồ sơ thất bại: ${insertErr.message}`;
        } else {
          formOk = `Đã tạo tài khoản "${username}".`;
          username = "";
        }
      }
    }
  } else if (action === "delete") {
    const targetId = String(form.get("user_id") ?? "");
    if (!targetId) {
      formError = "Thiếu user_id.";
    } else if (targetId === me.id) {
      formError = "Không thể tự xóa tài khoản của chính mình.";
    } else {
      // Cascade: app_users row is removed by FK, but we still drop the auth user
      // explicitly so the email becomes reusable.
      await supabaseAdmin.from("app_users").delete().eq("id", targetId);
      const { error: delErr } = await supabaseAdmin.auth.admin.deleteUser(targetId);
      if (delErr) formError = `Xóa thất bại: ${delErr.message}`;
      else formOk = "Đã xóa tài khoản.";
    }
  }
}

type UserRow = {
  id: string;
  email: string;
  role: Role;
  branch: Branch | null;
  status: Status;
  created_at: string;
};

const { data: users } = await supabaseAdmin
  .from("app_users")
  .select("id, email, role, branch, status, created_at")
  .order("created_at", { ascending: false });

const rows = (users ?? []) as UserRow[];

const roleLabel: Record<Role, string> = {
  admin: "Quản trị",
  editor: "Biên tập viên",
  branch_editor: "Biên tập theo nhánh",
};
const branchLabel: Record<Branch, string> = {
  noi: "Nội",
  ngoai: "Ngoại",
  both: "Cả hai",
};
const statusLabel: Record<Status, { text: string; cls: string }> = {
  approved: { text: "Đã duyệt", cls: "bg-success-50 text-success-700 border-success-100" },
  pending: { text: "Chờ duyệt", cls: "bg-warning-50 text-warning-600 border-warning-100" },
  revoked: { text: "Đã thu hồi", cls: "bg-error-50 text-error-700 border-error-100" },
};

function fmtDate(iso: string) {
  const d = new Date(iso);
  return d.toLocaleString("vi-VN", {
    year: "numeric", month: "2-digit", day: "2-digit",
    hour: "2-digit", minute: "2-digit",
  });
}
---

<AdminLayout title="Người dùng" crumbs={[{ label: "Người dùng" }]}>
  <div class="space-y-6">
    {formError && (
      <div class="rounded-lg border border-error-100 bg-error-50 px-4 py-3 text-theme-sm text-error-700">
        {formError}
      </div>
    )}
    {formOk && (
      <div class="rounded-lg border border-success-100 bg-success-50 px-4 py-3 text-theme-sm text-success-700">
        {formOk}
      </div>
    )}

    <section class="rounded-2xl border border-gray-200 bg-white shadow-theme-xs">
      <header class="border-b border-gray-100 px-5 py-4">
        <h2 class="text-theme-sm font-semibold text-gray-800">Tạo tài khoản mới</h2>
        <p class="mt-1 text-theme-xs text-gray-500">
          Đặt tên đăng nhập + mật khẩu rồi gửi cho cô chú qua Zalo / SMS.
        </p>
      </header>
      <form method="post" class="grid grid-cols-1 gap-4 p-5 md:grid-cols-2 lg:grid-cols-4">
        <input type="hidden" name="action" value="create" />

        <div class="md:col-span-2 lg:col-span-1">
          <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">
            Tên đăng nhập
          </label>
          <input
            type="text" name="username" required
            value={username}
            placeholder="vd: cohai"
            spellcheck="false" autocapitalize="off"
            class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm text-gray-800 shadow-theme-xs placeholder:text-gray-400 focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10"
          />
        </div>

        <div class="md:col-span-2 lg:col-span-1">
          <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">
            Mật khẩu
          </label>
          <input
            type="text" name="password" required minlength="6"
            placeholder="ít nhất 6 ký tự"
            class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm text-gray-800 shadow-theme-xs placeholder:text-gray-400 focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10"
          />
        </div>

        <div>
          <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">
            Vai trò
          </label>
          <select
            name="role"
            class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm text-gray-800 shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10"
          >
            <option value="branch_editor" selected={role === "branch_editor"}>Biên tập theo nhánh</option>
            <option value="editor" selected={role === "editor"}>Biên tập viên</option>
            <option value="admin" selected={role === "admin"}>Quản trị</option>
          </select>
        </div>

        <div>
          <label class="mb-1.5 block text-theme-sm font-medium text-gray-700">
            Nhánh (chỉ áp dụng cho biên tập theo nhánh)
          </label>
          <select
            name="branch"
            class="h-11 w-full rounded-lg border border-gray-300 px-4 py-2.5 text-theme-sm text-gray-800 shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10"
          >
            <option value="both" selected={branch === "both"}>Cả nội + ngoại</option>
            <option value="noi" selected={branch === "noi"}>Họ Nội</option>
            <option value="ngoai" selected={branch === "ngoai"}>Họ Ngoại</option>
          </select>
        </div>

        <div class="md:col-span-2 lg:col-span-4 flex justify-end">
          <button
            type="submit"
            class="rounded-lg bg-brand-500 px-5 py-2.5 text-theme-sm font-medium text-white shadow-theme-xs transition hover:bg-brand-600"
          >
            Tạo tài khoản
          </button>
        </div>
      </form>
    </section>

    <section class="rounded-2xl border border-gray-200 bg-white shadow-theme-xs">
      <header class="border-b border-gray-100 px-5 py-4">
        <h2 class="text-theme-sm font-semibold text-gray-800">
          Danh sách người dùng ({rows.length})
        </h2>
      </header>
      <div class="overflow-x-auto">
        <table class="w-full text-left text-theme-sm">
          <thead class="bg-gray-50 text-theme-xs uppercase text-gray-500">
            <tr>
              <th class="px-5 py-3 font-medium">Tên đăng nhập</th>
              <th class="px-5 py-3 font-medium">Vai trò</th>
              <th class="px-5 py-3 font-medium">Nhánh</th>
              <th class="px-5 py-3 font-medium">Trạng thái</th>
              <th class="px-5 py-3 font-medium">Tạo lúc</th>
              <th class="px-5 py-3 font-medium text-right">Hành động</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {rows.map((u) => {
              const isMe = u.id === me.id;
              const sLabel = statusLabel[u.status];
              return (
                <tr class="hover:bg-gray-50">
                  <td class="px-5 py-3 font-medium text-gray-800">
                    {emailToUsername(u.email)}
                    {isMe && (
                      <span class="ml-2 rounded bg-brand-50 px-1.5 py-0.5 text-theme-xs font-medium text-brand-600">
                        bạn
                      </span>
                    )}
                  </td>
                  <td class="px-5 py-3 text-gray-700">{roleLabel[u.role]}</td>
                  <td class="px-5 py-3 text-gray-700">
                    {u.role === "branch_editor" && u.branch ? branchLabel[u.branch] : "—"}
                  </td>
                  <td class="px-5 py-3">
                    <span class={`inline-flex rounded-md border px-2 py-0.5 text-theme-xs font-medium ${sLabel.cls}`}>
                      {sLabel.text}
                    </span>
                  </td>
                  <td class="px-5 py-3 text-theme-xs text-gray-500">
                    {fmtDate(u.created_at)}
                  </td>
                  <td class="px-5 py-3 text-right">
                    {!isMe && (
                      <form method="post" class="inline" onsubmit="return confirm('Xóa tài khoản này?');">
                        <input type="hidden" name="action" value="delete" />
                        <input type="hidden" name="user_id" value={u.id} />
                        <button
                          type="submit"
                          class="rounded-md border border-error-100 px-3 py-1 text-theme-xs font-medium text-error-700 hover:bg-error-50"
                        >
                          Xóa
                        </button>
                      </form>
                    )}
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </section>
  </div>
</AdminLayout>
