---
import AdminLayout from "@/layouts/AdminLayout.astro";
import UsersList, { type UserRow as UserCardRow } from "@/components/admin/UsersList.tsx";
import ToastBanner from "@/components/admin/ToastBanner.tsx";
import { supabaseAdmin } from "@/lib/supabase/admin";
import { usernameToEmail, emailToUsername, validateUsername } from "@/lib/username";

export const prerender = false;

const me = Astro.locals.user;
if (!me || me.role !== "admin") {
  return Astro.redirect("/admin");
}

type Role = "admin" | "editor" | "branch_editor";
type Branch = "noi" | "ngoai" | "both";
type Status = "pending" | "approved" | "revoked";

let formError: string | null = null;
let formOk: string | null = null;
let username = "";
let role: Role = "branch_editor";
let branch: Branch = "both";

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = String(form.get("action") ?? "");

  if (action === "create") {
    username = String(form.get("username") ?? "").trim();
    const password = String(form.get("password") ?? "");
    role = (String(form.get("role") ?? "branch_editor") as Role);
    branch = (String(form.get("branch") ?? "both") as Branch);

    const usernameErr = validateUsername(username);
    if (usernameErr) {
      formError = usernameErr;
    } else if (password.length < 6) {
      formError = "Mật khẩu phải có ít nhất 6 ký tự.";
    } else if (!["admin", "editor", "branch_editor"].includes(role)) {
      formError = "Vai trò không hợp lệ.";
    } else if (!["noi", "ngoai", "both"].includes(branch)) {
      formError = "Nhánh không hợp lệ.";
    } else {
      const email = usernameToEmail(username);
      const { data: created, error: createErr } =
        await supabaseAdmin.auth.admin.createUser({
          email,
          password,
          email_confirm: true,
        });

      if (createErr || !created.user) {
        formError = createErr?.message?.includes("already")
          ? "Tên đăng nhập này đã được dùng."
          : `Tạo tài khoản thất bại: ${createErr?.message ?? "unknown"}`;
      } else {
        const { error: insertErr } = await supabaseAdmin
          .from("app_users")
          .upsert(
            {
              id: created.user.id,
              email,
              role,
              // Only branch_editor uses branch; admins/editors operate across all.
              branch: role === "branch_editor" ? branch : "both",
              status: "approved",
            },
            { onConflict: "id" },
          );

        if (insertErr) {
          // Rollback the auth user so we don't leave a half-provisioned account.
          await supabaseAdmin.auth.admin.deleteUser(created.user.id);
          formError = `Lưu hồ sơ thất bại: ${insertErr.message}`;
        } else {
          formOk = `Đã tạo tài khoản "${username}".`;
          username = "";
        }
      }
    }
  } else if (action === "delete") {
    const targetId = String(form.get("user_id") ?? "");
    if (!targetId) {
      formError = "Thiếu user_id.";
    } else if (targetId === me.id) {
      formError = "Không thể tự xóa tài khoản của chính mình.";
    } else {
      // Cascade: app_users row is removed by FK, but we still drop the auth user
      // explicitly so the email becomes reusable.
      await supabaseAdmin.from("app_users").delete().eq("id", targetId);
      const { error: delErr } = await supabaseAdmin.auth.admin.deleteUser(targetId);
      if (delErr) formError = `Xóa thất bại: ${delErr.message}`;
      else formOk = "Đã xóa tài khoản.";
    }
  }
}

type UserRow = {
  id: string;
  email: string;
  role: Role;
  branch: Branch | null;
  status: Status;
  created_at: string;
};

const { data: users } = await supabaseAdmin
  .from("app_users")
  .select("id, email, role, branch, status, created_at")
  .order("created_at", { ascending: false });

const rows = (users ?? []) as UserRow[];

const userItems: UserCardRow[] = rows.map((u) => ({
  id: u.id,
  username: emailToUsername(u.email),
  role: u.role,
  branch: u.branch,
  status: u.status,
  created_at: u.created_at,
  is_me: u.id === me.id,
}));
---

<AdminLayout title="Người dùng" crumbs={[{ label: "Người dùng" }]}>
  {formError && <ToastBanner client:load kind="err" text={formError} />}
  {formOk && <ToastBanner client:load kind="ok" text={formOk} />}

  <div class="space-y-6">
    <header>
      <h1 class="text-xl font-semibold text-foreground">Người dùng admin</h1>
      <p class="mt-0.5 text-sm text-muted-foreground">
        Tạo tài khoản cho cô chú; gửi tên đăng nhập + mật khẩu qua Zalo / SMS.
      </p>
    </header>

    <section class="rounded-2xl border border-border bg-card shadow-theme-xs">
      <header class="border-b border-border px-5 py-4">
        <h2 class="text-sm font-semibold text-foreground">Tạo tài khoản mới</h2>
        <p class="mt-0.5 text-xs text-muted-foreground">
          Tên đăng nhập viết liền không dấu, mật khẩu ≥ 6 ký tự.
        </p>
      </header>
      <form method="post" class="grid grid-cols-1 gap-4 p-5 md:grid-cols-2 lg:grid-cols-4">
        <input type="hidden" name="action" value="create" />

        <div class="md:col-span-2 lg:col-span-1">
          <label class="mb-1.5 block text-sm font-medium text-foreground">
            Tên đăng nhập
          </label>
          <input
            type="text" name="username" required
            value={username}
            placeholder="vd: cohai"
            spellcheck="false" autocapitalize="off"
            class="flex h-10 w-full rounded-md border border-input bg-background px-3 text-sm shadow-theme-xs placeholder:text-muted-foreground focus-visible:border-primary/50 focus-visible:outline-hidden focus-visible:ring-3 focus-visible:ring-ring/20"
          />
        </div>

        <div class="md:col-span-2 lg:col-span-1">
          <label class="mb-1.5 block text-sm font-medium text-foreground">
            Mật khẩu
          </label>
          <input
            type="text" name="password" required minlength="6"
            placeholder="ít nhất 6 ký tự"
            class="flex h-10 w-full rounded-md border border-input bg-background px-3 text-sm shadow-theme-xs placeholder:text-muted-foreground focus-visible:border-primary/50 focus-visible:outline-hidden focus-visible:ring-3 focus-visible:ring-ring/20"
          />
        </div>

        <div>
          <label class="mb-1.5 block text-sm font-medium text-foreground">Vai trò</label>
          <select
            name="role"
            class="flex h-10 w-full rounded-md border border-input bg-background px-3 text-sm shadow-theme-xs focus-visible:border-primary/50 focus-visible:outline-hidden focus-visible:ring-3 focus-visible:ring-ring/20"
          >
            <option value="branch_editor" selected={role === "branch_editor"}>Biên tập theo nhánh</option>
            <option value="editor" selected={role === "editor"}>Biên tập viên</option>
            <option value="admin" selected={role === "admin"}>Quản trị</option>
          </select>
        </div>

        <div>
          <label class="mb-1.5 block text-sm font-medium text-foreground">
            Nhánh
            <span class="ml-1 font-normal text-muted-foreground text-xs">(chỉ branch_editor)</span>
          </label>
          <select
            name="branch"
            class="flex h-10 w-full rounded-md border border-input bg-background px-3 text-sm shadow-theme-xs focus-visible:border-primary/50 focus-visible:outline-hidden focus-visible:ring-3 focus-visible:ring-ring/20"
          >
            <option value="both" selected={branch === "both"}>Cả nội + ngoại</option>
            <option value="noi" selected={branch === "noi"}>Họ Nội</option>
            <option value="ngoai" selected={branch === "ngoai"}>Họ Ngoại</option>
          </select>
        </div>

        <div class="md:col-span-2 lg:col-span-4 flex justify-end">
          <button
            type="submit"
            class="inline-flex h-10 items-center gap-2 rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground shadow-theme-xs hover:bg-brand-600 focus-visible:outline-hidden focus-visible:ring-3 focus-visible:ring-ring/40"
          >
            Tạo tài khoản
          </button>
        </div>
      </form>
    </section>

    <UsersList client:load users={userItems} />
  </div>
</AdminLayout>
