---
export const prerender = false;

import { readFile } from "node:fs/promises";
import { resolve } from "node:path";
import AdminLayout from "@/layouts/AdminLayout.astro";
import { renderMarkdown } from "@/lib/markdown";

const me = Astro.locals.user;
if (!me || me.role !== "admin") return Astro.redirect("/admin/help");

// Repo-relative path; Astro SSR runs from project root.
const mdPath = resolve(process.cwd(), "docs/admin/setup.md");
let mdSource = "";
try {
  mdSource = await readFile(mdPath, "utf8");
} catch (err) {
  mdSource = `# Lỗi đọc file\n\nKhông tìm thấy \`docs/admin/setup.md\`.\n\n${err instanceof Error ? err.message : ""}`;
}

const html = renderMarkdown(mdSource);
---

<AdminLayout
  title="Hướng dẫn cài đặt kỹ thuật"
  crumbs={[{ label: "Trợ giúp", href: "/admin/help" }, { label: "Cài đặt kỹ thuật" }]}
>
  <article class="setup-doc max-w-prose mx-auto">
    <p class="text-xs text-muted-foreground mb-2">
      Nguồn: <code>docs/admin/setup.md</code> · Sửa file để cập nhật trang này.
    </p>
    <Fragment set:html={html} />
  </article>
</AdminLayout>

<style is:global>
  .setup-doc {
    color: var(--color-foreground);
  }
  .setup-doc h1 {
    font-size: 1.875rem;
    font-weight: 700;
    margin-top: 0;
    margin-bottom: 1rem;
    color: var(--color-foreground);
  }
  .setup-doc h2 {
    font-size: 1.375rem;
    font-weight: 600;
    margin-top: 2.25rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-foreground);
  }
  .setup-doc h3 {
    font-size: 1.05rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .setup-doc p {
    line-height: 1.7;
    margin-bottom: 0.9rem;
  }
  .setup-doc ul, .setup-doc ol {
    padding-left: 1.5rem;
    margin-bottom: 0.9rem;
  }
  .setup-doc li {
    margin-bottom: 0.3rem;
    line-height: 1.6;
  }
  .setup-doc code {
    background: var(--color-muted);
    padding: 0.1em 0.35em;
    border-radius: 4px;
    font-size: 0.85em;
    font-family: ui-monospace, "JetBrains Mono", monospace;
  }
  .setup-doc pre {
    background: #1a1a1a;
    color: #f6e8c3;
    padding: 1rem 1.2rem;
    border-radius: 8px;
    overflow-x: auto;
    margin-bottom: 1.2rem;
    font-size: 0.85rem;
    line-height: 1.55;
  }
  .setup-doc pre code {
    background: transparent;
    padding: 0;
    color: inherit;
    font-size: inherit;
  }
  .setup-doc table {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0 1.5rem;
    font-size: 0.9rem;
  }
  .setup-doc th, .setup-doc td {
    border: 1px solid var(--color-border);
    padding: 0.5rem 0.75rem;
    text-align: left;
    vertical-align: top;
  }
  .setup-doc th {
    background: var(--color-muted);
    font-weight: 600;
  }
  .setup-doc a {
    color: var(--color-primary);
    text-decoration: underline;
  }
  .setup-doc a:hover {
    opacity: 0.85;
  }
  .setup-doc hr {
    margin: 2.5rem 0;
    border: 0;
    border-top: 1px solid var(--color-border);
  }
  .setup-doc strong {
    font-weight: 600;
  }
  .setup-doc blockquote {
    border-left: 3px solid var(--color-primary);
    padding-left: 1rem;
    margin: 1rem 0;
    color: var(--color-muted-foreground);
    font-style: italic;
  }
</style>
