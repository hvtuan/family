---
export const prerender = false;
import Base from "@/layouts/Base.astro";
import PageHead from "@/components/astro/PageHead.astro";
import TraditionCard from "@/components/astro/TraditionCard.astro";
import Lotus from "@/components/astro/Lotus.astro";
import { getTraditions } from "@/lib/content";

const traditions = await getTraditions();
---

<Base title="Truyền thống" pageKey="traditions">
  <div class="flex justify-center pt-12 text-jade">
    <Lotus size={96} ring />
  </div>
  <PageHead
    kicker="Traditions"
    title="Nếp nhà giữ qua thời gian"
    subtitle="Những nét sinh hoạt, ẩm thực và lễ nghi mà gia đình lưu truyền."
    subtitleEn="Customs, foods, and rituals passed down through the household"
  />

  <section class="max-w-[1240px] mx-auto px-5 pt-2 pb-20">
    {traditions.length === 0 ? (
      <div class="rounded-md border border-dashed border-line bg-cream/40 p-12 text-center">
        <p class="text-base text-ink-3 m-0">Chưa có truyền thống nào được ghi.</p>
      </div>
    ) : (
      <ul class="list-none m-0 p-0 grid grid-cols-1 sm:grid-cols-[repeat(auto-fit,minmax(300px,1fr))] gap-5">
        {traditions.map((t) => <TraditionCard tradition={t} />)}
      </ul>
    )}
  </section>
</Base>
