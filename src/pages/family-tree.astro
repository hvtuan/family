---
export const prerender = false;
import Base from "@/layouts/Base.astro";
import FamilyTreeScroll from "@/components/react/FamilyTreeScroll";
import { getMembers } from "@/lib/content";
import { toClientMember } from "@/lib/members-client";
import { getSiteIdentity } from "@/lib/settings";

const all = await getMembers((entry) => entry.data.status === "published");
const clientMembers = all.map(toClientMember);
const SITE = await getSiteIdentity();
const generationsCount = new Set(clientMembers.map((m) => m.gen)).size;
---

<Base title="Cây gia phả" pageKey="family-tree">
  <section
    class="relative max-w-[1240px] mx-auto px-4 sm:px-12 pt-12 sm:pt-16 pb-24 u-paper-texture"
  >
    <!-- Subtle ink wash patches (4 random soft circles at low opacity for organic feel) -->
    <div
      aria-hidden="true"
      class="absolute inset-0 pointer-events-none overflow-hidden"
      style="background-image:
        radial-gradient(circle at 12% 8%, rgba(168, 133, 63, 0.06) 0%, transparent 18%),
        radial-gradient(circle at 88% 22%, rgba(168, 133, 63, 0.05) 0%, transparent 22%),
        radial-gradient(circle at 18% 70%, rgba(168, 133, 63, 0.05) 0%, transparent 24%),
        radial-gradient(circle at 82% 88%, rgba(168, 133, 63, 0.04) 0%, transparent 18%);"
    ></div>

    <FamilyTreeScroll
      members={clientMembers}
      site={{
        surname: SITE.surname,
        hometown: SITE.hometown,
        motto: SITE.motto,
        established: SITE.established ?? null,
      }}
      generationsCount={generationsCount}
      client:load
    />
  </section>
</Base>
