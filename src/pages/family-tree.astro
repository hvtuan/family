---
export const prerender = false;
import Base from "@/layouts/Base.astro";
import FamilyTreeScroll from "@/components/react/FamilyTreeScroll";
import { getMembers } from "@/lib/content";
import { toClientMember } from "@/lib/members-client";
import { getSiteIdentity } from "@/lib/settings";

const all = await getMembers((entry) => entry.data.status === "published");
const clientMembers = all.map(toClientMember);
const SITE = await getSiteIdentity();
const generationsCount = new Set(clientMembers.map((m) => m.gen)).size;
---

<Base title="Cây gia phả" pageKey="family-tree">
  <section class="relative max-w-[1280px] mx-auto px-4 sm:px-8 pt-12 sm:pt-16 pb-24">
    <FamilyTreeScroll
      members={clientMembers}
      site={{
        surname: SITE.surname,
        hometown: SITE.hometown,
        motto: SITE.motto,
        established: SITE.established ?? null,
      }}
      generationsCount={generationsCount}
      client:load
    />
  </section>
</Base>
