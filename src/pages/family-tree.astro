---
export const prerender = false;
import Base from "@/layouts/Base.astro";
import PageHead from "@/components/astro/PageHead.astro";
import FamilyTree from "@/components/react/FamilyTree";
import { getMembers } from "@/lib/content";
import { toClientMember } from "@/lib/members-client";

const all = await getMembers((entry) => entry.data.status === "published");
const clientMembers = all.map(toClientMember);
---

<Base title="Cây gia phả" pageKey="family-tree">
  <PageHead
    kicker="Family Tree"
    title="Bốn thế hệ họ Nguyễn"
    subtitle="Kéo để di chuyển · phóng to/thu nhỏ bằng nút hoặc hai ngón tay · bấm vào mỗi người để xem chi tiết."
    subtitleEn="Drag to pan, pinch or +/− to zoom, click to open"
  />
  <section class="max-w-[1240px] mx-auto px-5 pt-2 pb-20">
    <FamilyTree members={clientMembers} client:load />
  </section>
</Base>
