---
import Base from "@/layouts/Base.astro";
import PageHead from "@/components/astro/PageHead.astro";
import FamilyTree from "@/components/react/FamilyTree";
import { getCollection } from "astro:content";
import { toClientMember } from "@/lib/members-client";

const all = await getCollection(
  "members",
  ({ data }) => data.status === "published",
);
const clientMembers = all.map(toClientMember);
---

<Base title="Cây gia phả" pageKey="family-tree">
  <PageHead
    kicker="Cây gia phả • Family Tree"
    title="Bốn thế hệ họ Nguyễn"
    subtitle="Kéo để di chuyển, dùng nút phóng to/thu nhỏ hoặc hai ngón tay để thu phóng. Bấm vào mỗi người để mở chi tiết."
    subtitleEn="Drag to pan, pinch or +/− to zoom, click to open details"
  />
  <section class="tree-section">
    <FamilyTree members={clientMembers} client:load />
  </section>
  <style>
    .tree-section {
      max-width: 1240px;
      margin: 0 auto;
      padding: 1rem 1.25rem 4rem;
    }
  </style>
</Base>
