---
import Base from "@/layouts/Base.astro";
import PageHead from "@/components/astro/PageHead.astro";
import { getCollection } from "astro:content";

const events = (await getCollection("timeline")).sort(
  (a, b) =>
    a.data.year - b.data.year || (a.data.date ?? "").localeCompare(b.data.date ?? ""),
);
const memberIndex = new Map(
  (await getCollection("members")).map((m) => [m.id, m]),
);

const categoryLabel: Record<string, { vi: string; en: string }> = {
  founding: { vi: "Lập gia tộc", en: "Founding" },
  birth: { vi: "Sinh", en: "Birth" },
  marriage: { vi: "Hôn lễ", en: "Marriage" },
  death: { vi: "Mất", en: "Passing" },
  milestone: { vi: "Mốc son", en: "Milestone" },
  gathering: { vi: "Tụ họp", en: "Gathering" },
};
---

<Base title="Mốc thời gian" pageKey="timeline">
  <PageHead
    kicker="Mốc thời gian • Timeline"
    title="Những dấu mốc của gia đình"
    subtitle="Theo dòng năm tháng, từ ngày khởi tổ đến hôm nay."
    subtitleEn="From the founding day to the present"
  />

  <section class="timeline">
    <ol class="timeline-track">
      {
        events.map((e) => {
          const cat = e.data.category ? categoryLabel[e.data.category] : undefined;
          const related = e.data.related
            .map((r) => memberIndex.get(r.id))
            .filter(Boolean);
          return (
            <li class="timeline-item">
              <div class="timeline-dot" aria-hidden="true">
                <span class="dot-year">{e.data.year}</span>
              </div>
              <article class="timeline-card u-card">
                <header class="timeline-card-head">
                  {cat && (
                    <span class="timeline-cat">
                      <span>{cat.vi}</span>
                      <span class="timeline-cat-en" lang="en">
                        {cat.en}
                      </span>
                    </span>
                  )}
                  {e.data.date && (
                    <time datetime={e.data.date} class="timeline-date">
                      {e.data.date}
                      {e.data.lunar && <span class="lunar-badge">âm lịch</span>}
                    </time>
                  )}
                </header>
                <h2 class="timeline-title">{e.data.title}</h2>
                <p class="timeline-title-en" lang="en">
                  {e.data.titleEn}
                </p>
                <p class="timeline-desc">{e.data.desc}</p>
                <p class="timeline-desc-en" lang="en">
                  {e.data.descEn}
                </p>
                {related.length > 0 && (
                  <footer class="timeline-related">
                    <span class="related-label">Liên quan:</span>
                    <ul>
                      {related.map((m) => (
                        <li>
                          <a href={`/members?member=${m!.data.id}`}>{m!.data.name}</a>
                        </li>
                      ))}
                    </ul>
                  </footer>
                )}
              </article>
            </li>
          );
        })
      }
    </ol>

    {
      events.length === 0 && (
        <p class="empty-state">Chưa có mốc thời gian nào được ghi lại.</p>
      )
    }
  </section>

  <style>
    .timeline {
      max-width: 880px;
      margin: 0 auto;
      padding: 1rem 1.25rem 4rem;
    }
    .timeline-track {
      list-style: none;
      margin: 0;
      padding: 0;
      position: relative;
    }
    .timeline-track::before {
      content: "";
      position: absolute;
      left: 56px;
      top: 0;
      bottom: 0;
      width: 2px;
      background: var(--color-line-strong);
    }
    .timeline-item {
      display: grid;
      grid-template-columns: 112px 1fr;
      gap: 1rem;
      align-items: flex-start;
      padding-bottom: 2rem;
    }
    .timeline-dot {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 112px;
      position: relative;
      padding-top: 0.5rem;
    }
    .dot-year {
      width: 64px;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      background: var(--color-paper);
      border: 3px solid var(--color-vermilion);
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 1.05rem;
      color: var(--color-vermilion);
      box-shadow: var(--shadow-paper-1);
      z-index: 1;
    }
    .timeline-card {
      padding: 1.25rem 1.5rem;
    }
    .timeline-card-head {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 0.5rem;
    }
    .timeline-cat {
      display: inline-flex;
      flex-direction: column;
      line-height: 1.1;
      padding: 0.3rem 0.75rem;
      background: var(--color-vermilion);
      color: var(--color-paper);
      border-radius: 999px;
      font-size: 0.78rem;
      font-weight: 600;
    }
    .timeline-cat-en {
      font-size: 0.6rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      opacity: 0.85;
    }
    .timeline-date {
      font-size: 0.85rem;
      color: var(--color-ink-3);
      font-feature-settings: "tnum" 1;
      display: inline-flex;
      gap: 0.4rem;
      align-items: center;
    }
    .lunar-badge {
      font-size: 0.65rem;
      padding: 0.1rem 0.45rem;
      background: var(--color-paper-3);
      border-radius: 999px;
      color: var(--color-ink-2);
      letter-spacing: 0.04em;
    }
    .timeline-title {
      font-size: 1.3rem;
      margin: 0;
    }
    .timeline-title-en {
      font-size: 0.78rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--color-ink-3);
      margin-bottom: 0.6rem;
    }
    .timeline-desc {
      color: var(--color-ink-2);
      line-height: 1.6;
    }
    .timeline-desc-en {
      color: var(--color-ink-3);
      font-size: 0.88rem;
      line-height: 1.5;
      margin-top: 0.3rem;
      font-style: italic;
    }
    .timeline-related {
      margin-top: 0.875rem;
      padding-top: 0.75rem;
      border-top: 1px dashed var(--color-line);
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      align-items: baseline;
      font-size: 0.85rem;
    }
    .related-label {
      color: var(--color-ink-3);
      font-size: 0.78rem;
      letter-spacing: 0.06em;
    }
    .timeline-related ul {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
    }
    .timeline-related li a {
      color: var(--color-vermilion);
      font-weight: 600;
    }
    .empty-state {
      text-align: center;
      padding: 4rem 1rem;
      color: var(--color-ink-3);
    }

    @media (max-width: 568px) {
      .timeline-track::before {
        left: 24px;
      }
      .timeline-item {
        grid-template-columns: 56px 1fr;
      }
      .timeline-dot {
        width: 56px;
      }
      .dot-year {
        width: 48px;
        height: 48px;
        font-size: 0.78rem;
      }
    }
  </style>
</Base>
