---
export const prerender = false;
import Base from "@/layouts/Base.astro";
import PageHead from "@/components/astro/PageHead.astro";
import TimelineEvent from "@/components/astro/TimelineEvent.astro";
import { getMembers, getTimeline } from "@/lib/content";

const events = (await getTimeline()).sort(
  (a, b) =>
    a.data.year - b.data.year || (a.data.date ?? "").localeCompare(b.data.date ?? ""),
);
const memberIndex = new Map(
  (await getMembers()).map((m) => [m.id, m]),
);
---

<Base title="Mốc thời gian" pageKey="timeline">
  <PageHead
    kicker="Timeline"
    title="Những dấu mốc của gia đình"
    subtitle={events.length > 0
      ? `Từ ${events[0].data.year} đến ${events[events.length - 1].data.year} — dòng năm tháng đi qua bao thế hệ.`
      : "Theo dòng năm tháng, từ ngày khởi tổ đến hôm nay."}
    subtitleEn="From the founding day to the present"
  />

  <section class="max-w-[880px] mx-auto px-5 pt-2 pb-24">
    {events.length === 0 ? (
      <div class="rounded-md border border-dashed border-line bg-cream/40 p-12 text-center">
        <p class="text-base text-ink-3 m-0">
          Chưa có mốc thời gian nào được ghi lại.
        </p>
      </div>
    ) : (
      <ol class="list-none m-0 p-0 relative pt-12 pb-12">
        <!-- Center spine — gold gradient that fades at top/bottom.
             Ends short of the blossoms (top-10 / bottom-10) so the
             line doesn't visually pass through the flower. -->
        <span
          aria-hidden="true"
          class="absolute left-14 w-px mobile:left-6"
          style="top: 2.75rem; bottom: 2.75rem; background: linear-gradient(to bottom, transparent 0, var(--color-gold-2) 24px, var(--color-gold-2) calc(100% - 24px), transparent 100%);"
        ></span>
        <!-- Top + bottom blossom anchors with breathing room -->
        <span
          aria-hidden="true"
          class="absolute left-14 -translate-x-1/2 top-2 text-vermilion text-2xl mobile:left-6"
        >❀</span>
        <span
          aria-hidden="true"
          class="absolute left-14 -translate-x-1/2 bottom-2 text-vermilion text-2xl mobile:left-6"
        >❀</span>

        {events.map((e) => {
          const related = e.data.related
            .map((r) => memberIndex.get(r.id))
            .filter(Boolean)
            .map((m) => ({ id: m!.data.id, name: m!.data.name }));
          return <TimelineEvent event={e.data} related={related} />;
        })}
      </ol>
    )}
  </section>
</Base>
