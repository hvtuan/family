---
export const prerender = false;
import Base from "@/layouts/Base.astro";
import BlossomDivider from "@/components/astro/BlossomDivider.astro";
import HeroSlideshow, { type HeroSlide } from "@/components/astro/HeroSlideshow.tsx";
import Lotus from "@/components/astro/Lotus.astro";
import MemberCard from "@/components/astro/MemberCard.astro";
import QuoteCard from "@/components/astro/QuoteCard.astro";
import { SITE } from "@/data/site";
import { getMembers, getQuotes, getTimeline } from "@/lib/content";
import { toClientMember } from "@/lib/members-client";
import { isInActiveWindow, listHeroSlides } from "@/lib/hero-admin";
import { getHeroDefaults } from "@/lib/settings";

const heroDefaults = await getHeroDefaults();

const allMembers = await getMembers((entry) => entry.data.status === "published");
const clientMembers = allMembers.map(toClientMember);
const quotes = await getQuotes();
const timeline = await getTimeline();

// Active hero slides — when any exist the slideshow renders ABOVE the
// static Lotus hero block. Filtered by schedule window so future /
// expired event slides drop out automatically.
const allHeroSlides = await listHeroSlides(false);
const heroSlideRows = allHeroSlides.filter((s) =>
  isInActiveWindow(s, new Date()),
);
const heroSlides: HeroSlide[] = heroSlideRows.map((s) => ({
  id: s.id,
  kind: s.photo.kind,
  src: s.photo.src,
  poster: s.photo.src_medium ?? s.photo.src_thumb,
  thumb: s.photo.src_thumb,
  caption: s.photo.caption,
  altVi: s.photo.alt_vi,
  // Mobile variant — when set, the React island swaps to it on viewports < 768.
  mobileSrc: s.photo_mobile?.src ?? null,
  mobilePoster: s.photo_mobile?.src_medium ?? s.photo_mobile?.src_thumb ?? null,
  mobileKind: s.photo_mobile?.kind ?? null,
  headlineVi: s.headline_vi,
  headlineEn: s.headline_en,
  ctaLabel: s.cta_label,
  ctaHref: s.cta_href,
  durationMs: s.duration_ms,
}));

const heroQuote = quotes[0];
const heroAuthorRef = heroQuote?.data.authorRef
  ? clientMembers.find((m) => m.id === heroQuote.data.authorRef!.id)
  : undefined;

const featuredMembers = clientMembers
  .slice()
  .sort(
    (a, b) =>
      a.gen - b.gen || (a.birthOrder ?? 99) - (b.birthOrder ?? 99),
  )
  .slice(0, 3);

const generations = new Set(clientMembers.map((m) => m.gen)).size;
const yearsSince = new Date().getFullYear() - SITE.established;
---

<Base pageKey="home">
  {heroSlides.length > 0 && (
    <HeroSlideshow client:load slides={heroSlides} height={heroDefaults.height} />
  )}

  <!-- ─── HERO ────────────────────────────────────────────────
       Lotus motif + brand name + motto. Acts as sub-hero when the
       slideshow is on, or the only hero when no slides configured.
       Hidden via settings toggle when admin wants slideshow alone. -->
  {(heroSlides.length === 0 || heroDefaults.showLotusWhenEmpty) && (
  <section class="relative overflow-hidden u-paper-texture">
    <div class="max-w-[880px] mx-auto px-5 pt-20 pb-16 md:pt-28 md:pb-20 text-center">
      <!-- Lotus seal — Vietnamese cultural motif as the visual anchor -->
      <div class="relative inline-block mb-6">
        <Lotus size={140} ring />
      </div>

      <p class="text-xs tracking-wider uppercase font-semibold text-gold-2 mb-3">
        {SITE.brand.en}
      </p>

      <h1 class="font-display font-bold leading-[1.05] tracking-tight text-ink m-0">
        <span style="font-size: var(--text-6xl);">{SITE.brand.vi}</span>
      </h1>

      <p class="mt-4 text-lg text-ink-2 leading-relaxed">
        {SITE.hometown}
      </p>

      <!-- Motto in script — restrained, single line, jade not vermilion -->
      <p class="mt-8 font-script italic text-2xl text-jade">
        "{SITE.motto}"
      </p>

      <!-- Inline stats line — heritage tone, not dashboard -->
      <p class="mt-10 text-sm text-ink-3 tabular-nums">
        <span class="text-ink font-semibold">{clientMembers.length}</span> thành viên
        <span class="mx-2 text-line-strong">·</span>
        <span class="text-ink font-semibold">{generations}</span> thế hệ
        <span class="mx-2 text-line-strong">·</span>
        <span class="text-ink font-semibold">{timeline.length}</span> dấu mốc
        <span class="mx-2 text-line-strong">·</span>
        từ năm <span class="text-ink font-semibold">{SITE.established}</span>
        <span class="text-ink-3"> ({yearsSince} năm)</span>
      </p>

      <div class="mt-10 flex justify-center gap-3 flex-wrap">
        <a href="/family-tree" class="u-btn u-btn-primary u-btn-lg">
          Xem cây gia phả
        </a>
        <a href="/members" class="u-btn u-btn-secondary u-btn-lg">
          Tất cả thành viên
        </a>
      </div>
    </div>
  </section>
  )}

  {heroQuote && (
    <section class="max-w-[720px] mx-auto px-5 py-12">
      <QuoteCard
        quote={heroQuote.data}
        authorHref={heroAuthorRef ? `/members?member=${heroAuthorRef.id}` : undefined}
        variant="compact"
      />
    </section>
  )}

  <BlossomDivider variant="lg" tone="gold" />

  <!-- ─── FEATURED MEMBERS ─────────────────────────────────── -->
  <section class="max-w-[1240px] mx-auto px-5 pt-6 pb-20">
    <header class="text-center mb-10">
      <p class="u-kicker">Members</p>
      <h2 class="font-display font-bold text-ink m-0 mt-2 leading-tight" style="font-size: var(--text-3xl);">
        Những người dựng nên gia đình
      </h2>
    </header>

    <ul class="list-none m-0 p-0 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {featuredMembers.map((m) => (
        <li>
          <MemberCard member={m} />
        </li>
      ))}
    </ul>

    <div class="flex justify-center gap-3 mt-12 flex-wrap">
      <a href="/members" class="u-btn u-btn-primary">
        Xem tất cả thành viên →
      </a>
    </div>
  </section>
</Base>
