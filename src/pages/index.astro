---
export const prerender = false;
import Base from "@/layouts/Base.astro";
import BlossomDivider from "@/components/astro/BlossomDivider.astro";
import Stamp from "@/components/astro/Stamp.astro";
import MemberCard from "@/components/astro/MemberCard.astro";
import QuoteCard from "@/components/astro/QuoteCard.astro";
import { SITE } from "@/data/site";
import { getMembers, getQuotes, getTimeline } from "@/lib/content";
import { toClientMember } from "@/lib/members-client";

const allMembers = await getMembers((entry) => entry.data.status === "published");
const clientMembers = allMembers.map(toClientMember);
const quotes = await getQuotes();
const timeline = await getTimeline();

const heroQuote = quotes[0];
const heroAuthorRef = heroQuote?.data.authorRef
  ? clientMembers.find((m) => m.id === heroQuote.data.authorRef!.id)
  : undefined;

const featuredMembers = clientMembers
  .slice()
  .sort(
    (a, b) =>
      a.gen - b.gen || (a.birthOrder ?? 99) - (b.birthOrder ?? 99),
  )
  .slice(0, 3);

const generations = new Set(clientMembers.map((m) => m.gen)).size;
const stats = [
  { label: "Thành viên", labelEn: "Members", value: clientMembers.length },
  { label: "Thế hệ", labelEn: "Generations", value: generations },
  { label: "Kỷ niệm", labelEn: "Milestones", value: timeline.length },
  { label: "Năm khởi tổ", labelEn: "Established", value: SITE.established },
];
---

<Base pageKey="home">
  <section class="max-w-[1240px] mx-auto px-5 pt-16 pb-10">
    <div class="flex flex-col gap-5 items-center text-center">
      <p class="u-kicker">Gia phả • Genealogy</p>
      <h1 class="flex flex-col gap-1">
        <span class="font-display font-bold text-[clamp(2.4rem,6vw,4.5rem)] leading-[1.05] tracking-[-0.02em] text-ink">
          {SITE.brand.vi}
        </span>
        <span class="text-[0.85rem] tracking-[0.3em] uppercase text-ink-3">
          {SITE.brand.en}
        </span>
      </h1>
      <p class="text-[1.05rem] text-ink-2">
        {SITE.hometown} • <span lang="en">{SITE.hometownEn}</span>
      </p>
      <div class="flex gap-6 items-center mt-4 flex-wrap justify-center">
        <Stamp text={SITE.monogram} />
        <div class="flex flex-col gap-1 text-2xl text-left">
          <span class="u-script">{SITE.motto}</span>
          <span class="text-[0.7rem] tracking-[0.2em] uppercase text-ink-3">
            {SITE.mottoEn}
          </span>
        </div>
      </div>
    </div>
  </section>

  {
    heroQuote && (
      <section class="max-w-[720px] mx-auto px-5 py-6">
        <QuoteCard
          quote={heroQuote.data}
          authorHref={heroAuthorRef ? `/members?member=${heroAuthorRef.id}` : undefined}
          variant="compact"
        />
      </section>
    )
  }

  <section class="max-w-[1240px] mx-auto px-5 py-6">
    <div class="grid grid-cols-[repeat(auto-fit,minmax(140px,1fr))] gap-3">
      {
        stats.map((s) => (
          <div class="bg-paper-2 border border-line rounded-xl p-5 text-center">
            <div class="font-display font-bold text-[2.2rem] text-vermilion leading-none">
              {s.value}
            </div>
            <div class="mt-2 text-[0.92rem] text-ink">{s.label}</div>
            <div lang="en" class="text-[0.65rem] tracking-[0.16em] uppercase text-ink-3">
              {s.labelEn}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <BlossomDivider />

  <section class="max-w-[1240px] mx-auto px-5 pt-4 pb-16">
    <header class="text-center mb-8">
      <p class="u-kicker">Thành viên • Members</p>
      <h2 class="text-[clamp(1.6rem,3vw,2.4rem)] my-2">
        Những người dựng nên gia đình
      </h2>
      <p class="text-[0.85rem] tracking-[0.16em] uppercase text-ink-3" lang="en">
        The people who built our family
      </p>
    </header>

    <ul class="list-none m-0 p-0 grid grid-cols-1 sm:grid-cols-[repeat(auto-fit,minmax(260px,1fr))] gap-5">
      {featuredMembers.map((m) => (
        <li>
          <MemberCard member={m} />
        </li>
      ))}
    </ul>

    <div class="flex justify-center gap-3 mt-10 flex-wrap">
      <a
        href="/members"
        class="inline-flex items-center gap-2 px-5 py-3 rounded-full font-semibold text-[0.95rem] bg-vermilion text-paper shadow-paper-1 transition-all duration-150 hover:-translate-y-px hover:shadow-paper-2 hover:text-paper"
      >
        Xem tất cả thành viên
      </a>
      <a
        href="/family-tree"
        class="inline-flex items-center gap-2 px-5 py-3 rounded-full font-semibold text-[0.95rem] bg-paper-2 text-ink border border-line-strong hover:bg-paper-3 hover:text-ink"
      >
        Cây gia phả
      </a>
    </div>
  </section>
</Base>
