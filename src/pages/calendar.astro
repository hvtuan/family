---
export const prerender = false;
import Base from "@/layouts/Base.astro";
import PageHead from "@/components/astro/PageHead.astro";
import DateCard from "@/components/astro/DateCard.astro";
import { getDates, getMembers } from "@/lib/content";

const dates = await getDates();
const memberIndex = new Map(
  (await getMembers()).map((m) => [m.id, m]),
);

type DType = (typeof dates)[number]["data"]["type"];

const typeOrder: DType[] = [
  "memorial",
  "anniversary",
  "birthday",
  "festival",
  "national",
  "gathering",
];

const typeLabel: Record<DType, { vi: string; en: string; emoji: string }> = {
  memorial: { vi: "Giỗ kỵ", en: "Memorials", emoji: "🪔" },
  anniversary: { vi: "Kỷ niệm", en: "Anniversaries", emoji: "💐" },
  birthday: { vi: "Sinh nhật", en: "Birthdays", emoji: "🎂" },
  festival: { vi: "Lễ hội", en: "Festivals", emoji: "🎏" },
  national: { vi: "Lễ quốc gia", en: "National holidays", emoji: "🇻🇳" },
  gathering: { vi: "Họp mặt", en: "Gatherings", emoji: "🍵" },
};

function parseSortKey(raw: string): number {
  const m1 = raw.match(/^(\d{4})-(\d{2})-(\d{2})/);
  if (m1) return Number(m1[2]) * 100 + Number(m1[3]);
  const m2 = raw.match(/^(\d{1,2})[-/](\d{1,2})$/);
  if (m2) return Number(m2[1]) * 100 + Number(m2[2]);
  return 9999;
}

const grouped = typeOrder
  .map((type) => ({
    type,
    items: dates
      .filter((d) => d.data.type === type)
      .sort((a, b) => parseSortKey(a.data.date) - parseSortKey(b.data.date)),
  }))
  .filter((g) => g.items.length > 0);
---

<Base title="Lịch" pageKey="calendar">
  <PageHead
    kicker="Calendar"
    title="Những ngày gia đình ghi nhớ"
    subtitle="Giỗ kỵ, sinh nhật, lễ hội — sắp xếp theo ngày trong năm."
    subtitleEn="Memorials, birthdays, festivals — ordered by day of year"
  />

  <section
    class="relative max-w-[960px] mx-auto px-5 pt-2 pb-20 flex flex-col gap-10"
  >
    <!-- Decorative calendar grid overlay — very subtle, behind content -->
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 opacity-[0.04] -z-0"
      style="background-image:
        linear-gradient(to right, var(--color-ink) 1px, transparent 1px),
        linear-gradient(to bottom, var(--color-ink) 1px, transparent 1px);
        background-size: 80px 80px;"
    ></div>

    <div class="relative">
      {grouped.length === 0 ? (
        <div class="rounded-md border border-dashed border-line bg-cream/40 p-12 text-center">
          <p class="text-base text-ink-3 m-0">Chưa có ngày kỷ niệm nào được ghi.</p>
        </div>
      ) : (
        <div class="flex flex-col gap-12">
          {grouped.map(({ type, items }) => {
            const t = typeLabel[type];
            return (
              <div class="flex flex-col gap-4">
                <header class="flex items-center gap-3.5 pb-3 border-b border-gold-2/40">
                  <span class="text-3xl leading-none" aria-hidden="true">{t.emoji}</span>
                  <h2
                    class="font-display font-bold m-0 text-ink leading-tight"
                    style="font-size: var(--text-xl);"
                    title={t.en}
                  >
                    {t.vi}
                  </h2>
                  <span class="ml-auto inline-flex items-center justify-center min-w-7 h-7 px-2 bg-paper-2 border border-line rounded-full text-xs text-ink-2 font-semibold tabular-nums">
                    {items.length}
                  </span>
                </header>
                <ul class="list-none m-0 p-0 flex flex-col gap-3">
                  {items.map((d) => {
                    const member = d.data.member
                      ? memberIndex.get(d.data.member.id)
                      : undefined;
                    return (
                      <DateCard
                        entry={d.data}
                        member={member ? { id: member.data.id, name: member.data.name } : undefined}
                      />
                    );
                  })}
                </ul>
              </div>
            );
          })}
        </div>
      )}
    </div>
  </section>
</Base>
