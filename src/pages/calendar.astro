---
import Base from "@/layouts/Base.astro";
import PageHead from "@/components/astro/PageHead.astro";
import { getCollection } from "astro:content";

const dates = await getCollection("dates");
const memberIndex = new Map(
  (await getCollection("members")).map((m) => [m.id, m]),
);

type D = (typeof dates)[number];

const typeOrder: D["data"]["type"][] = [
  "memorial",
  "anniversary",
  "birthday",
  "festival",
  "national",
  "gathering",
];

const typeLabel: Record<D["data"]["type"], { vi: string; en: string; emoji: string }> = {
  memorial: { vi: "Giỗ kỵ", en: "Memorials", emoji: "🪔" },
  anniversary: { vi: "Kỷ niệm", en: "Anniversaries", emoji: "💐" },
  birthday: { vi: "Sinh nhật", en: "Birthdays", emoji: "🎂" },
  festival: { vi: "Lễ hội", en: "Festivals", emoji: "🎏" },
  national: { vi: "Lễ quốc gia", en: "National holidays", emoji: "🇻🇳" },
  gathering: { vi: "Họp mặt", en: "Gatherings", emoji: "🍵" },
};

const monthNames = [
  "Tháng 1",
  "Tháng 2",
  "Tháng 3",
  "Tháng 4",
  "Tháng 5",
  "Tháng 6",
  "Tháng 7",
  "Tháng 8",
  "Tháng 9",
  "Tháng 10",
  "Tháng 11",
  "Tháng 12",
];

function parseDate(raw: string): { month: number; day: number } | null {
  // Accept "MM-DD", "YYYY-MM-DD", or "MM/DD"
  const m1 = raw.match(/^(\d{4})-(\d{2})-(\d{2})/);
  if (m1) return { month: Number(m1[2]), day: Number(m1[3]) };
  const m2 = raw.match(/^(\d{1,2})[-/](\d{1,2})$/);
  if (m2) return { month: Number(m2[1]), day: Number(m2[2]) };
  return null;
}

function sortKey(d: D) {
  const p = parseDate(d.data.date);
  if (!p) return 9999;
  return p.month * 100 + p.day;
}

const grouped = typeOrder
  .map((type) => ({
    type,
    items: dates
      .filter((d) => d.data.type === type)
      .sort((a, b) => sortKey(a) - sortKey(b)),
  }))
  .filter((g) => g.items.length > 0);
---

<Base title="Lịch" pageKey="calendar">
  <PageHead
    kicker="Lịch • Calendar"
    title="Những ngày gia đình ghi nhớ"
    subtitle="Giỗ kỵ, sinh nhật, lễ hội — sắp xếp theo ngày trong năm."
    subtitleEn="Memorials, birthdays, festivals — ordered by day of year"
  />

  <section class="calendar">
    {
      grouped.length === 0 ? (
        <p class="empty-state">Chưa có ngày kỷ niệm nào được ghi.</p>
      ) : (
        grouped.map(({ type, items }) => {
          const t = typeLabel[type];
          return (
            <div class="cal-group">
              <header class="cal-group-head">
                <span class="cal-group-icon" aria-hidden="true">
                  {t.emoji}
                </span>
                <div>
                  <h2>{t.vi}</h2>
                  <p lang="en">{t.en}</p>
                </div>
                <span class="cal-group-count">{items.length}</span>
              </header>
              <ul class="cal-list">
                {items.map((d) => {
                  const member = d.data.member
                    ? memberIndex.get(d.data.member.id)
                    : undefined;
                  const parsed = parseDate(d.data.date);
                  return (
                    <li class="cal-item u-card">
                      <div class="cal-date">
                        <span class="cal-day">
                          {parsed ? String(parsed.day).padStart(2, "0") : "—"}
                        </span>
                        <span class="cal-month">
                          {parsed ? monthNames[parsed.month - 1] : d.data.date}
                        </span>
                        <span
                          class={`cal-cal-type cal-cal-type-${d.data.calendar}`}
                        >
                          {d.data.calendar === "lunar" ? "Âm lịch" : "Dương lịch"}
                        </span>
                      </div>
                      <div class="cal-body">
                        <h3>{d.data.name}</h3>
                        <p class="cal-name-en" lang="en">
                          {d.data.nameEn}
                        </p>
                        {member && (
                          <p class="cal-member">
                            <span class="cal-member-label">Tưởng nhớ:</span>{" "}
                            <a href={`/members?member=${member.data.id}`}>
                              {member.data.name}
                            </a>
                          </p>
                        )}
                        {d.data.notes && <p class="cal-notes">{d.data.notes}</p>}
                        {d.data.recurring && (
                          <span class="cal-recurring">Hằng năm</span>
                        )}
                      </div>
                    </li>
                  );
                })}
              </ul>
            </div>
          );
        })
      )
    }
  </section>

  <style>
    .calendar {
      max-width: 960px;
      margin: 0 auto;
      padding: 1rem 1.25rem 4rem;
      display: flex;
      flex-direction: column;
      gap: 2.5rem;
    }
    .cal-group {
      display: flex;
      flex-direction: column;
      gap: 0.875rem;
    }
    .cal-group-head {
      display: flex;
      align-items: center;
      gap: 0.875rem;
      padding-bottom: 0.625rem;
      border-bottom: 2px solid var(--color-line-strong);
    }
    .cal-group-icon {
      font-size: 2rem;
      line-height: 1;
    }
    .cal-group-head h2 {
      font-size: 1.4rem;
      margin: 0;
    }
    .cal-group-head p[lang="en"] {
      font-size: 0.7rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--color-ink-3);
    }
    .cal-group-count {
      margin-left: auto;
      padding: 0.25rem 0.7rem;
      background: var(--color-paper-2);
      border-radius: 999px;
      font-size: 0.85rem;
      color: var(--color-ink-2);
      font-weight: 600;
    }

    .cal-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .cal-item {
      display: grid;
      grid-template-columns: 110px 1fr;
      gap: 1rem;
      padding: 1rem 1.25rem;
      align-items: center;
    }
    .cal-date {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.2rem;
      padding: 0.625rem;
      background: var(--color-paper-2);
      border-radius: 10px;
      text-align: center;
    }
    .cal-day {
      font-family: var(--font-display);
      font-size: 2rem;
      font-weight: 700;
      color: var(--color-vermilion);
      line-height: 1;
    }
    .cal-month {
      font-size: 0.78rem;
      color: var(--color-ink-2);
    }
    .cal-cal-type {
      font-size: 0.6rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 0.1rem 0.5rem;
      border-radius: 999px;
      margin-top: 0.2rem;
    }
    .cal-cal-type-lunar {
      background: var(--color-vermilion);
      color: var(--color-paper);
    }
    .cal-cal-type-solar {
      background: var(--color-jade);
      color: var(--color-paper);
    }
    .cal-body h3 {
      font-size: 1.1rem;
      margin: 0;
    }
    .cal-name-en {
      font-size: 0.75rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--color-ink-3);
      margin-bottom: 0.4rem;
    }
    .cal-member {
      font-size: 0.92rem;
      color: var(--color-ink-2);
    }
    .cal-member-label {
      color: var(--color-ink-3);
      font-size: 0.78rem;
    }
    .cal-member a {
      color: var(--color-vermilion);
      font-weight: 600;
    }
    .cal-notes {
      margin-top: 0.5rem;
      font-size: 0.85rem;
      color: var(--color-ink-3);
      line-height: 1.55;
    }
    .cal-recurring {
      display: inline-block;
      margin-top: 0.5rem;
      padding: 0.15rem 0.55rem;
      background: var(--color-paper-3);
      border-radius: 999px;
      font-size: 0.7rem;
      color: var(--color-ink-2);
    }
    .empty-state {
      text-align: center;
      padding: 4rem 1rem;
      color: var(--color-ink-3);
    }

    @media (max-width: 568px) {
      .cal-item {
        grid-template-columns: 90px 1fr;
        gap: 0.75rem;
      }
      .cal-day {
        font-size: 1.5rem;
      }
    }
  </style>
</Base>
