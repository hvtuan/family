---
import Base from "@/layouts/Base.astro";
import { SITE } from "@/data/site";
---

<Base title="Không tìm thấy" pageKey="404">
  <section class="max-w-[640px] mx-auto my-16 px-5 pb-16 text-center flex flex-col gap-3.5 items-center">
    <div
      class="w-[120px] h-[120px] flex items-center justify-center border-4 border-vermilion rounded-2xl bg-vermilion/5 text-vermilion font-display font-black text-[2.5rem] -rotate-3 tracking-wide mb-2"
      aria-hidden="true"
    >
      404
    </div>
    <p class="u-kicker">Lạc bước • Page not found</p>
    <h1 class="text-[clamp(2rem,5vw,3rem)]">Không tìm thấy trang</h1>
    <p class="max-w-[50ch] text-ink-2 leading-relaxed">
      Có thể đường dẫn đã đổi, hoặc trang này chưa được dựng. Quay lại
      <a href="/" class="text-vermilion font-semibold hover:underline">
        trang chủ {SITE.brand.vi}
      </a>
      để tiếp tục.
    </p>
    <p lang="en" class="text-[0.85rem] text-ink-3 italic">
      The page you're looking for doesn't exist. Return to the
      <a href="/" class="text-vermilion font-semibold hover:underline">homepage</a>.
    </p>

    <ul class="list-none mt-6 m-0 p-0 flex flex-wrap gap-2 justify-center">
      <li>
        <a href="/family-tree" class="inline-block px-4 py-2 bg-paper-2 border border-line rounded-full text-ink text-[0.9rem] hover:bg-paper-3 hover:text-ink">Cây gia phả</a>
      </li>
      <li>
        <a href="/members" class="inline-block px-4 py-2 bg-paper-2 border border-line rounded-full text-ink text-[0.9rem] hover:bg-paper-3 hover:text-ink">Thành viên</a>
      </li>
      <li>
        <a href="/timeline" class="inline-block px-4 py-2 bg-paper-2 border border-line rounded-full text-ink text-[0.9rem] hover:bg-paper-3 hover:text-ink">Mốc thời gian</a>
      </li>
      <li>
        <a href="/sayings" class="inline-block px-4 py-2 bg-paper-2 border border-line rounded-full text-ink text-[0.9rem] hover:bg-paper-3 hover:text-ink">Lời nhắn</a>
      </li>
    </ul>
  </section>
</Base>
