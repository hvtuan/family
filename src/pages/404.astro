---
import Base from "@/layouts/Base.astro";
import { SITE } from "@/data/site";
---

<Base title="Không tìm thấy" pageKey="404">
  <section class="not-found">
    <div class="nf-seal" aria-hidden="true">404</div>
    <p class="u-kicker">Lạc bước • Page not found</p>
    <h1>Không tìm thấy trang</h1>
    <p class="nf-desc">
      Có thể đường dẫn đã đổi, hoặc trang này chưa được dựng. Quay lại
      <a href="/">trang chủ {SITE.brand.vi}</a> để tiếp tục.
    </p>
    <p lang="en" class="nf-desc-en">
      The page you're looking for doesn't exist. Return to the
      <a href="/">homepage</a>.
    </p>

    <ul class="nf-suggested">
      <li><a href="/family-tree">Cây gia phả</a></li>
      <li><a href="/members">Thành viên</a></li>
      <li><a href="/timeline">Mốc thời gian</a></li>
      <li><a href="/sayings">Lời nhắn</a></li>
    </ul>
  </section>

  <style>
    .not-found {
      max-width: 640px;
      margin: 4rem auto;
      padding: 3rem 1.25rem 4rem;
      text-align: center;
      display: flex;
      flex-direction: column;
      gap: 0.875rem;
      align-items: center;
    }

    .nf-seal {
      width: 120px;
      height: 120px;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 4px solid var(--color-vermilion);
      border-radius: 16px;
      background: rgba(139, 42, 31, 0.04);
      color: var(--color-vermilion);
      font-family: var(--font-display);
      font-weight: 900;
      font-size: 2.5rem;
      transform: rotate(-4deg);
      letter-spacing: 0.05em;
      margin-bottom: 0.5rem;
    }

    .not-found h1 {
      font-size: clamp(2rem, 5vw, 3rem);
    }

    .nf-desc {
      max-width: 50ch;
      color: var(--color-ink-2);
      line-height: 1.6;
    }

    .nf-desc a {
      color: var(--color-vermilion);
      font-weight: 600;
    }
    .nf-desc a:hover {
      text-decoration: underline;
    }

    .nf-desc-en {
      font-size: 0.85rem;
      color: var(--color-ink-3);
      font-style: italic;
    }

    .nf-suggested {
      list-style: none;
      margin: 1.5rem 0 0;
      padding: 0;
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      justify-content: center;
    }

    .nf-suggested a {
      display: inline-block;
      padding: 0.5rem 1rem;
      background: var(--color-paper-2);
      border: 1px solid var(--color-line);
      border-radius: 999px;
      color: var(--color-ink);
      font-size: 0.9rem;
    }
    .nf-suggested a:hover {
      background: var(--color-paper-3);
      color: var(--color-ink);
    }
  </style>
</Base>
