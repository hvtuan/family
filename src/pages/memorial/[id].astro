---
export const prerender = false;

import Base from "@/layouts/Base.astro";
import MemorialHero from "@/components/astro/MemorialHero.astro";
import MemorialBio from "@/components/astro/MemorialBio.astro";
import MemorialQuotes from "@/components/astro/MemorialQuotes.astro";
import MemorialTraditions from "@/components/astro/MemorialTraditions.astro";
import LotusSeal from "@/components/astro/LotusSeal.astro";
import IncenseButton from "@/components/react/IncenseButton";
import CondolenceForm from "@/components/react/CondolenceForm";
import CondolenceBook from "@/components/react/CondolenceBook";
import { getMemorialMember } from "@/lib/memorial";
import { getAnniversariesForMember, getUpcomingAnniversaries } from "@/lib/anniversary";
import { listApprovedFor } from "@/lib/condolences";
import { getLocale } from "@/i18n";
import { getSiteIdentity } from "@/lib/settings";
import { solarToLunar, ganZhiOfYearVi } from "@/lib/lunar";

const id = Astro.params.id!;
const member = await getMemorialMember(id);

if (!member) {
  return Astro.redirect("/404");
}
if (!member.memorialEnabled) {
  return Astro.redirect("/members?member=" + id);
}

const lang = getLocale(Astro);
const SITE = await getSiteIdentity();
const surname = SITE.surname || "Nguyễn";

const [ownNext, familyUpcoming, condolences] = await Promise.all([
  getAnniversariesForMember(id, 1),
  getUpcomingAnniversaries({ withinDays: 365 }),
  listApprovedFor(id, { limit: 20 }),
]);

// Closest upcoming giỗ for THIS member (1-line callout above the list).
const ownNextAnniversary = ownNext[0] ?? null;

// Upcoming giỗ of OTHER deceased members in the family (Facebook-style).
const otherUpcoming = familyUpcoming
  .filter((a) => a.member.id !== id)
  .slice(0, 6);

const currentYear = new Date().getFullYear();
const ogUrl = `/og/memorial/${id}.png?lang=${lang}`;

const condolencesSerialized = condolences.map((c) => ({
  id: c.id,
  visitorName: c.visitorName,
  visitorRelation: c.visitorRelation,
  body: c.body,
  createdAt: c.createdAt.toISOString(),
}));

const pageTitle = `Tưởng niệm ${member.name}`;
const pageDescription = member.bio?.slice(0, 160) ?? `Trang tưởng niệm ${member.name} — gia phả họ ${surname}.`;
---

<Base
  title={pageTitle}
  description={pageDescription}
  pageKey="memorial"
  ogImageUrl={ogUrl}
>
  <MemorialHero member={member} />

  <MemorialBio bio={member.bio} bodyMd={(member as { bodyMd?: string }).bodyMd ?? null} />

  <!-- "Thắp một nén tâm hương" — sticky-ish primary action -->
  <section class="max-w-[760px] mx-auto px-5 pb-10 text-center">
    <IncenseButton
      client:load
      memberId={member.id}
      initialCount={member.incenseCountThisYear}
      anniversaryYear={currentYear}
      lang={lang}
      memorialEnabled={member.memorialEnabled}
    />
  </section>

  <MemorialQuotes memberId={member.id} memberName={member.name} />

  <MemorialTraditions member={member} />

  <!-- Lời tưởng nhớ (condolence book) -->
  <section class="max-w-[860px] mx-auto px-5 pt-4 pb-16">
    <header class="text-center mb-8">
      <p class="u-kicker">Lời tưởng nhớ</p>
      <h2
        class="font-display italic text-ink m-0 mt-2"
        style="font-size: var(--text-2xl);"
      >
        Những dòng tưởng nhớ {member.name}
      </h2>
      <div class="mt-4">
        <CondolenceForm client:load memberId={member.id} lang={lang} />
      </div>
    </header>

    <CondolenceBook
      client:load
      memberId={member.id}
      initial={condolencesSerialized}
      lang={lang}
    />
  </section>

  <!-- "Giỗ tiếp theo" 1-line callout for THIS member -->
  {ownNextAnniversary && (
    <section class="max-w-[760px] mx-auto px-5 pb-6">
      <div class="rounded-md border border-gold-2/40 bg-cream/60 px-5 py-3 flex items-center gap-3 text-sm">
        <span aria-hidden="true">🌸</span>
        <p class="m-0 leading-tight flex-1 text-ink">
          <span class="text-ink-2">Giỗ tiếp theo của {member.name}:</span>
          <span class="font-semibold text-ink tabular-nums ml-1.5">
            {(() => {
              const d = ownNextAnniversary.date;
              return `${String(d.getDate()).padStart(2,"0")}/${String(d.getMonth()+1).padStart(2,"0")}/${d.getFullYear()}`;
            })()}
          </span>
          <span class="text-ink-3 text-xs ml-1.5">
            (Năm {ganZhiOfYearVi(solarToLunar(ownNextAnniversary.date).year)})
          </span>
        </p>
        <span class="text-ink-3 text-xs whitespace-nowrap">
          {ownNextAnniversary.daysUntil === 0
            ? "hôm nay"
            : `còn ${ownNextAnniversary.daysUntil} ngày`}
        </span>
      </div>
    </section>
  )}

  <!-- Family-wide upcoming anniversaries — Facebook-style "ngày giỗ
       của các thành viên khác". Helps visitors see the next people to
       honour. Hidden when the family has only one deceased. -->
  {otherUpcoming.length > 0 && (
    <section class="max-w-[760px] mx-auto px-5 pb-16">
      <div class="rounded-md border border-gold-2/30 bg-cream/40 p-6">
        <header class="text-center mb-5">
          <p class="u-kicker">Ngày giỗ sắp tới trong gia đình</p>
          <p class="mt-1 text-xs text-ink-3 m-0">
            Của các thành viên khác đã khuất
          </p>
        </header>
        <ul class="list-none m-0 p-0 grid gap-3">
          {otherUpcoming.map((a) => {
            const dd = String(a.date.getDate()).padStart(2, "0");
            const mm = String(a.date.getMonth() + 1).padStart(2, "0");
            const yy = a.date.getFullYear();
            const ganZhi = ganZhiOfYearVi(solarToLunar(a.date).year);
            const m = a.member;
            const memberHref = `/memorial/${m.id}`;
            return (
              <li>
                <a
                  href={memberHref}
                  class="group flex items-center gap-4 rounded-md border border-transparent hover:border-gold-2/30 hover:bg-paper/40 px-3 py-2 transition-colors"
                >
                  <!-- Mini sepia portrait -->
                  <span
                    class="block shrink-0 overflow-hidden rounded-md border border-gold-2/40"
                    style="width: 48px; height: 60px;"
                  >
                    {m.photoUrl ? (
                      <img
                        src={m.photoUrl}
                        alt={m.name}
                        class="w-full h-full object-cover"
                        style="filter: sepia(0.18) saturate(0.9);"
                        loading="lazy"
                      />
                    ) : (
                      <span class="flex w-full h-full items-center justify-center bg-paper-2/50 text-gold-2/40 font-display italic text-lg">
                        {m.name.slice(0, 1)}
                      </span>
                    )}
                  </span>

                  <div class="flex-1 min-w-0">
                    <p class="m-0 font-display italic text-ink text-base group-hover:text-vermilion transition-colors truncate">
                      {m.name}
                    </p>
                    <p class="m-0 text-xs text-ink-3 mt-0.5 tabular-nums">
                      <span class="font-semibold text-ink-2">{`${dd}/${mm}/${yy}`}</span>
                      <span class="mx-1.5 opacity-50">·</span>
                      Năm {ganZhi}
                    </p>
                  </div>

                  <span class="text-ink-3 text-xs shrink-0 whitespace-nowrap">
                    {a.daysUntil === 0
                      ? "hôm nay"
                      : a.daysUntil === 1
                        ? "ngày mai"
                        : `còn ${a.daysUntil} ngày`}
                  </span>
                </a>
              </li>
            );
          })}
        </ul>

        <div class="mt-5 text-center">
          <a class="text-sm text-jade hover:text-vermilion transition-colors" href="/altar">
            Xem toàn bộ bàn thờ tổ tiên →
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Footer seal -->
  <div class="flex justify-center pb-12 opacity-60">
    <LotusSeal surname={surname} size="sm" />
  </div>
</Base>
