---
export const prerender = false;

import Base from "@/layouts/Base.astro";
import MemorialHero from "@/components/astro/MemorialHero.astro";
import MemorialBio from "@/components/astro/MemorialBio.astro";
import MemorialQuotes from "@/components/astro/MemorialQuotes.astro";
import MemorialTraditions from "@/components/astro/MemorialTraditions.astro";
import LotusSeal from "@/components/astro/LotusSeal.astro";
import IncenseButton from "@/components/react/IncenseButton";
import CondolenceForm from "@/components/react/CondolenceForm";
import CondolenceBook from "@/components/react/CondolenceBook";
import { getMemorialMember } from "@/lib/memorial";
import { getAnniversariesForMember } from "@/lib/anniversary";
import { listApprovedFor } from "@/lib/condolences";
import { getLocale } from "@/i18n";
import { getSiteIdentity } from "@/lib/settings";

const id = Astro.params.id!;
const member = await getMemorialMember(id);

if (!member) {
  return Astro.redirect("/404");
}
if (!member.memorialEnabled) {
  return Astro.redirect("/members?member=" + id);
}

const lang = getLocale(Astro);
const SITE = await getSiteIdentity();
const surname = SITE.surname || "Nguyễn";

const [anniversaries, condolences] = await Promise.all([
  getAnniversariesForMember(id, 5),
  listApprovedFor(id, { limit: 20 }),
]);

const currentYear = new Date().getFullYear();
const ogUrl = `/og/memorial/${id}.png?lang=${lang}`;

const condolencesSerialized = condolences.map((c) => ({
  id: c.id,
  visitorName: c.visitorName,
  visitorRelation: c.visitorRelation,
  body: c.body,
  createdAt: c.createdAt.toISOString(),
}));

const pageTitle = `Tưởng niệm ${member.name}`;
const pageDescription = member.bio?.slice(0, 160) ?? `Trang tưởng niệm ${member.name} — gia phả họ ${surname}.`;
---

<Base
  title={pageTitle}
  description={pageDescription}
  pageKey="memorial"
  ogImageUrl={ogUrl}
>
  <MemorialHero member={member} />

  <MemorialBio bio={member.bio} bodyMd={(member as { bodyMd?: string }).bodyMd ?? null} />

  <!-- "Thắp một nén tâm hương" — sticky-ish primary action -->
  <section class="max-w-[760px] mx-auto px-5 pb-10 text-center">
    <IncenseButton
      client:load
      memberId={member.id}
      initialCount={member.incenseCountThisYear}
      anniversaryYear={currentYear}
      lang={lang}
      memorialEnabled={member.memorialEnabled}
    />
  </section>

  <MemorialQuotes memberId={member.id} memberName={member.name} />

  <MemorialTraditions member={member} />

  <!-- Lời tưởng nhớ (condolence book) -->
  <section class="max-w-[860px] mx-auto px-5 pt-4 pb-16">
    <header class="text-center mb-8">
      <p class="u-kicker">Lời tưởng nhớ</p>
      <h2
        class="font-display italic text-ink m-0 mt-2"
        style="font-size: var(--text-2xl);"
      >
        Những dòng tưởng nhớ {member.name}
      </h2>
      <div class="mt-4">
        <CondolenceForm client:load memberId={member.id} lang={lang} />
      </div>
    </header>

    <CondolenceBook
      client:load
      memberId={member.id}
      initial={condolencesSerialized}
      lang={lang}
    />
  </section>

  <!-- Anniversary lookahead — small footer card -->
  {anniversaries.length > 0 && (
    <section class="max-w-[760px] mx-auto px-5 pb-16">
      <div class="rounded-md border border-gold-2/30 bg-cream/40 p-6">
        <p class="u-kicker text-center">Những ngày giỗ sắp tới</p>
        <ul class="list-none m-0 p-0 mt-4 grid gap-2 text-sm text-ink-2">
          {anniversaries.slice(0, 5).map((a) => {
            const dd = String(a.date.getDate()).padStart(2, "0");
            const mm = String(a.date.getMonth() + 1).padStart(2, "0");
            const yy = a.date.getFullYear();
            const typeLabel = a.type === "lunar" ? "Âm lịch" : "Dương lịch";
            return (
              <li class="flex justify-between border-b border-line/50 pb-1.5 last:border-0">
                <span>
                  <span class="font-semibold text-ink">{`${dd}/${mm}/${yy}`}</span>
                  <span class="ml-2 text-xs text-ink-3">({typeLabel})</span>
                </span>
                <span class="text-ink-3">
                  {a.daysUntil === 0
                    ? "hôm nay"
                    : `còn ${a.daysUntil} ngày`}
                </span>
              </li>
            );
          })}
        </ul>
      </div>
    </section>
  )}

  <!-- Footer seal -->
  <div class="flex justify-center pb-12 opacity-60">
    <LotusSeal surname={surname} size="sm" />
  </div>
</Base>
